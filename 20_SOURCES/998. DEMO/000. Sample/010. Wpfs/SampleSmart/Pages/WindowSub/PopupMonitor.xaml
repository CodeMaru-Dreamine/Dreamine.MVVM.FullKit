<Window x:Class="SampleSmart.Pages.WindowSub.PopupMonitor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="320"
        WindowStartupLocation="CenterOwner"
        Title="Monitor">

    <Grid Background="White" Margin="18">
        <StackPanel>
            <TextBlock Text="📊 Popup Monitor"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0 0 0 16"/>

            <TextBlock Text="현재 WindowStateService 상태"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0 0 0 8"/>

            <Border BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Background="#FAFAFA">
                <TextBlock Text="{Binding WindowStateSummary}"
                           FontSize="14"
                           TextWrapping="Wrap"
                           LineHeight="24"/>
            </Border>

            <Button Content="새로고침"
                    Width="100"
                    Height="32"
                    HorizontalAlignment="Right"
                    Margin="0 18 0 0"
                    Command="{Binding RefreshCommand}"/>
        </StackPanel>
    </Grid>
</Window>