<UserControl x:Class="SampleSmart.Pages.PageSub.PageCommunicationMonitor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:commViews="clr-namespace:Dreamine.Communication.Wpf.Views;assembly=Dreamine.Communication.Wpf"
             xmlns:tabs="clr-namespace:SampleSmart.Pages.PageSub.CommunicationTabs"
             MinWidth="1200"
             MinHeight="650">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="256" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Dreamine Communication Sample"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <TabControl Grid.Row="1"
                    Margin="0,0,0,8">
            <TabItem Header="InMemory">
                <tabs:InMemoryCommunicationTab />
            </TabItem>

            <TabItem Header="TCP">
                <tabs:TcpCommunicationTab />
            </TabItem>
        </TabControl>

        <commViews:CommunicationMonitorView Grid.Row="2"
                                            DataContext="{Binding Monitor}" />
    </Grid>
</UserControl>
