<UserControl x:Class="SampleSmart.Pages.PageSub.PageCommunicationMonitor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:commViews="clr-namespace:Dreamine.Communication.Wpf.Views;assembly=Dreamine.Communication.Wpf"
             MinWidth="1200"
             MinHeight="520">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8"
                Margin="0,0,0,8">
            <DockPanel>
                <TextBlock Text="Dreamine Communication Sample"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right">

                    <!-- InMemory Sample -->
                    <Button Content="Add Channel"
                            Width="110"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding AddChannelCommand}" />

                    <Button Content="Connect"
                            Width="90"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding ConnectCommand}" />

                    <Button Content="Disconnect"
                            Width="100"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding DisconnectCommand}" />

                    <Button Content="Send Test"
                            Width="100"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding SendTestCommand}" />

                    <Button Content="Receive Test"
                            Width="110"
                            Height="30"
                            Margin="0,0,16,0"
                            Command="{Binding ReceiveTestCommand}" />

                    <!-- TCP Loopback Sample -->
                    <Button Content="Start TCP"
                            Width="100"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding StartTcpServerCommand}" />

                    <Button Content="Connect TCP"
                            Width="110"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding ConnectTcpClientCommand}" />

                    <Button Content="Send TCP"
                            Width="90"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding SendTcpCommand}" />

                    <Button Content="Stop TCP"
                            Width="90"
                            Height="30"
                            Command="{Binding StopTcpCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <commViews:CommunicationMonitorView Grid.Row="1"
                                            DataContext="{Binding Monitor}" />
    </Grid>
</UserControl>