<UserControl x:Class="SampleSmart.Pages.PageSub.CommunicationTabs.SerialCommunicationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:serial="clr-namespace:SampleSmart.Pages.PageSub.CommunicationTabs.Serial"
             MinWidth="600"
             MinHeight="300">

    <Border Background="White"
            BorderBrush="#DDD"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Serial Communication Test"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TabControl Grid.Row="1">
                <TabItem Header="Port Test">
                    <serial:SerialPortTestView />
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>