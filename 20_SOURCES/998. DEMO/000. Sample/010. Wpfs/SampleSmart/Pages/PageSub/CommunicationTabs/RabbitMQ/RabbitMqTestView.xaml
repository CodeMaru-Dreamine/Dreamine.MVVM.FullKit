<UserControl x:Class="SampleSmart.Pages.PageSub.CommunicationTabs.RabbitMQ.RabbitMqTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White"
            BorderBrush="#DDD"
            BorderThickness="1"
            CornerRadius="6"
            Padding="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0"
                        Margin="0,0,0,6">
                <TextBlock Text="RabbitMQ Test"
                           FontSize="15"
                           FontWeight="SemiBold" />

                <TextBlock Text="Connect to RabbitMQ, subscribe to a route, and publish MessageEnvelope payloads."
                           Foreground="Gray"
                           FontSize="11"
                           Margin="0,2,0,0" />
            </StackPanel>

            <!-- Connection -->
            <Grid Grid.Row="1"
                  Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Host"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="1"
                         Height="24"
                         Margin="4,0"
                         Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="2"
                           Text="Port"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="3"
                         Height="24"
                         Margin="4,0"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="4"
                           Text="Virtual"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="5"
                         Height="24"
                         Margin="4,0"
                         Text="{Binding VirtualHost, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <!-- Account -->
            <Grid Grid.Row="2"
                  Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="User"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="1"
                         Height="24"
                         Margin="4,0"
                         Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="2"
                           Text="Password"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="3"
                         Height="24"
                         Margin="4,0"
                         Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <!-- Exchange / Queue -->
            <Grid Grid.Row="3"
                  Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Exchange"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="1"
                         Height="24"
                         Margin="4,0"
                         Text="{Binding ExchangeName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="2"
                           Text="Queue"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="3"
                         Height="24"
                         Margin="4,0"
                         Text="{Binding QueueName, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <!-- Routing / Message -->
            <Grid Grid.Row="4"
                  Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Routing"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="1"
                         Height="24"
                         Margin="4,0"
                         Text="{Binding RoutingKey, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="2"
                           Text="Message"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Column="3"
                         Height="24"
                         Margin="4,0"
                         Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <!-- Bottom -->
            <Grid Grid.Row="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Buttons -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,6">

                    <Button Content="Connect"
                            Width="100"
                            Height="28"
                            Margin="0,0,6,0"
                            Command="{Binding ConnectRabbitMqCommand}" />

                    <Button Content="Subscribe"
                            Width="100"
                            Height="28"
                            Margin="0,0,6,0"
                            Command="{Binding SubscribeRabbitMqCommand}" />

                    <Button Content="Publish"
                            Width="100"
                            Height="28"
                            Margin="0,0,6,0"
                            Command="{Binding PublishRabbitMqCommand}" />

                    <Button Content="Disconnect"
                            Width="100"
                            Height="28"
                            Command="{Binding DisconnectRabbitMqCommand}" />
                </StackPanel>

                <!-- Summary -->
                <Border Grid.Row="1"
                        BorderBrush="#EEE"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="6">

                    <TextBlock Text="{Binding RabbitMqSelectionSummary}"
                               Foreground="Gray"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>