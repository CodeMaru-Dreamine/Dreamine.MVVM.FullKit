<UserControl x:Class="SampleSmart.Pages.PageSub.CommunicationTabs.UdpCommunicationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:udp="clr-namespace:SampleSmart.Pages.PageSub.CommunicationTabs.Udp">
    <Border Background="White"
            BorderBrush="#DDD"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="UDP Communication Test"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TabControl Grid.Row="1">
                <TabItem Header="Peer Loopback">
                    <udp:UdpPeerTestView />
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
