<UserControl x:Class="SampleSmart.Pages.PageSub.CommunicationTabs.TcpCommunicationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tcp="clr-namespace:SampleSmart.Pages.PageSub.CommunicationTabs.Tcp">
    <Border Background="White"
            BorderBrush="#DDD"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="TCP Communication Test"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TabControl Grid.Row="1">
                <TabItem Header="Loopback">
                    <tcp:TcpLoopbackTestView />
                </TabItem>

                <TabItem Header="Client Test">
                    <tcp:TcpClientTestView />
                </TabItem>

                <TabItem Header="Server Test">
                    <tcp:TcpServerTestView />
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
