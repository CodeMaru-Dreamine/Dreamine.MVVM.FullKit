<UserControl x:Class="SampleSmart.Pages.PageSub.CommunicationTabs.Tcp.TcpServerTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White"
            BorderBrush="#DDD"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">
        <StackPanel>
            <TextBlock Text="Dreamine Server + External TCP Client"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TextBlock Text="Select protocol mode, start the Dreamine TCP server, then connect using Hercules TCP Client."
                       Foreground="Gray"
                       Margin="0,0,0,8" />

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,8">
                <TextBlock Text="Protocol"
                           Width="80"
                           VerticalAlignment="Center" />

                <ComboBox Width="180"
                          Height="28"
                          Margin="0,0,8,0"
                          ItemsSource="{Binding TcpServerProtocols}"
                          SelectedItem="{Binding SelectedTcpServerProtocol}" />

                <TextBlock Text="Encoding"
                           Width="70"
                           VerticalAlignment="Center" />

                <ComboBox Width="110"
                          Height="28"
                          Margin="0,0,8,0"
                          ItemsSource="{Binding TcpServerEncodings}"
                          SelectedItem="{Binding SelectedTcpServerEncoding}" />

                <Button Content="Start Server"
                        Width="120"
                        Height="30"
                        Margin="0,0,8,0"
                        Command="{Binding StartServerCommand}" />

                <Button Content="Stop Server"
                        Width="120"
                        Height="30"
                        Command="{Binding StopServerCommand}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Send"
                           Width="80"
                           VerticalAlignment="Center" />

                <TextBox Width="500"
                         Height="30"
                         Margin="0,0,8,0"
                         Text="{Binding TcpServerSendText, UpdateSourceTrigger=PropertyChanged}" />

                <Button Content="Send"
                        Width="100"
                        Height="30"
                        Command="{Binding SendServerCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>