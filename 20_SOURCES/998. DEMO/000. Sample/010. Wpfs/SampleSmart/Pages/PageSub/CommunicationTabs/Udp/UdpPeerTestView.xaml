<UserControl x:Class="SampleSmart.Pages.PageSub.CommunicationTabs.Udp.UdpPeerTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White"
            BorderBrush="#DDD"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">
        <StackPanel>
            <TextBlock Text="Dreamine UDP Peer Loopback Test"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TextBlock Text="UDP Peer A and Peer B are bound to different local ports. Each peer sends datagrams to the other peer."
                       Foreground="Gray"
                       Margin="0,0,0,8" />

            <TextBlock Text="{Binding UdpEndpointSummary}"
                       Foreground="Gray"
                       Margin="0,0,0,8" />

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,8">
                <TextBlock Text="Protocol"
                           Width="80"
                           VerticalAlignment="Center" />

                <ComboBox Width="180"
                          Height="28"
                          Margin="0,0,8,0"
                          ItemsSource="{Binding UdpProtocols}"
                          SelectedItem="{Binding SelectedUdpProtocol}" />

                <TextBlock Text="Encoding"
                           Width="70"
                           VerticalAlignment="Center" />

                <ComboBox Width="100"
                          Height="28"
                          Margin="0,0,8,0"
                          ItemsSource="{Binding UdpTextEncodings}"
                          SelectedItem="{Binding SelectedUdpEncoding}" />

                <Button Content="Start Loopback"
                        Width="130"
                        Height="30"
                        Margin="0,0,8,0"
                        Command="{Binding StartUdpLoopbackCommand}" />

                <Button Content="Stop Loopback"
                        Width="120"
                        Height="30"
                        Command="{Binding StopUdpLoopbackCommand}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,8">
                <TextBlock Text="Send"
                           Width="80"
                           VerticalAlignment="Center" />

                <TextBox Width="500"
                         Height="30"
                         Margin="0,0,8,0"
                         Text="{Binding UdpSendText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text=""
                           Width="80" />

                <Button Content="Send Peer A"
                        Width="120"
                        Height="30"
                        Margin="0,0,8,0"
                        Command="{Binding SendUdpPeerACommand}" />

                <Button Content="Send Peer B"
                        Width="120"
                        Height="30"
                        Margin="0,0,8,0"
                        Command="{Binding SendUdpPeerBCommand}" />

                <Button Content="Connect A"
                        Width="100"
                        Height="30"
                        Margin="0,0,8,0"
                        Command="{Binding ConnectUdpPeerACommand}" />

                <Button Content="Connect B"
                        Width="100"
                        Height="30"
                        Margin="0,0,8,0"
                        Command="{Binding ConnectUdpPeerBCommand}" />

                <Button Content="Disconnect A"
                        Width="110"
                        Height="30"
                        Margin="0,0,8,0"
                        Command="{Binding DisconnectUdpPeerACommand}" />

                <Button Content="Disconnect B"
                        Width="110"
                        Height="30"
                        Command="{Binding DisconnectUdpPeerBCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
