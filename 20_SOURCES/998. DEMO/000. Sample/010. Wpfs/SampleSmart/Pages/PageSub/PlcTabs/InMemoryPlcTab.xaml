<UserControl x:Class="SampleSmart.Pages.PageSub.PlcTabs.InMemoryPlcTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10">
        <StackPanel>
            <TextBlock Text="InMemory PLC Test" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="외부 PLC 없이 메모리 기반 Read/Write를 검증합니다. Connect 후 D100/M10 등에 Write → Read 순서로 테스트하십시오."
                       TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,10" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Use InMemory Client" Width="160" Command="{Binding UseInMemoryCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
