<UserControl x:Class="SampleSmart.Pages.PageSub.PageIoMonitor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="1200"
             MinHeight="650">
    <UserControl.Resources>
        <Style x:Key="IoPointBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="128" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderBrush" Value="#DDD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#F8FAFC" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Dreamine I/O Sample"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Fastech Ethernet 16 DI / 16 DO"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal">
                    <TextBlock Text="Host"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBox Width="130"
                             Height="28"
                             Margin="0,0,12,0"
                             Text="{Binding Runtime.Host, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Port"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBox Width="70"
                             Height="28"
                             Margin="0,0,12,0"
                             Text="{Binding Runtime.PortText, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Content="Use Real UDP"
                            Width="115"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding UseRealControllerCommand}" />
                    <Button Content="Use Sample"
                            Width="105"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding UseSampleControllerCommand}" />
                    <Button Content="Connect"
                            Width="90"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding ConnectCommand}" />
                    <Button Content="Probe"
                            Width="80"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding ProbeHardwareCommand}" />
                    <Button Content="Disconnect"
                            Width="100"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding DisconnectCommand}" />
                    <Button Content="Toggle DI"
                            Width="90"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding ToggleInputsCommand}" />
                    <Button Content="Read DI"
                            Width="90"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding RefreshInputsCommand}" />
                    <Button Content="Write DO"
                            Width="90"
                            Height="30"
                            Margin="0,0,8,0"
                            Command="{Binding WriteOutputsCommand}" />
                    <Button Content="Read DO"
                            Width="90"
                            Height="30"
                            Command="{Binding ReadOutputsCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,0,4,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Digital Inputs"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <ItemsControl ItemsSource="{Binding Runtime.Inputs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource IoPointBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ValueText}"
                                                       Foreground="#475569" />
                                        </StackPanel>
                                        <Ellipse Grid.Column="1"
                                                 Width="18"
                                                 Height="18"
                                                 VerticalAlignment="Center"
                                                 Stroke="#CBD5E1"
                                                 StrokeThickness="1">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#E2E8F0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Value}" Value="True">
                                                            <Setter Property="Fill" Value="#22C55E" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Margin="4,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Digital Outputs"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <ItemsControl ItemsSource="{Binding Runtime.Outputs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource IoPointBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ValueText}"
                                                       Foreground="#475569" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="1"
                                                  Width="22"
                                                  Height="22"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Background="#F8FAFC"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,8,0,0">
            <TextBlock Text="{Binding Runtime.StatusMessage}"
                       Foreground="#334155"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
