<UserControl x:Class="SampleSmart.Pages.PageSub.PageDatabase"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="620" d:DesignWidth="1100">
    <Grid Background="#FAFAFA" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Dreamine Database"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#222" />
                <TextBlock Text="SQLite, MySQL, Oracle, and MS SQL providers share the same Dreamine CRUD surface."
                           FontSize="12"
                           Foreground="#666"
                           Margin="0,6,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding SelectedProviderTab.StatusMessage}"
                       DockPanel.Dock="Right"
                       FontSize="13"
                       Foreground="#286B3A"
                       VerticalAlignment="Center"
                       TextAlignment="Right" />
        </DockPanel>

        <TabControl Grid.Row="1"
                    ItemsSource="{Binding ProviderTabs}"
                    SelectedItem="{Binding SelectedProviderTab}"
                    Margin="0,16,0,0"
                    Background="White">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" />
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid Background="#FAFAFA" Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="14"
                                Background="White"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Connection string" FontSize="12" Foreground="#555" />
                                    <TextBox Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32"
                                             Margin="0,4,12,0"
                                             Padding="8,4" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Initialize"
                                        Width="96"
                                        Height="32"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding InitializeCommand}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0,12,0,12"
                                Padding="14"
                                Background="White"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Name" FontSize="12" Foreground="#555" />
                                    <TextBox Text="{Binding NameInput, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32"
                                             Margin="0,4,0,0"
                                             Padding="8,4" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="Role" FontSize="12" Foreground="#555" />
                                    <TextBox Text="{Binding RoleInput, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32"
                                             Margin="0,4,0,0"
                                             Padding="8,4" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <Button Content="Add"
                                            Width="76"
                                            Height="32"
                                            Command="{Binding AddCommand}" />
                                    <Button Content="Update"
                                            Width="76"
                                            Height="32"
                                            Margin="8,0,0,0"
                                            Command="{Binding UpdateCommand}" />
                                    <Button Content="Delete"
                                            Width="76"
                                            Height="32"
                                            Margin="8,0,0,0"
                                            Command="{Binding DeleteCommand}" />
                                    <Button Content="Refresh"
                                            Width="76"
                                            Height="32"
                                            Margin="8,0,0,0"
                                            Command="{Binding RefreshCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  Background="White"
                                  BorderBrush="#DDD"
                                  BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="*" />
                                <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="180" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</UserControl>
