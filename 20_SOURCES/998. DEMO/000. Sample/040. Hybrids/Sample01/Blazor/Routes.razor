@*!
  \file Blazor/Routes.razor
  \brief Router/RouteView를 캡슐화한 라우팅 컴포넌트
*@

@namespace Sample01.Blazor
@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="@typeof(Sample01.Blazor.Routes).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" />
    </Found>

    <NotFound>
        <h3 class="m-3">페이지를 찾을 수 없습니다.</h3>
    </NotFound>
</Router>