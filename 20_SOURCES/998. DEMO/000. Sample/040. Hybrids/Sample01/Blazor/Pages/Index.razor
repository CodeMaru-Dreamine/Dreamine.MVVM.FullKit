@page "/"
@namespace Sample01.Blazor.Pages

@using System.Globalization
@using Sample01.Blazor.Components
@using Sample01.Blazor.ViewModels

@inject IndexViewModel VM

<!-- \file Blazor/Pages/Index.razor -->
<!-- \brief Dreamine 대시보드 + JS 단일 버튼 테스트(충돌 진단용) -->
<!-- \details Blazor 서버 인터랙티브와 순수 JS 이벤트를 동시에 검증한다. -->
<!-- \author Dreamine -->
<!-- \date 2025-11-06 -->
<!-- \version 1.0.1 -->

<PageTitle>Dreamine Dashboard</PageTitle>

<div class="page-container">
    <header class="page-header">
        <h1>🌌 Dreamine Dashboard</h1>
        <p>현실과 타협하지 않는 완전 무결한 프레임워크의 시작점</p>
    </header>

    <section class="card-grid">
        <div class="card">
            <h3>🚀 프로젝트</h3>
            <p>현재 진행 중인 프로젝트 현황 및 최근 변경 사항을 확인합니다.</p>
            <button class="primary-btn" @onclick="VM.OpenProjectAsync">열기</button>
        </div>

        <div class="card">
            <h3>📦 NuGet 패키지</h3>
            <p>Dreamine All-in-One 패키지 및 구성 요소 관리.</p>
            <button class="primary-btn" @onclick="VM.OpenNugetAsync">열기</button>
        </div>

        <div class="card">
            <h3>📘 문서</h3>
            <p>MD, HiddenLogs, TODO, Lore 문서에 바로 접근합니다.</p>
            <button class="primary-btn" @onclick="VM.OpenDocsAsync">열기</button>
        </div>

        <div class="card">
            <h3>⚙️ 설정</h3>
            <p>Host, DI Container, CLI 설정 등 시스템 초기화 옵션 관리.</p>
            <button class="primary-btn" @onclick="VM.OpenSettingsAsync">열기</button>
        </div>

        <!-- =========================
             🧪 순수 JS 버튼 테스트 섹션
             ========================= -->
        <div class="card">
            <h3>🧪 JS 테스트</h3>
            <p class="text-muted">Blazor 부트스트랩과 무관하게 DOM/이벤트만 확인</p>
            <button id="jsBtn" class="primary-btn">JS Click</button>
            <p id="jsMsg" class="mt-2"></p>
        </div>
    </section>

    <section class="mt-4">
        <LocalCounter />
    </section>

    <footer class="footer">
        <p>@DateTime.Now.ToString("yyyy.MM.dd HH:mm", CultureInfo.InvariantCulture)</p>
        <small>Dreamine Framework © 2025 CodeMaru</small>
    </footer>
</div>

<!-- /// \brief 페이지 전용 테스트 스크립트(한 번만 로드) -->
<!-- /// \details 서버 렌더링 문맥에서 중복 로드를 방지하기 위해 즉시 실행 + 단일 바인딩 -->
<script>
    /** \brief JS 버튼 클릭 이벤트를 바인딩하고 메시지를 갱신한다. */
    (function attachOnce() {
      const btn = document.getElementById('jsBtn');
      const msg = document.getElementById('jsMsg');
      if (!btn || !msg) return;

      if (!btn.dataset.bound) {
        btn.addEventListener('click', function () {
          const t = new Date().toLocaleTimeString();
          msg.textContent = `✅ JS 버튼 클릭됨 (${t})`;
          console.log('[Index] JS button clicked at', t);
        });
        btn.dataset.bound = '1';
      }
    })();
</script>