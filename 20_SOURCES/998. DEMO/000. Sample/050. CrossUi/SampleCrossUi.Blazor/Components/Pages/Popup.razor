@page "/popup"
@rendermode InteractiveServer
@inject DreamineDialogService DialogService

<h3>Popup Demo</h3>

<button class="btn" style="background-color:#0d1b3e;color:white;" @onclick="ShowMessageBox">DreamineMessageBox (5s auto-close)</button>
<button class="btn ms-2" style="background-color:#0d1b3e;color:white;" @onclick="ShowBlinkOk">BlinkPopup — 완료 알림</button>
<button class="btn ms-2" style="background-color:#0d1b3e;color:white;" @onclick="ShowBlinkAlarm">BlinkPopup — 설비 ALARM (점멸)</button>

<p class="mt-3 fst-italic">@LastResult</p>

@code {
    private string LastResult = "Last result: —";

    private async Task ShowMessageBox()
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "DreamineMessageBox 데모입니다.\n버튼을 클릭하거나 기다리면 자동으로 닫힙니다.",
            "MessageBox Demo",
            autoClickDelaySeconds: 5);
        LastResult = $"Last result: MessageBox → {result}";
    }

    private async Task ShowBlinkOk()
    {
        var result = await DialogService.ShowBlinkAsync(new BlinkPopupOptions
        {
            Title = "작업 완료",
            Message = "작업이 성공적으로 완료되었습니다.",
            UseBlink = false,
            Color1 = "#0D1B3E",
            Color2 = "#0D1B3E",
            ForegroundColor = "#FFFFFF",
            OkText = "확인"
        });
        LastResult = $"Last result: BlinkPopup(OK) → {result}";
    }

    private async Task ShowBlinkAlarm()
    {
        var result = await DialogService.ShowBlinkAsync(new BlinkPopupOptions
        {
            Title = "⚠ ALARM",
            Message = "설비 이상이 감지되었습니다.\n운영자 확인이 필요합니다.",
            UseBlink = true,
            BlinkIntervalMs = 400,
            Color1 = "#B41E1E",
            Color2 = "#500A0A",
            ForegroundColor = "#FFD700",
            OkText = "확인",
            CancelText = "취소"
        });
        LastResult = $"Last result: BlinkPopup(Alarm) → {result}";
    }
}
