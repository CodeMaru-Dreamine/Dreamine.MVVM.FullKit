@page "/controls"
@rendermode InteractiveServer
@implements IDisposable
@inject ControlsViewModel ViewModel
@inject IJSRuntime JS

<h3>Controls Demo</h3>

<div class="dreamine-tabs mb-3">
    @foreach (var tab in _tabs)
    {
        <button class="dreamine-tab-button @(tab == _activeTab ? "active" : "")"
                @onclick="() => _activeTab = tab">@tab</button>
    }
</div>

<div class="controls-stage">
@if (_activeTab == "Button")
{
    <h5>Button</h5>
    <DreamineButton Variant="DreamineButtonVariant.Primary" OnClick="() => ViewModel.ClickMeCommand.Execute(null)">
        Click Me (@ViewModel.ClickCount)
    </DreamineButton>

    <h6 class="mt-3">Color Variants</h6>
    <div class="controls-row">
        <DreamineButton Variant="DreamineButtonVariant.Primary" OnClick='() => SetButtonStatus("Primary")'>Primary</DreamineButton>
        <DreamineButton Variant="DreamineButtonVariant.Success" OnClick='() => SetButtonStatus("Success")'>Success</DreamineButton>
        <DreamineButton Variant="DreamineButtonVariant.Warning" OnClick='() => SetButtonStatus("Warning")'>Warning</DreamineButton>
        <DreamineButton Variant="DreamineButtonVariant.Danger" OnClick='() => SetButtonStatus("Danger")'>Danger</DreamineButton>
    </div>

    <h6 class="mt-3">Size Variants</h6>
    <div class="controls-row">
        <DreamineButton Size="DreamineButtonSize.Small" OnClick='() => SetButtonStatus("Small")'>Small</DreamineButton>
        <DreamineButton Size="DreamineButtonSize.Normal" OnClick='() => SetButtonStatus("Normal")'>Normal</DreamineButton>
        <DreamineButton Size="DreamineButtonSize.Large" OnClick='() => SetButtonStatus("Large")'>Large</DreamineButton>
    </div>

    <h6 class="mt-3">Disabled</h6>
    <DreamineButton Disabled="true">Disabled Button</DreamineButton>

    <p class="mt-3 fst-italic">@_buttonTabStatus</p>
}
else if (_activeTab == "CheckBox / Radio")
{
    <h5>Check Boxes</h5>
    <div class="controls-row">
        <DreamineCheckBox @bind-Checked="ViewModel.Check1">Option 1</DreamineCheckBox>
        <DreamineCheckBox @bind-Checked="ViewModel.Check2">Option 2</DreamineCheckBox>
        <DreamineCheckBox @bind-Checked="ViewModel.Check3">Option 3</DreamineCheckBox>
    </div>

    <h5 class="mt-3">Radio Buttons</h5>
    <div class="controls-row">
        <DreamineRadioButton Name="radioDemo" Value="Option A"
                             SelectedValue="@ViewModel.SelectedRadio"
                             SelectedValueChanged="v => ViewModel.SelectRadioCommand.Execute(v)">Option A</DreamineRadioButton>
        <DreamineRadioButton Name="radioDemo" Value="Option B"
                             SelectedValue="@ViewModel.SelectedRadio"
                             SelectedValueChanged="v => ViewModel.SelectRadioCommand.Execute(v)">Option B</DreamineRadioButton>
        <DreamineRadioButton Name="radioDemo" Value="Option C"
                             SelectedValue="@ViewModel.SelectedRadio"
                             SelectedValueChanged="v => ViewModel.SelectRadioCommand.Execute(v)">Option C</DreamineRadioButton>
    </div>
    <p class="mt-2">Selected: @ViewModel.SelectedRadio</p>
}
else if (_activeTab == "CheckLed")
{
    <h5>CheckLed</h5>
    <div class="controls-row">
        <DreamineButton OnClick="() => ViewModel.ToggleLedCommand.Execute(null)">Toggle LED</DreamineButton>
        <DreamineButton OnClick="() => ViewModel.TogglePulseCommand.Execute(null)">Toggle Pulse</DreamineButton>
        <DreamineCheckLed IsOn="ViewModel.LedIsOn" IsPulse="ViewModel.LedIsPulse" />
        <span>LED: @ViewModel.LedIsOn / Pulse: @ViewModel.LedIsPulse</span>
    </div>

    <h6 class="mt-3">Corner Position 변형</h6>
    <div class="d-flex gap-3">
        <div class="dreamine-led-box"><DreamineCheckLed IsOn="true" Corner="DreamineCheckLedCorner.TopLeft" /></div>
        <div class="dreamine-led-box"><DreamineCheckLed IsOn="true" Corner="DreamineCheckLedCorner.TopRight" /></div>
        <div class="dreamine-led-box"><DreamineCheckLed IsOn="true" Corner="DreamineCheckLedCorner.BottomLeft" /></div>
        <div class="dreamine-led-box"><DreamineCheckLed IsOn="false" Corner="DreamineCheckLedCorner.BottomRight" /></div>
    </div>

    <h6 class="mt-3">Diameter 변형</h6>
    <div class="d-flex align-items-center gap-2">
        <DreamineCheckLed IsOn="true" Diameter="10" />
        <DreamineCheckLed IsOn="true" Diameter="18" />
        <DreamineCheckLed IsOn="true" Diameter="26" />
        <DreamineCheckLed IsOn="true" Diameter="34" />
        <DreamineCheckLed IsOn="true" Diameter="42" />
    </div>
}
else if (_activeTab == "TextBox")
{
    <h5>Text Input</h5>
    <div class="controls-row">
        <DreamineTextBox @bind-Value="ViewModel.TextInput"
                         Hint="Type something (가상 키보드 데모)"
                         OnFocus="() => _showKeyboard = true" />
        <DreamineButton OnClick="() => ViewModel.ClearTextCommand.Execute(null)">Clear Text</DreamineButton>
    </div>

    <div class="controls-row mt-2">
        <DreamineTextBox @bind-Value="ViewModel.Password" IsPassword="true" Hint="Password" />
        <DreamineButton OnClick="() => ViewModel.ClearPasswordCommand.Execute(null)">Clear Password</DreamineButton>
    </div>

    <h6 class="mt-3">Read-Only</h6>
    <DreamineTextBox Value="수정할 수 없는 텍스트입니다." ReadOnly="true" />

    <div class="mt-3">
        <DreamineVirtualKeyboard IsVisible="_showKeyboard"
                                 Value="@ViewModel.TextInput"
                                 ValueChanged="v => ViewModel.TextInput = v"
                                 OnEnter="() => _showKeyboard = false" />
    </div>
}
else if (_activeTab == "ComboBox")
{
    <h5>Fruit Picker</h5>
    <DreamineComboBox Items="ViewModel.FruitItems" @bind-SelectedItem="ViewModel.SelectedFruit" />

    <h6 class="mt-3">Disabled</h6>
    <DreamineComboBox Items="ViewModel.FruitItems" SelectedItem="@ViewModel.FruitItems.First()" Disabled="true" />
}
else if (_activeTab == "DataGrid / ListBox")
{
    <h5>DataGrid</h5>
    <DreamineDataGrid TItem="ControlsDemoRow" Items="ViewModel.GridRows" @bind-SelectedItem="_selectedGridRow">
        <HeaderContent>
            <th>No</th><th>Name</th><th>Status</th>
        </HeaderContent>
        <RowContent>
            <td>@context.No</td><td>@context.Name</td><td>@context.Status</td>
        </RowContent>
    </DreamineDataGrid>
    <p class="fst-italic mt-2">@(_selectedGridRow is null ? "(선택된 행 없음)" : $"선택된 행: No.{_selectedGridRow.No} {_selectedGridRow.Name} ({_selectedGridRow.Status})")</p>

    <h6 class="mt-3">ListBox (더블클릭으로 활성화)</h6>
    <DreamineListBox Items="ViewModel.FruitItems"
                     @bind-SelectedItem="_selectedFruitItem"
                     OnActivate="f => ViewModel.ListBoxActivatedCommand.Execute(f)" />
    <p class="fst-italic mt-2">활성화 결과: @ViewModel.StatusMessage</p>

    <h6 class="mt-3">AutoScroll 로그</h6>
    <DreamineButton OnClick="() => ViewModel.ClickMeCommand.Execute(null)">Click Me</DreamineButton>
    <div class="dreamine-log-list mt-2" @ref="_logListRef">
        @foreach (var entry in ViewModel.ActivityLog)
        {
            <div>@entry</div>
        }
    </div>
}
else if (_activeTab == "Misc")
{
    <h5>Misc</h5>
    <DreamineExpander Header="자세히 보기" @bind-IsExpanded="ViewModel.IsExpanded">
        Expander 안쪽 콘텐츠입니다. WPF/WinForms/MAUI와 같은 펼치기/접기 동작을 보여줍니다.
    </DreamineExpander>

    <h6 class="mt-3">Numeric Range</h6>
    <DreamineNumericSlider @bind-Value="ViewModel.NumericInput" Min="0" Max="100" />
    <p>Value: @ViewModel.NumericInput.ToString("F0")</p>

    <p class="mt-3 fst-italic">Status: @ViewModel.StatusMessage</p>
}
</div>

@code {
    private static readonly string[] _tabs =
    {
        "Button", "CheckBox / Radio", "CheckLed", "TextBox", "ComboBox", "DataGrid / ListBox", "Misc"
    };

    private string _activeTab = "Button";
    private string _buttonTabStatus = "(버튼을 눌러보세요)";
    private ControlsDemoRow? _selectedGridRow;
    private string? _selectedFruitItem;
    private bool _showKeyboard;
    private ElementReference _logListRef;
    private int _lastLogCount;

    protected override void OnInitialized()
    {
        ViewModel.PropertyChanged += OnPropertyChanged;
    }

    private void OnPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 로그 항목이 늘어났을 때만 스크롤시킨다(매 렌더마다 부르면 사용자가 위로
        // 스크롤해서 과거 로그를 보는 중에도 자꾸 맨 아래로 끌려간다).
        if (_activeTab == "DataGrid / ListBox" && ViewModel.ActivityLog.Count != _lastLogCount)
        {
            _lastLogCount = ViewModel.ActivityLog.Count;
            await JS.InvokeVoidAsync("dreamineScrollToBottom", _logListRef);
        }
    }

    private void SetButtonStatus(string name)
        => _buttonTabStatus = $"[{DateTime.Now:HH:mm:ss}] '{name}' 버튼이 클릭되었습니다.";

    public void Dispose()
        => ViewModel.PropertyChanged -= OnPropertyChanged;
}
