<UserControl
    x:Class="SampleCrossUi.Wpf.Views.CounterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Dreamine.UI.Wpf.Controls;assembly=Dreamine.UI.Wpf.Controls"
    Background="#FF1A1A2E"
    Foreground="White">

    <StackPanel
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        Width="360">

        <ctrl:DreamineLabel
            Content="Counter Demo"
            FontSize="20"
            FontWeight="Bold"
            Foreground="White"
            HorizontalAlignment="Center"
            Margin="0,0,0,12" />

        <ctrl:DreamineLabel
            Content="{Binding Count, StringFormat='Count: {0}'}"
            FontSize="52"
            FontWeight="Bold"
            Foreground="#FF4FC3F7"
            HorizontalAlignment="Center"
            Margin="0,0,0,16" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <ctrl:DreamineButton
                Content="Increment"
                Foreground="White"
                Command="{Binding IncrementCommand}"
                Width="130" Height="40"
                Margin="0,0,10,0" />
            <ctrl:DreamineButton
                Content="Reset"
                Foreground="White"
                Command="{Binding ResetCommand}"
                Width="100" Height="40" />
        </StackPanel>

        <TextBlock
            Text="Operation Log"
            FontSize="13"
            FontWeight="SemiBold"
            Foreground="#FFAAAAAA"
            Margin="0,0,0,6" />

        <Border Background="#FF0F1E3A" BorderBrush="#FF2D4A6E" BorderThickness="1" CornerRadius="4">
            <ListBox
                ItemsSource="{Binding Logs}"
                Height="200"
                Background="Transparent"
                BorderThickness="0"
                Foreground="White">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Padding" Value="6,3" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CreatedAt, StringFormat='[HH:mm:ss]', Mode=OneWay}"
                                       Foreground="#FF80CBC4"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding Message, Mode=OneWay}"
                                       Foreground="#FFE0E0E0" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

    </StackPanel>
</UserControl>
