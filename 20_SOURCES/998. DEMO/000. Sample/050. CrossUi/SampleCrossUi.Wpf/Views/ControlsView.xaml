<UserControl
    x:Class="SampleCrossUi.Wpf.Views.ControlsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Dreamine.UI.Wpf.Controls;assembly=Dreamine.UI.Wpf.Controls"
    xmlns:vk="clr-namespace:Dreamine.UI.Wpf.Equipment.DreamineVirtualKeyboard;assembly=Dreamine.UI.Wpf.Equipment"
    xmlns:conv="clr-namespace:Dreamine.UI.Wpf.Converters;assembly=Dreamine.UI.Wpf"
    xmlns:behaviors="clr-namespace:Dreamine.UI.Wpf.Behaviors;assembly=Dreamine.UI.Wpf"
    xmlns:mvvmBehaviors="clr-namespace:Dreamine.MVVM.Behaviors.MVVM;assembly=Dreamine.MVVM.Behaviors"
    xmlns:local="clr-namespace:SampleCrossUi.Shared.ViewModels;assembly=SampleCrossUi.Shared"
    Background="#FF1A1A2E"
    Foreground="White">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:BooleanToBrushConverter x:Key="LedStatusBrushConverter" OnBrush="#FF4CAF50" OffBrush="#FF8899AA" />
        <conv:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" />
        <conv:ComparisonConverter x:Key="ComparisonConverter" />
        <conv:BooleanNegationConverter x:Key="BooleanNegationConverter" />

        <!-- ════ Converters 탭에서만 쓰는 57개 컨버터 리소스 ════ -->
        <!-- Boolean → other -->
        <conv:BooleanConverter x:Key="BooleanConverter" />
        <conv:BooleanToColorConverter x:Key="BooleanToColorConverter" />
        <conv:BooleanToIconConverter x:Key="BooleanToIconConverter" />
        <conv:BoolToFontStyleConverter x:Key="BoolToFontStyleConverter" />
        <conv:BoolToScrollBarVisibilityConverter x:Key="BoolToScrollBarVisibilityConverter" />
        <conv:BoolToIntDynamicConverter x:Key="BoolToIntDynamicConverter" />
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <conv:NullableToBoolConverter x:Key="NullableToBoolConverter" />
        <conv:BrushOrUnsetConverter x:Key="BrushOrUnsetConverter" />

        <!-- Boolean multi-value -->
        <conv:AndConverter x:Key="AndConverter" />
        <conv:OrBooleanMultiConverter x:Key="OrBooleanMultiConverter" />
        <conv:BothTrueMultiConverter x:Key="BothTrueMultiConverter" />
        <conv:BothFalseMultiConverter x:Key="BothFalseMultiConverter" />
        <conv:MultiBoolOrToVisibilityConverter x:Key="MultiBoolOrToVisibilityConverter" />

        <!-- Numeric -->
        <conv:AddOffsetConverter x:Key="AddOffsetConverter" />
        <conv:DoubleEqualsConverter x:Key="DoubleEqualsConverter" Format="0.00" />
        <conv:DoubleEqualsBoolConverter x:Key="DoubleEqualsBoolConverter" />
        <conv:DoubleToStringConverter x:Key="DoubleToStringConverter" />
        <conv:DoubleToIsCheckedConverter x:Key="DoubleToIsCheckedConverter" />
        <conv:Int64ToInt32Converter x:Key="Int64ToInt32Converter" />
        <conv:IntEqualsToBoolConverter x:Key="IntEqualsToBoolConverter" />
        <conv:StringToDoubleConverter x:Key="StringToDoubleConverter" Format="0.0" />
        <conv:NumberClampConverter x:Key="NumberClampConverter" />
        <conv:NumberComparisonConverter x:Key="NumberComparisonConverter" />
        <conv:MathConverter x:Key="MathConverter" />
        <conv:ScreenBreakpointConverter x:Key="ScreenBreakpointConverter" />
        <conv:SelectedItemsCountRangeConverter x:Key="SelectedItemsCountRangeConverter" />

        <!-- Enum -->
        <conv:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
        <conv:EnumEqualsConverter x:Key="EnumEqualsConverter" />
        <conv:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <conv:EnumToStringConverter x:Key="EnumToStringConverter" IsUpper="True" />
        <conv:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <conv:FormatToExampleConverter x:Key="FormatToExampleConverter" />

        <!-- String -->
        <conv:UppercaseConverter x:Key="UppercaseConverter" />
        <conv:BoolPickNameConverter x:Key="BoolPickNameConverter" />
        <conv:ValueUnitCombinationConverter x:Key="ValueUnitCombinationConverter" />

        <!-- Visibility -->
        <conv:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:ValueComparisionToVisibilityConverter x:Key="ValueComparisionToVisibilityConverter" />
        <conv:TextShapeVisibilityConverter x:Key="TextShapeVisibilityConverter" />
        <conv:VisibilityToIntegerConverter x:Key="VisibilityToIntegerConverter" />
        <conv:ComparisionConverter x:Key="ComparisionConverter" />

        <!-- Date/Time -->
        <conv:DateTimeToTimeSpanConverter x:Key="DateTimeToTimeSpanConverter" />
        <conv:TimeSpanHmEditConverter x:Key="TimeSpanHmEditConverter" />
        <conv:LanguageToXmlLanguageConverter x:Key="LanguageToXmlLanguageConverter" />

        <!-- Multi-value/composition -->
        <conv:MultiParameterConverter x:Key="MultiParameterConverter" />
        <conv:TupleConverter x:Key="TupleConverter" />
        <conv:PropertyPathValueConverter x:Key="PropertyPathValueConverter" />
        <conv:PropertyAccessorConverter x:Key="PropertyAccessorConverter" />

        <!-- Internal/template-support (일반 화면용은 아니지만 동작 확인용으로 포함) -->
        <conv:DatagridRowNoConverter x:Key="DatagridRowNoConverter" />
        <conv:OffsetMarginConverter x:Key="OffsetMarginConverter" />
        <conv:LedBrushConverter x:Key="LedBrushConverter" />
        <conv:LedInnerDiameterConverter x:Key="LedInnerDiameterConverter" />
        <conv:LedPositionConverter x:Key="LedPositionConverter" />

        <!-- 외부 이미지 파일 없이 DreamineImage를 시연하기 위한 벡터 DrawingImage -->
        <DrawingImage x:Key="DemoDrawingImage">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FF1E90FF">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="50,50" RadiusX="50" RadiusY="50" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="50,50" RadiusX="22" RadiusY="22" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <Style x:Key="DemoCard" TargetType="Border">
            <Setter Property="Background" Value="#FF0F1E3A" />
            <Setter Property="BorderBrush" Value="#FF2D4A6E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF7EB8E8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="PropLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF8899AA" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="ResultText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF4FC3F7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- ════ DreamineTabControl ════ -->
        <ctrl:DreamineTabControl Grid.Row="0" Margin="12,8,12,4">

            <!-- ═══════════ TAB 1: Button ═══════════ -->
            <TabItem Header="Button">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,8">
                    <StackPanel MaxWidth="640">

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="기본 버튼 — Background / Foreground" Style="{StaticResource CardTitle}" />
                                <WrapPanel>
                                    <ctrl:DreamineButton Content="Primary" Foreground="White"
                                        Background="#FF1E90FF" Width="100" Height="34" Margin="0,0,8,8"
                                        Command="{Binding ClickMeCommand}" />
                                    <ctrl:DreamineButton Content="Secondary" Foreground="White"
                                        Background="#FF2D4A6E" Width="100" Height="34" Margin="0,0,8,8"
                                        Command="{Binding ClickMeCommand}" />
                                    <ctrl:DreamineButton Content="Success" Foreground="White"
                                        Background="#FF1B7A3E" Width="100" Height="34" Margin="0,0,8,8"
                                        Command="{Binding ClickMeCommand}" />
                                    <ctrl:DreamineButton Content="Warning" Foreground="White"
                                        Background="#FFB85C00" Width="100" Height="34" Margin="0,0,8,8"
                                        Command="{Binding ClickMeCommand}" />
                                    <ctrl:DreamineButton Content="Danger" Foreground="White"
                                        Background="#FF8B1A1A" Width="100" Height="34" Margin="0,0,8,8"
                                        Command="{Binding ClickMeCommand}" />
                                </WrapPanel>
                                <TextBlock Style="{StaticResource ResultText}"
                                    Text="{Binding ClickCount, StringFormat='클릭 횟수: {0}'}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="ShineColor — 글로우 효과" Style="{StaticResource CardTitle}" />
                                <WrapPanel>
                                    <ctrl:DreamineButton Content="Blue Glow" Foreground="White"
                                        Background="#FF0D1B3E" ShineColor="#FF1E90FF"
                                        Width="110" Height="36" Margin="0,0,8,8"
                                        Command="{Binding ClickMeCommand}" />
                                    <ctrl:DreamineButton Content="Cyan Glow" Foreground="White"
                                        Background="#FF0D1B3E" ShineColor="#FF00BCD4"
                                        Width="110" Height="36" Margin="0,0,8,8"
                                        Command="{Binding ClickMeCommand}" />
                                    <ctrl:DreamineButton Content="Green Glow" Foreground="White"
                                        Background="#FF0D1B3E" ShineColor="#FF4CAF50"
                                        Width="110" Height="36" Margin="0,0,8,8"
                                        Command="{Binding ClickMeCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="크기 변형" Style="{StaticResource CardTitle}" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ctrl:DreamineButton Content="XS" Foreground="White"
                                        Background="#FF1E90FF" Width="50" Height="24" Margin="0,0,8,0"
                                        FontSize="10" Command="{Binding ClickMeCommand}" />
                                    <ctrl:DreamineButton Content="Small" Foreground="White"
                                        Background="#FF1E90FF" Width="72" Height="28" Margin="0,0,8,0"
                                        FontSize="11" Command="{Binding ClickMeCommand}" />
                                    <ctrl:DreamineButton Content="Medium" Foreground="White"
                                        Background="#FF1E90FF" Width="90" Height="34" Margin="0,0,8,0"
                                        Command="{Binding ClickMeCommand}" />
                                    <ctrl:DreamineButton Content="Large" Foreground="White"
                                        Background="#FF1E90FF" Width="110" Height="42"
                                        FontSize="15" Command="{Binding ClickMeCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="비활성 / 그림자" Style="{StaticResource CardTitle}" />
                                <StackPanel Orientation="Horizontal">
                                    <ctrl:DreamineButton Content="Enabled" Foreground="White"
                                        Background="#FF1E90FF" Width="100" Height="34" Margin="0,0,8,0"
                                        Command="{Binding ClickMeCommand}" />
                                    <ctrl:DreamineButton Content="Disabled" Foreground="White"
                                        Background="#FF1E90FF" Width="100" Height="34" Margin="0,0,16,0"
                                        IsEnabled="False" />
                                    <ctrl:DreamineButton Content="Shadow" Foreground="White"
                                        Background="#FF1E90FF" Width="100" Height="34"
                                        UseShadow="True" ShadowColor="#FF1E90FF" ShadowBlurRadius="20" ShadowOpacity="0.7"
                                        Command="{Binding ClickMeCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════ TAB 2: CheckBox / Radio ═══════════ -->
            <TabItem Header="CheckBox / Radio">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,8">
                    <StackPanel MaxWidth="640">

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="DreamineCheckBox — IsChecked 바인딩" Style="{StaticResource CardTitle}" />
                                <ctrl:DreamineCheckBox Content="Check 1 (기본 체크됨)"
                                    IsChecked="{Binding Check1}" Foreground="White" Margin="0,0,0,8" />
                                <ctrl:DreamineCheckBox Content="Check 2 (기본 해제됨)"
                                    IsChecked="{Binding Check2}" Foreground="White" Margin="0,0,0,8" />
                                <ctrl:DreamineCheckBox Content="Check 3 (IsEnabled=False)"
                                    IsChecked="{Binding Check3}" Foreground="#FF8899AA" IsEnabled="False" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Check1:" Style="{StaticResource PropLabel}" />
                                    <TextBlock Text="{Binding Check1}" Foreground="#FF4FC3F7" />
                                    <TextBlock Text="   Check2:" Foreground="#FF8899AA" FontSize="11"
                                        VerticalAlignment="Center" Margin="16,0,8,0" />
                                    <TextBlock Text="{Binding Check2}" Foreground="#FF4FC3F7" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="DreamineRadioButton — GroupName=&quot;demo&quot;" Style="{StaticResource CardTitle}" />
                                <StackPanel Orientation="Horizontal">
                                    <ctrl:DreamineRadioButton Content="Option A" GroupName="demo"
                                        ctrl:DreamineRadioButton.Command="{Binding SelectRadioCommand}"
                                        ctrl:DreamineRadioButton.CommandParameter="Option A"
                                        ctrl:DreamineRadioButton.CommandTriggerName="Click"
                                        IsChecked="True"
                                        Foreground="White" Margin="0,0,16,0" />
                                    <ctrl:DreamineRadioButton Content="Option B" GroupName="demo"
                                        ctrl:DreamineRadioButton.Command="{Binding SelectRadioCommand}"
                                        ctrl:DreamineRadioButton.CommandParameter="Option B"
                                        ctrl:DreamineRadioButton.CommandTriggerName="Click"
                                        Foreground="White" Margin="0,0,16,0" />
                                    <ctrl:DreamineRadioButton Content="Option C" GroupName="demo"
                                        ctrl:DreamineRadioButton.Command="{Binding SelectRadioCommand}"
                                        ctrl:DreamineRadioButton.CommandParameter="Option C"
                                        ctrl:DreamineRadioButton.CommandTriggerName="Click"
                                        Foreground="White" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource ResultText}"
                                    Text="{Binding SelectedRadio, StringFormat='선택: {0}'}" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════ TAB 3: CheckLed ═══════════ -->
            <TabItem Header="CheckLed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,8">
                    <StackPanel MaxWidth="640">

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="IsOn / IsPulse 토글" Style="{StaticResource CardTitle}" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ctrl:DreamineCheckLed IsOn="{Binding LedIsOn}"
                                        IsPulse="{Binding LedIsPulse}"
                                        Width="36" Height="36" Margin="0,0,16,0" />
                                    <ctrl:DreamineButton Content="ON / OFF" Foreground="White"
                                        Background="#FF2D4A6E" Width="90" Height="32" Margin="0,0,8,0"
                                        Command="{Binding ToggleLedCommand}" />
                                    <ctrl:DreamineButton Content="Pulse" Foreground="White"
                                        Background="#FF2D4A6E" Width="80" Height="32"
                                        Command="{Binding TogglePulseCommand}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="IsOn:" Style="{StaticResource PropLabel}" />
                                    <TextBlock Text="{Binding LedIsOn}" Foreground="#FF4FC3F7" />
                                    <TextBlock Text="   IsPulse:" Foreground="#FF8899AA" FontSize="11"
                                        VerticalAlignment="Center" Margin="16,0,8,0" />
                                    <TextBlock Text="{Binding LedIsPulse}" Foreground="#FF4FC3F7" />
                                </StackPanel>

                                <!-- BoolToVisibilityConverter 데모: 위 ON/OFF 버튼과 같은 LedIsOn 값을 사용합니다. -->
                                <TextBlock Text="BoolToVisibilityConverter (LedIsOn → Visibility)"
                                    Style="{StaticResource PropLabel}" Margin="0,14,0,4" />
                                <TextBlock Text="● LedIsOn = True 인 동안만 표시됩니다."
                                    Foreground="#FF4CAF50"
                                    Visibility="{Binding LedIsOn, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text="● LedIsOn = False 인 동안만 표시됩니다."
                                    Foreground="#FFFF5252"
                                    Visibility="{Binding LedIsOn, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="Corner 위치 (4가지)" Style="{StaticResource CardTitle}" />
                                <WrapPanel>
                                    <StackPanel Margin="0,0,20,8">
                                        <TextBlock Text="TopLeft" Style="{StaticResource PropLabel}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                        <Border Width="60" Height="60" Background="#FF0D1B3E"
                                                BorderBrush="#FF2D4A6E" BorderThickness="1" CornerRadius="4">
                                            <ctrl:DreamineCheckLed IsOn="True" Corner="TopLeft"
                                                Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,8">
                                        <TextBlock Text="TopRight" Style="{StaticResource PropLabel}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                        <Border Width="60" Height="60" Background="#FF0D1B3E"
                                                BorderBrush="#FF2D4A6E" BorderThickness="1" CornerRadius="4">
                                            <ctrl:DreamineCheckLed IsOn="True" Corner="TopRight"
                                                Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,8">
                                        <TextBlock Text="BottomLeft" Style="{StaticResource PropLabel}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                        <Border Width="60" Height="60" Background="#FF0D1B3E"
                                                BorderBrush="#FF2D4A6E" BorderThickness="1" CornerRadius="4">
                                            <ctrl:DreamineCheckLed IsOn="True" Corner="BottomLeft"
                                                Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="4" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,8">
                                        <TextBlock Text="BottomRight" Style="{StaticResource PropLabel}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                        <Border Width="60" Height="60" Background="#FF0D1B3E"
                                                BorderBrush="#FF2D4A6E" BorderThickness="1" CornerRadius="4">
                                            <ctrl:DreamineCheckLed IsOn="True" Corner="BottomRight"
                                                Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="4" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="IsOn=False" Style="{StaticResource PropLabel}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                        <Border Width="60" Height="60" Background="#FF0D1B3E"
                                                BorderBrush="#FF2D4A6E" BorderThickness="1" CornerRadius="4">
                                            <ctrl:DreamineCheckLed IsOn="False" Corner="TopRight"
                                                Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4" />
                                        </Border>
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="Diameter — 크기 변형" Style="{StaticResource CardTitle}" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ctrl:DreamineCheckLed IsOn="True" Diameter="10" Margin="0,0,14,0" />
                                    <ctrl:DreamineCheckLed IsOn="True" Diameter="16" Margin="0,0,14,0" />
                                    <ctrl:DreamineCheckLed IsOn="True" Diameter="22" Margin="0,0,14,0" />
                                    <ctrl:DreamineCheckLed IsOn="True" Diameter="30" Margin="0,0,14,0" />
                                    <ctrl:DreamineCheckLed IsOn="True" Diameter="42" Margin="14,0,0,15"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════ TAB 4: TextBox ═══════════ -->
            <TabItem Header="TextBox">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,8">
                    <StackPanel MaxWidth="640">

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="DreamineTextBox — 일반 입력" Style="{StaticResource CardTitle}" />
                                <ctrl:DreamineTextBox
                                    Text="{Binding TextInput, UpdateSourceTrigger=PropertyChanged}"
                                    Hint="여기에 텍스트를 입력하세요..."
                                    Height="40" Foreground="Black" Background="#FFE9EEF5"
                                    Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal">
                                    <ctrl:DreamineButton Content="Clear" Foreground="White"
                                        Background="#FF2D4A6E" Width="80" Height="30"
                                        Command="{Binding ClearTextCommand}" />
                                    <TextBlock Text="{Binding TextInput, StringFormat='  값: {0}'}"
                                        Foreground="#FF4FC3F7" VerticalAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="FocusOnLoadedBehavior + EnterKeyCommandBehavior" Style="{StaticResource CardTitle}" />
                                <TextBlock Text="이 탭이 열리면 아래 입력칸에 자동으로 포커스가 가고, Enter를 누르면 ClearTextCommand가 실행됩니다."
                                    Foreground="#FF8899AA" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <ctrl:DreamineTextBox
                                    Text="{Binding TextInput, UpdateSourceTrigger=PropertyChanged}"
                                    Hint="포커스 자동 진입 + Enter로 Clear..."
                                    Height="40" Foreground="Black" Background="#FFE9EEF5"
                                    mvvmBehaviors:FocusOnLoadedBehavior.IsEnabled="True"
                                    mvvmBehaviors:EnterKeyCommandBehavior.Command="{Binding ClearTextCommand}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="DreamineTextBox — 가상 키보드 (UseVirtualKeyBoard=True)" Style="{StaticResource CardTitle}" />
                                <ctrl:DreamineTextBox
                                    Text="{Binding TextInput, UpdateSourceTrigger=PropertyChanged}"
                                    vk:DreamineVirtualKeyboardAssist.UseVirtualKeyBoard="True"
                                    Hint="클릭하면 가상 키보드가 열립니다..."
                                    Height="40" Foreground="Black" Background="#FFE9EEF5" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="DreamineTextBox — 읽기 전용 (IsReadOnly=True)" Style="{StaticResource CardTitle}" />
                                <ctrl:DreamineTextBox
                                    Text="이 텍스트는 수정할 수 없습니다."
                                    IsReadOnly="True"
                                    Height="40" Foreground="#FF8899AA" Background="#FF0A1525" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="NumericRangeBehavior — 0~100 범위로 강제 보정(Clamp)" Style="{StaticResource CardTitle}" />
                                <TextBox
                                    Text="{Binding NumericInput, UpdateSourceTrigger=PropertyChanged}"
                                    behaviors:NumericRangeBehavior.IsEnabled="True"
                                    behaviors:NumericRangeBehavior.Min="0"
                                    behaviors:NumericRangeBehavior.Max="100"
                                    behaviors:NumericRangeBehavior.Mode="Clamp"
                                    Width="120" Height="30" Padding="6,4"
                                    HorizontalAlignment="Left" />
                                <TextBlock Style="{StaticResource ResultText}"
                                    Text="{Binding NumericInput, StringFormat='값: {0} (범위를 벗어나면 자동으로 0~100 사이로 보정됩니다)'}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="DreaminePasswordBox" Style="{StaticResource CardTitle}" />
                                <ctrl:DreaminePasswordBox
