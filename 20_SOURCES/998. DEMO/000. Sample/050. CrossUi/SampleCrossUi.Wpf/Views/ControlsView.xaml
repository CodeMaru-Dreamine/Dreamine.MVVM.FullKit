                                    <TextBlock Text="EmptyStringToVisibilityConverter — TextInput:" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11" Text="{Binding TextInput, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="NullToVisibilityConverter — DemoNullable:" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11" Text="{Binding DemoNullable, Converter={StaticResource NullToVisibilityConverter}}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="ValueComparisionToVisibilityConverter — NumericInput &gt; 50:" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11" Text="{Binding NumericInput, Converter={StaticResource ValueComparisionToVisibilityConverter}, ConverterParameter=50}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="TextShapeVisibilityConverter — SelectedFruit == &quot;Text&quot;:" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11" Text="{Binding SelectedFruit, Converter={StaticResource TextShapeVisibilityConverter}}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="VisibilityToIntegerConverter — BoolToVisibilityConverter(Check1):" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11" Text="{Binding Check1, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ComparisionConverter — SelectedFruit == &quot;Cherry&quot;:" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11" Text="{Binding SelectedFruit, Converter={StaticResource ComparisionConverter}, ConverterParameter=Cherry}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="날짜/시간 관련" Style="{StaticResource CardTitle}" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="DateTimeToTimeSpanConverter — DemoDateTime:" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11" Text="{Binding DemoDateTime, Converter={StaticResource DateTimeToTimeSpanConverter}}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="TimeSpanHmEditConverter — Time → &quot;H:MM&quot;:" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11" Text="{Binding Time, Converter={StaticResource TimeSpanHmEditConverter}}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="LanguageToXmlLanguageConverter — 현재 언어:" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11"
                                        Text="{Binding Source={StaticResource LangProxy}, Path=CurrentLanguage, Converter={StaticResource LanguageToXmlLanguageConverter}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="Multi-value / 합성(Composition)" Style="{StaticResource CardTitle}" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="MultiParameterConverter — (SelectedFruit, ClickCount):" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource MultiParameterConverter}" StringFormat="{}{0}">
                                                <Binding Path="SelectedFruit" />
                                                <Binding Path="ClickCount" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="TupleConverter — (SelectedFruit, NumericInput):" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource TupleConverter}" StringFormat="{}{0}">
                                                <Binding Path="SelectedFruit" />
                                                <Binding Path="NumericInput" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="PropertyPathValueConverter — (this, &quot;ClickCount&quot;):" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource PropertyPathValueConverter}" StringFormat="{}{0}">
                                                <Binding Path="." />
                                                <Binding Source="ClickCount" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PropertyAccessorConverter — (this, &quot;StatusMessage&quot;):" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource PropertyAccessorConverter}">
                                                <Binding Path="." />
                                                <Binding Source="StatusMessage" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DemoCard}">
                            <StackPanel>
                                <TextBlock Text="내부/특수 용도 (DataGrid 행 템플릿, CheckLed 템플릿 전용 등)" Style="{StaticResource CardTitle}" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="DatagridRowNoConverter — index 2 → 행번호:" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <TextBlock Foreground="#FF4FC3F7" FontSize="11" Text="{Binding ClickCount, Converter={StaticResource DatagridRowNoConverter}}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="OffsetMarginConverter — NumericInput → Margin:" Foreground="#FF8899AA" FontSize="11" Width="300" />
                                    <Border Margin="{Binding NumericInput, Converter={StaticResource OffsetMarginConverter}}"
                                        Width="10" Height="10" Background="#FF4FC3F7" />
                                </StackPanel>

                                <TextBlock Text="↓ DreamineCheckLed 내부 템플릿 전용(LedBrushConverter/LedInnerDiameterConverter/LedPositionConverter) — 일반 화면 바인딩 대상이 아니라 직접 사용하는 예시는 없습니다. CheckLed 탭의 LED 표시 자체가 이 3개를 내부적으로 쓰고 있는 실제 사용처입니다."
                                    Foreground="#FF8899AA" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0" />

                                <TextBlock Text="↓ SelfTextConverterExtension(MarkupExtension)·IconToImageSourceConverter(System.Drawing.Icon 필요) — 외부 리소스/특수 호출 규약이 필요해 라이브 데모는 생략합니다."
                                    Foreground="#FF8899AA" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </ctrl:DreamineTabControl>

        <!-- ════ Status Bar ════ -->
        <Border Grid.Row="1" Background="#FF0A1525" BorderBrush="#FF2D4A6E" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusMessage}"
                    Foreground="#FF4FC3F7" FontSize="11"
                    VerticalAlignment="Center" Margin="16,0,0,0" />
                <TextBlock Text="{Binding ActivationLog, StringFormat='  |  ViewSwitcher: {0}'}"
                    Foreground="#FF8899AA" FontSize="11"
                    VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
