<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SampleCrossUi.Maui.MainPage"
             Title="Dreamine Cross-UI — MAUI">

    <Grid RowDefinitions="Auto,*">

        <HorizontalStackLayout Grid.Row="0" Spacing="8" Padding="12" BackgroundColor="#0d1b3e">
            <Button x:Name="BtnCounter"  Text="Counter"  Clicked="OnNavCounterClicked"  TextColor="White" />
            <Button x:Name="BtnLightBulb" Text="Light Bulb" Clicked="OnNavLightBulbClicked" TextColor="White" />
            <Button x:Name="BtnControls" Text="Controls" Clicked="OnNavControlsClicked" TextColor="White" />
            <Button x:Name="BtnPopup"    Text="Popup"    Clicked="OnNavPopupClicked"    TextColor="White" />
        </HorizontalStackLayout>

        <ContentView x:Name="PageHost" Grid.Row="1" />

    </Grid>
</ContentPage>
