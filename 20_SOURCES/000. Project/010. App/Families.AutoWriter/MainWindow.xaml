<Window x:Class="FamiliesAutoWriter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:FamiliesAutoWriter.ViewModels"
        xmlns:conv="clr-namespace:FamiliesAutoWriter.Converters"
        Title="Families AutoWriter 🤖" Height="840" Width="1440"
        Background="#1a1a2e" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:EnumToBoolConverter x:Key="EnumToBoolConverter"/>

        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox" x:Key="Input">
            <Setter Property="Background" Value="#0f172a"/>
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#e2e8f0"/>
            <Setter Property="SelectionBrush" Value="#6366f1"/>
        </Style>
        <Style TargetType="Button" x:Key="Btn">
            <Setter Property="Background" Value="#6366f1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4f46e5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3730a3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="BtnGhost" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#1e293b"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0f172a"/>
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바: App_Data 경로 -->
        <Border Grid.Row="0" Background="#0a0f1e" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#1e293b">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📁 App_Data 경로:" Foreground="#64748b"
                           VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                <TextBox Grid.Column="1" Style="{StaticResource Input}"
                         Text="{Binding AppDataRoot, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button Grid.Column="2" Style="{StaticResource BtnGhost}" Content="📂 찾기"
                        Command="{Binding BrowseAppDataCommand}" Margin="0,0,6,0"/>
                <Button Grid.Column="3" Style="{StaticResource BtnGhost}" Content="🔄"
                        ToolTip="슬러그 목록 새로고침" Command="{Binding RefreshSlugListCommand}"/>
            </Grid>
        </Border>

        <!-- 메인: 좌측 브라우저 + 우측 에디터 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="420"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="430" MinWidth="380"/>
            </Grid.ColumnDefinitions>

            <!-- ── 왼쪽: AI 브라우저 ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 주소바 -->
                <Border Grid.Row="0" Background="#0a0f1e" Padding="8,6"
                        BorderThickness="0,0,0,1" BorderBrush="#1e293b">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                            <Button Style="{StaticResource BtnGhost}" Content="🤖 Claude" Padding="8,5"
                                    Margin="0,0,4,0" Click="OnClaudeClick"/>
                            <Button Style="{StaticResource BtnGhost}" Content="💬 ChatGPT" Padding="8,5"
                                    Margin="0,0,4,0" Click="OnChatGptClick"/>
                            <Button Style="{StaticResource BtnGhost}" Content="✨ Gemini" Padding="8,5"
                                    Click="OnGeminiClick"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" x:Name="UrlBox" Style="{StaticResource Input}"
                                 Text="{Binding BrowserUrl, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="OnUrlKeyDown" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Style="{StaticResource Btn}" Content="이동"
                                Margin="6,0,0,0" Click="OnNavigateClick"/>
                    </Grid>
                </Border>

                <!-- WebView2 -->
                <wv2:WebView2 Grid.Row="1" x:Name="WebBrowser"/>
            </Grid>

            <!-- 구분선 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#0a0f1e"/>

            <!-- ── 오른쪽: 포스트 작성 ── -->
            <Border Grid.Column="2" Background="#0d1117">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">

                        <!-- 헤더 -->
                        <TextBlock Text="✍️ Families 포스트 작성" Foreground="#e2e8f0"
                                   FontSize="16" FontWeight="Bold" Margin="0,4,0,18"/>

                        <!-- 가족 선택 -->
                        <TextBlock Style="{StaticResource Label}" Text="가족 (슬러그)"/>
                        <ComboBox ItemsSource="{Binding Slugs}"
                                  SelectedItem="{Binding SelectedSlug}"
                                  Margin="0,0,0,14"/>

                        <!-- 제목 -->
                        <TextBlock Style="{StaticResource Label}" Text="제목 (선택)"/>
                        <TextBox Style="{StaticResource Input}"
                                 Text="{Binding PostTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>

                        <!-- 내용 -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Style="{StaticResource Label}" Text="내용" DockPanel.Dock="Left"/>
                            <TextBlock DockPanel.Dock="Right" Foreground="#475569" FontSize="11"
                                       Text="Markdown 지원" VerticalAlignment="Bottom"/>
                        </DockPanel>
                        <TextBox Style="{StaticResource Input}"
                                 Text="{Binding PostContent, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="200" VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,4"/>
                        <Border Background="#0f172a" CornerRadius="4" Padding="8,5" Margin="0,0,0,14">
                            <TextBlock Foreground="#475569" FontSize="11">
                                💡 AI에서 생성한 글을 복사(Ctrl+C) 후 여기서 Ctrl+V로 붙여넣기
                            </TextBlock>
                        </Border>

                        <!-- 앨범 ID -->
                        <TextBlock Style="{StaticResource Label}" Text="앨범 ID (비우면 전체 타임라인)"/>
                        <TextBox Style="{StaticResource Input}"
                                 Text="{Binding AlbumId, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"/>

                        <!-- 미디어 위치 -->
                        <TextBlock Style="{StaticResource Label}" Text="사진/영상 위치"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <RadioButton Content="본문 아래 (기본)" Margin="0,0,20,0"
                                         IsChecked="{Binding MediaPosition,
                                             Converter={StaticResource EnumToBoolConverter},
                                             ConverterParameter=Bottom}"/>
                            <RadioButton Content="본문 위"
                                         IsChecked="{Binding MediaPosition,
                                             Converter={StaticResource EnumToBoolConverter},
                                             ConverterParameter=Top}"/>
                        </StackPanel>

                        <!-- 상단 고정 -->
                        <CheckBox Content="📌 상단 고정 (Pin)" IsChecked="{Binding IsPinned}"
                                  Margin="0,0,0,16"/>

                        <!-- 사진 첨부 -->
                        <TextBlock Style="{StaticResource Label}" Text="사진 첨부 (로컬 파일)"/>
                        <Button Style="{StaticResource BtnGhost}" Content="🖼️ 사진 추가..."
                                Command="{Binding AddPhotosCommand}"
                                HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding PendingPhotos}" Margin="0,0,0,14">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1e293b" CornerRadius="4"
                                            Padding="8,5" Margin="0,0,0,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding}" Foreground="#94a3b8"
                                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="✕"
                                                    Foreground="#f87171" Background="Transparent"
                                                    BorderThickness="0" Padding="6,0" Cursor="Hand"
                                                    Command="{Binding DataContext.RemovePhotoCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 구분선 -->
                        <Separator Background="#1e293b" Margin="0,0,0,14"/>

                        <!-- 상태 메시지 -->
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                   TextWrapping="Wrap" Margin="0,0,0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#6ee7b7"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusMessage[0]}" Value="❌">
                                            <Setter Property="Foreground" Value="#f87171"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 저장/초기화 버튼 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource Btn}"
                                    Content="📤 Families에 저장" FontSize="14" FontWeight="Bold"
                                    Padding="12,10" Command="{Binding SavePostCommand}"/>
                            <Button Grid.Column="2" Style="{StaticResource BtnGhost}"
                                    Content="🗑 초기화" Command="{Binding ClearFormCommand}"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
