<Window x:Class="FamiliesAutoWriter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:FamiliesAutoWriter.ViewModels"
        xmlns:conv="clr-namespace:FamiliesAutoWriter.Converters"
        Title="Families AutoWriter 🤖" Height="900" Width="1480"
        Background="#0d1117" WindowStartupLocation="CenterScreen">

    <Window.DataContext><vm:MainViewModel /></Window.DataContext>

    <Window.Resources>
        <conv:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <Style TargetType="TextBlock" x:Key="Lbl">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style TargetType="TextBox" x:Key="Input">
            <Setter Property="Background" Value="#0f172a"/>
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#e2e8f0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0f172a"/>
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1e293b"/>
                        <Setter Property="Foreground" Value="#e2e8f0"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#6366f1"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="Btn">
            <Setter Property="Background" Value="#6366f1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4f46e5"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#3730a3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="BtnGhost" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#1e293b"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="BtnGreen" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#059669"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#047857"/></Trigger></Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="BtnRed" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#dc2626"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#b91c1c"/></Trigger></Style.Triggers>
        </Style>
        <Style TargetType="ToggleButton" x:Key="Toggle">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#16a34a"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <Border Grid.Row="0" Background="#0a0f1e" Padding="10,7"
                BorderThickness="0,0,0,1" BorderBrush="#1e293b">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📁" Foreground="#64748b" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Column="1" Style="{StaticResource Input}"
                         Text="{Binding AppDataRoot, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button Grid.Column="2" Style="{StaticResource BtnGhost}" Content="📂" ToolTip="App_Data 폴더 선택"
                        Command="{Binding BrowseAppDataCommand}" Margin="0,0,4,0"/>
                <TextBlock Grid.Column="3" Text="가족:" Foreground="#64748b" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Grid.Column="4" ItemsSource="{Binding Slugs}" SelectedItem="{Binding SelectedSlug}"
                          Width="100" Margin="0,0,4,0"/>
                <Button Grid.Column="5" Style="{StaticResource BtnGhost}" Content="🔄"
                        Command="{Binding RefreshSlugListCommand}"/>
            </Grid>
        </Border>

        <!-- 메인 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="480" MinWidth="440"/>
            </Grid.ColumnDefinitions>

            <!-- ── 왼쪽: AI 브라우저 ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#0a0f1e" Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="#1e293b">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                            <Button Style="{StaticResource BtnGhost}" Content="🤖 Claude" Padding="8,5" Margin="0,0,3,0" Click="OnClaudeClick"/>
                            <Button Style="{StaticResource BtnGhost}" Content="💬 ChatGPT" Padding="8,5" Margin="0,0,3,0" Click="OnChatGptClick"/>
                            <Button Style="{StaticResource BtnGhost}" Content="✨ Gemini" Padding="8,5" Click="OnGeminiClick"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" x:Name="UrlBox" Style="{StaticResource Input}"
                                 Text="{Binding BrowserUrl, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="OnUrlKeyDown" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Style="{StaticResource Btn}" Content="이동" Margin="6,0,0,0" Click="OnNavigateClick"/>
                    </Grid>
                </Border>
                <wv2:WebView2 Grid.Row="1" x:Name="WebBrowser"/>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#0a0f1e"/>

            <!-- ── 오른쪽: 컨트롤 패널 ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <!-- 자동화 루프 패널 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 하단: 수동 저장 -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ━━━━━ 자동화 루프 패널 ━━━━━ -->
                <Border Grid.Row="0" Background="#080e08"
                        BorderThickness="0,0,0,2" BorderBrush="#16a34a" Padding="14,12">
                    <StackPanel>

                        <!-- 헤더 -->
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="🔄 자동 글쓰기 루프" Foreground="#4ade80"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource BtnGhost}"
                                    Content="🗑 히스토리 초기화" Padding="7,3" FontSize="10"
                                    Command="{Binding ClearPromptHistoryCommand}"/>
                        </DockPanel>

                        <!-- 앨범 선택 + 로테이션 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="앨범:" Style="{StaticResource Lbl}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Albums}"
                                      SelectedItem="{Binding SelectedAlbum}"
                                      DisplayMemberPath="Name" Margin="0,0,8,0"/>
                            <CheckBox Grid.Column="2" Content="🔄 자동 로테이션"
                                      IsChecked="{Binding AlbumRotationEnabled}"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <!-- 프롬프트 입력 -->
                        <TextBlock Style="{StaticResource Lbl}" Margin="0,0,0,3">
                            프롬프트 — <Run Foreground="#6366f1">{앨범}</Run> 을 쓰면 현재 앨범명으로 자동 치환
                        </TextBlock>
                        <TextBox Style="{StaticResource Input}"
                                 Text="{Binding PromptText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="110" VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="12"
                                 Margin="0,0,0,8"/>

                        <!-- 루프 설정 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 루프 ON/OFF -->
                            <ToggleButton Grid.Column="0" Style="{StaticResource Toggle}"
                                          IsChecked="{Binding LoopEnabled}"
                                          Content="{Binding LoopLabel}"
                                          FontWeight="Bold" Padding="10,6" Margin="0,0,10,0"/>

                            <!-- 카운트다운 -->
                            <TextBlock Grid.Column="1" Text="{Binding LoopCountdown}"
                                       Foreground="#475569" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>

                            <!-- 간격 -->
                            <TextBlock Grid.Column="2" Text="간격:" Style="{StaticResource Lbl}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,10,0">
                                <ComboBox ItemsSource="{Binding IntervalOptions}"
                                          SelectedItem="{Binding LoopIntervalMinutes}" Width="48"/>
                                <TextBlock Text="분" Foreground="#64748b" FontSize="11"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>

                            <!-- AI 대기 -->
                            <TextBlock Grid.Column="4" Text="AI대기:" Style="{StaticResource Lbl}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="0,0,10,0">
                                <ComboBox ItemsSource="{Binding WaitOptions}"
                                          SelectedItem="{Binding AiWaitSeconds}" Width="48"/>
                                <TextBlock Text="초" Foreground="#64748b" FontSize="11"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>

                            <!-- 지금 실행 -->
                            <Button Grid.Column="6" Style="{StaticResource BtnGreen}"
                                    Content="▶ 지금 실행" Command="{Binding RunNowCommand}"/>
                        </Grid>

                        <!-- 루프 상태 -->
                        <Border Background="#0d1a0d" CornerRadius="4" Padding="8,6">
                            <TextBlock Text="{Binding LoopStatus}" FontSize="11"
                                       TextWrapping="Wrap" Foreground="#6ee7b7"/>
                        </Border>

                        <!-- 수동 전송만 -->
                        <DockPanel Margin="0,8,0,0">
                            <TextBlock DockPanel.Dock="Left" Text="프롬프트만 전송 (AI 응답은 수동 저장):"
                                       Foreground="#475569" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource BtnGhost}"
                                    Content="📤 프롬프트 전송" Padding="8,4" FontSize="11"
                                    Command="{Binding SendPromptNowCommand}"/>
                            <TextBlock Text="{Binding PromptStatus}" Foreground="#64748b"
                                       FontSize="10" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- ━━━━━ 수동 저장 패널 ━━━━━ -->
                <Border Grid.Row="1" Background="#0d1117">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14,12,14,14">

                            <!-- AI 응답 즉시 저장 -->
                            <Border Background="#0c1a0c" BorderBrush="#16a34a" BorderThickness="1"
                                    CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="⚡ AI 응답 추출 → 현재 앨범에 바로 저장"
                                               Foreground="#4ade80" FontSize="12" FontWeight="Bold"
                                               Margin="0,0,0,6"/>
                                    <Button Style="{StaticResource BtnGreen}"
                                            Content="🤖 AI 응답 추출 &amp; 저장"
                                            FontSize="13" FontWeight="Bold" Padding="10,8"
                                            Command="{Binding ExtractAndSaveCommand}"/>
                                </StackPanel>
                            </Border>

                            <!-- 직접 작성 -->
                            <TextBlock Text="✍️ 또는 직접 작성" Foreground="#475569" FontSize="11" Margin="0,0,0,8"/>

                            <TextBlock Style="{StaticResource Lbl}" Text="제목 (비우면 자동 생성)"/>
                            <TextBox Style="{StaticResource Input}"
                                     Text="{Binding PostTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Style="{StaticResource Lbl}" Text="내용 (Markdown)"/>
                            <TextBox Style="{StaticResource Input}"
                                     Text="{Binding PostContent, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="130" VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,8"/>

                            <!-- 미디어 위치 + 핀 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton Content="사진 아래" Margin="0,0,14,0"
                                             IsChecked="{Binding MediaPosition, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Bottom}"/>
                                <RadioButton Content="사진 위" Margin="0,0,14,0"
                                             IsChecked="{Binding MediaPosition, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Top}"/>
                                <CheckBox Content="📌 고정" IsChecked="{Binding IsPinned}"/>
                            </StackPanel>

                            <!-- 사진 -->
                            <Button Style="{StaticResource BtnGhost}" Content="🖼️ 사진 추가..."
                                    Command="{Binding AddPhotosCommand}" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding PendingPhotos}" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1e293b" CornerRadius="3" Padding="6,4" Margin="0,0,0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding}" Foreground="#94a3b8" FontSize="10"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="✕" Foreground="#f87171"
                                                        Background="Transparent" BorderThickness="0"
                                                        Padding="5,0" Cursor="Hand"
                                                        Command="{Binding DataContext.RemovePhotoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 상태 -->
                            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,8" Foreground="#6ee7b7"/>

                            <!-- 저장 버튼 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource Btn}"
                                        Content="📤 직접 작성 저장" FontSize="12" FontWeight="Bold"
                                        Padding="10,8" Command="{Binding SavePostCommand}"/>
                                <Button Grid.Column="2" Style="{StaticResource BtnGhost}"
                                        Content="🗑" ToolTip="초기화" Command="{Binding ClearFormCommand}"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
