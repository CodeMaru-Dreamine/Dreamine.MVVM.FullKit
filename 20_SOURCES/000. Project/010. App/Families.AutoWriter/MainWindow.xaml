<Window x:Class="FamiliesAutoWriter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:FamiliesAutoWriter.ViewModels"
        xmlns:conv="clr-namespace:FamiliesAutoWriter.Converters"
        Title="Families AutoWriter 🤖" Height="920" Width="1600"
        Background="#0d1117" WindowStartupLocation="CenterScreen">

    <Window.DataContext><vm:MainViewModel /></Window.DataContext>

    <Window.Resources>
        <conv:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Labels -->
        <Style TargetType="TextBlock" x:Key="Lbl">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox" x:Key="Input">
            <Setter Property="Background" Value="#0f172a"/>
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#e2e8f0"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        Margin="8,4,2,4"
                                        VerticalAlignment="Center"
                                        TextBlock.Foreground="{TemplateBinding Foreground}"
                                        TextBlock.FontSize="{TemplateBinding FontSize}"/>
                                    <TextBlock Grid.Column="1" Text="▾"
                                               Foreground="#64748b" FontSize="10"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Focusable="False" ClickMode="Press"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border Background="#1e293b" BorderBrush="#334155"
                                        BorderThickness="1" CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366f1"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366f1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1e293b"/>
                        <Setter Property="Foreground" Value="#e2e8f0"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4f46e5"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Buttons -->
        <Style TargetType="Button" x:Key="Btn">
            <Setter Property="Background" Value="#6366f1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4f46e5"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#3730a3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="BtnGhost" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#1e293b"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#334155"/></Trigger></Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="BtnGreen" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#059669"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#047857"/></Trigger></Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="BtnRed" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#dc2626"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#b91c1c"/></Trigger></Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="BtnOrange" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#d97706"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#b45309"/></Trigger></Style.Triggers>
        </Style>

        <!-- Tab button style -->
        <Style TargetType="ToggleButton" x:Key="TabBtn">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5,5,0,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0d1117"/>
                                <Setter Property="Foreground" Value="#e2e8f0"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6366f1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <!-- ── 메인 레이아웃: 좌(설정) | 우(탭 브라우저) ── -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" MinWidth="300"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════ 좌측 패널 (ActiveSession 바인딩) ════════════════════════ -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 경로 -->
                <RowDefinition Height="Auto"/>  <!-- 슬러그 -->
                <RowDefinition Height="Auto"/>  <!-- 앨범 -->
                <RowDefinition Height="Auto"/>  <!-- 루프 설정 -->
                <RowDefinition Height="Auto"/>  <!-- 미디어 위치 -->
                <RowDefinition Height="*"/>     <!-- 프롬프트 -->
                <RowDefinition Height="Auto"/>  <!-- 버튼 -->
                <RowDefinition Height="Auto"/>  <!-- 상태 -->
            </Grid.RowDefinitions>

            <!-- App_Data 경로 -->
            <Border Grid.Row="0" Background="#0f172a" BorderBrush="#334155" BorderThickness="1"
                    CornerRadius="6" Padding="10" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📁 App_Data 경로" Style="{StaticResource Lbl}"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource Input}"
                                 Text="{Binding ActiveSession.AppDataRoot, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="찾기" Style="{StaticResource BtnGhost}"
                                Command="{Binding ActiveSession.BrowseAppDataCommand}" Padding="8,5"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 슬러그 선택 -->
            <Border Grid.Row="1" Background="#0f172a" BorderBrush="#334155" BorderThickness="1"
                    CornerRadius="6" Padding="10" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="👨‍👩‍👧‍👦 가족 슬러그" Style="{StaticResource Lbl}"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding ActiveSession.Slugs}"
                                  SelectedItem="{Binding ActiveSession.SelectedSlug}"
                                  Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="새로고침" Style="{StaticResource BtnGhost}"
                                Command="{Binding ActiveSession.RefreshSlugListCommand}" Padding="8,5"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 앨범 선택 -->
            <Border Grid.Row="2" Background="#0f172a" BorderBrush="#334155" BorderThickness="1"
                    CornerRadius="6" Padding="10" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🗂 앨범 (선택 안 하면 전체 타임라인)" Style="{StaticResource Lbl}"/>
                    <ComboBox Grid.Row="1"
                              ItemsSource="{Binding ActiveSession.Albums}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding ActiveSession.SelectedAlbum}"
                              Margin="0,0,0,6"/>
                    <CheckBox Grid.Row="2"
                              Content="앨범 자동 순환 (포스트마다 다음 앨범으로)"
                              IsChecked="{Binding ActiveSession.AlbumRotationEnabled}"/>
                </Grid>
            </Border>

            <!-- 자동 루프 설정 -->
            <Border Grid.Row="3" Background="#0a1f14" BorderBrush="#065f46" BorderThickness="1"
                    CornerRadius="6" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="⚙️ 자동 루프 설정" Foreground="#34d399" FontSize="12" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <!-- 실행 간격 -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="실행 간격 " Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,6,3"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ActiveSession.IntervalOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedItem="{Binding ActiveSession.SelectedInterval}"/>
                    </Grid>

                    <!-- AI 응답 대기 -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="AI 대기 시간 " Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,6,3"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ActiveSession.WaitOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedItem="{Binding ActiveSession.AiWaitOption}"/>
                    </Grid>

                    <!-- 새 채팅 임계값 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="새 채팅 (N포스트마다) " Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,6,3"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ActiveSession.NewChatOptions}"
                                  SelectedItem="{Binding ActiveSession.NewChatEveryN}"/>
                    </Grid>

                    <!-- 루프 ON/OFF 토글 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" Content="자동 루프 사용"
                                  IsChecked="{Binding ActiveSession.LoopEnabled}"
                                  Foreground="#34d399" FontSize="12"
                                  VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="▶ 지금 실행"
                                Style="{StaticResource BtnGreen}"
                                Command="{Binding ActiveSession.RunNowCommand}" Padding="8,5"/>
                    </Grid>

                    <!-- 카운트다운 -->
                    <TextBlock Text="{Binding ActiveSession.LoopCountdown}" Foreground="#6ee7b7" FontSize="11"
                               Margin="0,4,0,0"
                               Visibility="{Binding ActiveSession.LoopEnabled, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>

            <!-- 미디어 위치 -->
            <Border Grid.Row="4" Background="#0f172a" BorderBrush="#334155" BorderThickness="1"
                    CornerRadius="6" Padding="10" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="🎥 미디어 위치" Style="{StaticResource Lbl}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <RadioButton Content="상단" Foreground="#e2e8f0" FontSize="12" Margin="0,0,12,0"
                                     IsChecked="{Binding ActiveSession.MediaPosition,
                                         Converter={StaticResource EnumToBoolConverter},
                                         ConverterParameter=Top}"/>
                        <RadioButton Content="하단" Foreground="#e2e8f0" FontSize="12"
                                     IsChecked="{Binding ActiveSession.MediaPosition,
                                         Converter={StaticResource EnumToBoolConverter},
                                         ConverterParameter=Bottom}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 프롬프트 -->
            <Border Grid.Row="5" Background="#0f172a" BorderBrush="#334155" BorderThickness="1"
                    CornerRadius="6" Padding="10" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📝 프롬프트 ({앨범} 자리 자동 치환)" Style="{StaticResource Lbl}"/>
                    <TextBox Grid.Row="1" Style="{StaticResource Input}"
                             Text="{Binding ActiveSession.PromptText, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             MinHeight="120"/>
                </Grid>
            </Border>

            <!-- 버튼들 -->
            <StackPanel Grid.Row="6" Margin="0,0,0,6">
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="📤 프롬프트 전송"
                            Style="{StaticResource Btn}"
                            Command="{Binding ActiveSession.SendPromptNowCommand}"/>
                    <Button Grid.Column="2" Content="💾 추출 → 저장"
                            Style="{StaticResource BtnOrange}"
                            Command="{Binding ActiveSession.ExtractAndSaveCommand}"/>
                </Grid>
                <Button Content="🗑 프롬프트 히스토리 초기화" Style="{StaticResource BtnGhost}"
                        Command="{Binding ActiveSession.ClearPromptHistoryCommand}" Padding="8,5"/>
                <TextBlock Text="{Binding ActiveSession.PromptStatus}" Foreground="#6ee7b7" FontSize="11" Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding ActiveSession.ExtractStatus}" Foreground="#fbbf24" FontSize="11" Margin="0,2,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- 루프 상태 -->
            <Border Grid.Row="7" Background="#0f172a" BorderBrush="#334155" BorderThickness="1"
                    CornerRadius="6" Padding="8">
                <TextBlock Text="{Binding ActiveSession.LoopStatus}" Foreground="#94a3b8" FontSize="11"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>

        <!-- ── 분리선 ── -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="#1e293b"/>

        <!-- ════════════════════════ 우측: 멀티탭 브라우저 ════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 탭 헤더 -->
                <RowDefinition Height="Auto"/>  <!-- URL 바 -->
                <RowDefinition Height="*"/>     <!-- 브라우저 컨테이너 -->
            </Grid.RowDefinitions>

            <!-- 탭 헤더 영역 -->
            <Border Grid.Row="0" Background="#0f172a" BorderBrush="#334155"
                    BorderThickness="0,0,0,1" Padding="6,4,6,0">
                <DockPanel>
                    <!-- 새 탭 생성 컨트롤 (오른쪽 고정) -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                        <TextBox x:Name="NewTabNameBox"
                                 Style="{StaticResource Input}"
                                 Width="80" Padding="6,4"
                                 VerticalAlignment="Center"
                                 KeyDown="OnNewTabNameKeyDown"
                                 ToolTip="탭 이름 입력 후 Enter 또는 + 클릭"/>
                        <ComboBox x:Name="NewTabModeBox"
                                  Width="60" Margin="4,0,4,0"
                                  VerticalAlignment="Center"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="여행"/>
                            <ComboBoxItem Content="요리"/>
                        </ComboBox>
                        <Button Content="+" Style="{StaticResource BtnGhost}"
                                Width="28" Padding="0"
                                Click="OnAddTabClick"
                                ToolTip="새 탭 추가"/>
                    </StackPanel>
                    <!-- 탭 버튼 목록 -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden">
                        <StackPanel x:Name="TabHeaderPanel" Orientation="Horizontal"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- URL 바 -->
            <Border Grid.Row="1" Background="#0f172a" BorderBrush="#334155"
                    BorderThickness="0,0,0,1" Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="←" Style="{StaticResource BtnGhost}"
                            Padding="8,5" Margin="0,0,4,0" Click="OnBackClick" ToolTip="뒤로"/>
                    <TextBox Grid.Column="1" x:Name="UrlBox"
                             Style="{StaticResource Input}"
                             FontFamily="Consolas" FontSize="12"
                             KeyDown="OnUrlKeyDown" Margin="0,0,6,0"/>
                    <Button Grid.Column="2" Content="이동" Style="{StaticResource BtnGhost}"
                            Padding="8,5" Margin="0,0,8,0" Click="OnNavigateClick"/>
                    <Button Grid.Column="3" Content="Claude" Style="{StaticResource BtnGhost}"
                            Padding="8,5" Margin="0,0,4,0" Click="OnClaudeClick"/>
                    <Button Grid.Column="4" Content="ChatGPT" Style="{StaticResource BtnGhost}"
                            Padding="8,5" Margin="0,0,4,0" Click="OnChatGptClick"/>
                    <Button Grid.Column="5" Content="Gemini" Style="{StaticResource BtnGhost}"
                            Padding="8,5" Click="OnGeminiClick"/>
                </Grid>
            </Border>

            <!-- 브라우저 컨테이너 (탭별 WebView2를 겹쳐서 표시) -->
            <Grid x:Name="WebViewHost" Grid.Row="2" Background="#0d1117"/>
        </Grid>
    </Grid>
</Window>
