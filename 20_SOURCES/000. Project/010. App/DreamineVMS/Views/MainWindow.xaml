<Window x:Class="DreamineVMS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DreamineVMS.Views"
        mc:Ignorable="d"
        Title="Dreamine VMS"
        Icon="pack://application:,,,/wwwroot/images/Icon.ico"
        Width="1380"
        Height="820"
        WindowStartupLocation="CenterScreen"
        Background="#0b1120">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="12" Padding="16" Background="#1f2937" CornerRadius="10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="White" Text="Dreamine VMS" />
                    <TextBlock Margin="0,4,0,20" Foreground="#9ca3af" Text="Hybrid CCTV management shell" />

                    <TextBlock Margin="0,0,0,6" Foreground="White" Text="Camera List" />
                    <ListBox Height="240" ItemsSource="{Binding Cameras}" SelectedItem="{Binding SelectedCamera}" Background="#111827" Foreground="#e5e7eb" BorderBrush="#374151">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Top" Margin="0,5,6,0"
                                             Fill="{Binding StateBrush}" />

                                    <StackPanel Grid.Column="1">
                                        <DockPanel LastChildFill="False">
                                            <TextBlock FontWeight="SemiBold" Foreground="#e5e7eb" Text="{Binding Name}" />
                                            <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="{Binding StateBrush}" Text="{Binding StateText}" />
                                        </DockPanel>
                                        <TextBlock FontSize="11" Foreground="#6b7280" Text="{Binding RtspUrl}" TextWrapping="NoWrap" />
                                        <TextBlock FontSize="11" Foreground="#2563eb" Text="{Binding HlsUrl}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <UniformGrid Columns="2" Rows="2" Margin="0,12,0,0">
                        <Button Height="32" Margin="0,0,6,6" Command="{Binding ConnectSelectedCameraCommand}" Content="Connect" />
                        <Button Height="32" Margin="0,0,0,6" Command="{Binding DisconnectSelectedCameraCommand}" Content="Disconnect" />
                        <Button Height="32" Margin="0,0,6,0" Command="{Binding StartAllCommand}" Content="Start All" />
                        <Button Height="32" Command="{Binding StopAllCommand}" Content="Stop All" />
                    </UniformGrid>

                    <Button Height="32" Margin="0,8,0,0" Command="{Binding ClearLogsCommand}" Content="Clear Logs" />

                    <Border Margin="0,18,0,0" Padding="10" Background="#111827" CornerRadius="8">
                        <TextBlock Foreground="#e5e7eb" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>

                <ListBox Margin="0,18,0,0" ItemsSource="{Binding Logs}" Background="#111827" Foreground="#e5e7eb" BorderBrush="#374151">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2">
                                <TextBlock FontSize="11" Foreground="#6b7280" Text="{Binding Time, StringFormat=HH:mm:ss}" />
                                <TextBlock Foreground="#d1d5db" Text="{Binding Message}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <TabControl Grid.Column="1" Margin="0,12,12,12" x:Name="MainTabControl" Background="#0b1120">
            <TabItem Header="Embedded Dashboard" x:Name="EmbeddedDashboardTab" />
            <TabItem Header="Live" x:Name="WpfLiveTab" />
            <TabItem Header="카메라 관리" x:Name="CamerasTab" />
            <TabItem Header="에이전트 설정">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0b1120" DataContext="{Binding AgentSettings}">
                    <Grid Margin="24" Background="#0b1120">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock FontSize="26" FontWeight="Bold" Foreground="#e5e7eb" Text="에이전트 서버 설정" />
                            <TextBlock Margin="0,6,0,0" Foreground="#9ca3af" TextWrapping="Wrap"
                                       Text="cctvviewer.codemaru.co.kr 에 가입한 이메일과 비밀번호를 입력하세요. 저장하면 appsettings.local.json에 기록되고, 앱을 재시작하면 자동으로 로그인됩니다." />
                        </StackPanel>

                        <!-- 입력 폼 -->
                        <Border Grid.Row="1" Margin="0,0,0,16" Padding="20" Background="#111827" BorderBrush="#1f2937" BorderThickness="1" CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- 서버 URL -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,14" VerticalAlignment="Center" Foreground="#9ca3af" Text="서버 URL" />
                                <TextBox   Grid.Row="0" Grid.Column="1" Margin="0,0,0,14"
                                           Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                           Background="#1f2937" Foreground="#e5e7eb" BorderBrush="#374151"
                                           Padding="8,6" />

                                <!-- 이메일 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,14" VerticalAlignment="Center" Foreground="#9ca3af" Text="이메일" />
                                <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,0,0,14"
                                           Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                           Background="#1f2937" Foreground="#e5e7eb" BorderBrush="#374151"
                                           Padding="8,6" />

                                <!-- 비밀번호 -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,20" VerticalAlignment="Center" Foreground="#9ca3af" Text="비밀번호" />
                                <PasswordBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,20"
                                             x:Name="AgentPasswordBox"
                                             PasswordChanged="AgentPasswordBox_PasswordChanged"
                                             Background="#1f2937" Foreground="#e5e7eb" BorderBrush="#374151"
                                             Padding="8,6" />

                                <!-- 버튼 -->
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                    <Button Width="110" Height="34" Margin="0,0,8,0"
                                            Command="{Binding SaveCommand}" Content="저장" />
                                    <Button Width="110" Height="34" Margin="0,0,8,0"
                                            Command="{Binding TestCommand}" Content="연결 테스트" />
                                    <Button Width="110" Height="34"
                                            Command="{Binding ReconnectCommand}" Content="재연결" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 상태 표시 -->
                        <Border Grid.Row="2" Padding="16" Background="#111827" BorderBrush="#1f2937" BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#e5e7eb" Text="연결 상태" />
                                    <TextBlock DockPanel.Dock="Right" FontSize="14" FontWeight="Bold"
                                               Foreground="{Binding IsConnected, Converter={x:Static local:BoolToBrushConverter.Instance}}"
                                               Text="{Binding IsConnected, Converter={x:Static local:BoolToStatusTextConverter.Instance}}" />
                                </DockPanel>
                                <TextBlock Margin="0,10,0,0" Foreground="#d1d5db" TextWrapping="Wrap"
                                           Text="{Binding StatusMessage}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
