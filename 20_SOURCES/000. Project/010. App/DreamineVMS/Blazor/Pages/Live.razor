@page "/live"
@namespace DreamineVMS.Blazor.Pages
@using DreamineVMS.Blazor.ViewModels
@implements IAsyncDisposable
@inject LivePageViewModel ViewModel

<PageTitle>Dreamine VMS Live</PageTitle>

<div class="page-shell live-shell">
    <div class="hero compact">
        <div>
            <h1>Live View</h1>
            <p>FFmpeg HLS 출력이 생성되면 브라우저/폰에서 재생됩니다.</p>
        </div>
    </div>

    <div class="live-grid six-layout">
        @foreach (var camera in ViewModel.Cameras)
        {
            string playerId = LivePageViewModel.GetPlayerId(camera);

            <section class="video-tile tile-@camera.DisplayOrder" data-status="Stream stopped.">
                <header>
                    <strong>@camera.Name</strong>
                    <span>@camera.Host</span>
                </header>

                <video id="@playerId"
                       class="video-player"
                       controls
                       autoplay
                       muted
                       playsinline
                       preload="auto">
                </video>

                <footer>@camera.HlsUrl</footer>
            </section>
        }
    </div>
</div>

@code {
    private PeriodicTimer? _syncTimer;
    private CancellationTokenSource? _syncCts;
    private bool _disposed;

    protected override void OnInitialized()
    {
        ViewModel.Initialize();
        ViewModel.PlayersNeedSync += OnPlayersNeedSync;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await ViewModel.OnAfterRenderAsync(firstRender);

        if (firstRender)
        {
            StartPlayerSyncLoop();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed)
        {
            return;
        }

        _disposed = true;
        ViewModel.PlayersNeedSync -= OnPlayersNeedSync;

        if (_syncCts is not null)
        {
            await _syncCts.CancelAsync();
        }

        _syncTimer?.Dispose();
        _syncCts?.Dispose();

        await ViewModel.DisposeAsync();
    }

    private void OnPlayersNeedSync(object? sender, EventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            await ViewModel.SynchronizePlayersAsync();
            StateHasChanged();
        });
    }

    private void StartPlayerSyncLoop()
    {
        _syncCts = new CancellationTokenSource();
        _syncTimer = new PeriodicTimer(TimeSpan.FromSeconds(2));

        _ = Task.Run(async () =>
        {
            try
            {
                while (await _syncTimer.WaitForNextTickAsync(_syncCts.Token))
                {
                    await InvokeAsync(ViewModel.SynchronizePlayersAsync);
                }
            }
            catch (OperationCanceledException)
            {
                // 정상 종료.
            }
        });
    }
}
