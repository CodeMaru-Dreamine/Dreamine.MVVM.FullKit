@page "/{Slug}/thankyou"
@layout WeddingThankYou.Blazor.Layout.WeddingLayout
@namespace WeddingThankYou.Blazor.Pages
@rendermode InteractiveServer

@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Rendering
@using Wedding.Common
@inject WeddingThankYou.ViewModels.InvitationViewModel Vm
@inject WeddingThankYou.ViewModels.GuestbookViewModel VmGuest
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>@Vm.CoupleName 감사 인사</PageTitle>

<HeadContent>
    <meta property="og:title" content="@Vm.OgTitle" />
    <meta property="og:description" content="@Vm.OgDescription" />
    <meta property="og:image" content="@(string.IsNullOrWhiteSpace(Vm.OgImageUrl) ? "/img/og-thankyou.png" : Vm.OgImageUrl)" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
</HeadContent>

@if (!Vm.IsLoaded)
{
    <div class="w-loading"><div class="w-spinner"></div></div>
}
else if (Vm.NotFound)
{
    <div class="w-notfound"><h1>404</h1><p>페이지를 찾을 수 없습니다.</p><a href="/">홈으로</a></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(Vm.MusicUrl))
    {
        <div class="w-music-bar @(Vm.MusicButtonPosition == "top" ? "w-music-bar--top" : "") @(Vm.HasCustomMusicButtonPosition ? "w-draggable-positioned" : "") @(AdminPreview ? "w-design-draggable" : "")"
             data-drag-target="music"
             style="@Vm.MusicButtonStyle">
            <audio @ref="audioRef" src="@Vm.MusicUrl" loop preload="auto"></audio>
            <button class="w-music-btn" @onclick="ToggleMusic" title="@(isMusicPlaying ? "음악 끄기" : "음악 켜기")">
                @(isMusicPlaying ? "⏸" : "🎵")
            </button>
            <span class="w-music-label">@(isMusicPlaying ? "재생 중" : "음악 켜기")</span>
        </div>
    }

    @if (UseTabs)
    {
        <nav class="w-invite-tabs-bar" aria-label="감사장 메뉴">
            @foreach (var item in TabItems)
            {
                <button class="@TabClass(item.Key)" @onclick="() => SetTab(item.Key)"><span>@item.Icon</span><small>@item.Label</small></button>
            }
        </nav>

        <button class="w-invite-menu-fab @(_mobileTabMenuOpen ? "is-open" : "")"
                @onclick="ToggleMobileTabMenu" aria-label="메뉴 열기">
            @(_mobileTabMenuOpen ? "✕" : "☰")
        </button>

        @if (_mobileTabMenuOpen)
        {
            <div class="w-invite-menu-backdrop" @onclick="ToggleMobileTabMenu"></div>
            <nav class="w-invite-menu-sheet" aria-label="감사장 메뉴 (모바일)">
                <div class="w-invite-menu-sheet__handle"></div>
                <div class="w-invite-menu-sheet__grid">
                    @foreach (var item in TabItems)
                    {
                        <button class="w-invite-menu-item @(ActiveTab == item.Key ? "active" : "")" @onclick="() => SelectTabAndClose(item.Key)">
                            <span class="w-invite-menu-item__ico">@item.Icon</span><span>@item.Label</span>
                        </button>
                    }
                </div>
            </nav>
        }
    }

    @if (UseGalleryLayout)
    {
        <section class="wedding-layout-gallery w-layout-gallery">
            <section class="wedding-gallery-cover" role="banner">
                @if (!string.IsNullOrWhiteSpace(Vm.HeroImageUrl))
                {
                    <img class="wedding-gallery-cover__image" src="@Vm.HeroImageUrl" alt="@Vm.CoupleName 대표 사진" />
                }
                else
                {
                    <div class="wedding-gallery-cover__image wedding-gallery-cover__image--empty"></div>
                }
                <div class="wedding-gallery-cover__panel">
                    <p class="wedding-layout-kicker">@Vm.HeroTitle</p>
                    <h1>@Vm.CoupleName</h1>
                    <p>@Vm.WeddingDate.ToString("yyyy년 MM월 dd일"), 함께해 주셔서 감사합니다.</p>
                    @if (!string.IsNullOrWhiteSpace(Vm.VenueName))
                    {
                        <p class="wedding-layout-muted">@Vm.VenueName</p>
                    }
                </div>
            </section>

            @foreach (var section in Vm.OrderedSections.Where(x => x != "hero"))
            {
                @RenderPremiumGallerySection(section)
            }
        </section>
    }
    else if (UseStoryLayout)
    {
        @* ══ Story 레이아웃 — 챕터 흐름형 (Gallery 앨범형과 시각적으로 구분) ══ *@
        <section class="wedding-layout-story w-layout-story">

            @foreach (var section in Vm.OrderedSections.Where(x => x != "hero"))
            {
                @RenderPremiumStorySection(section)
            }
        </section>
    }
    else if (!UseTabs || ActiveTab == "hero")
    {
    <section class="w-hero w-hero--thankyou w-hero--dh-@Vm.HeroPanelHorizontalDesktop w-hero--mh-@Vm.HeroPanelHorizontalMobile" role="banner">
        @if (!string.IsNullOrWhiteSpace(Vm.HeroImageUrl))
        {
            <div class="w-hero__bg" style="background-image:url('@Vm.HeroImageUrl')"></div>
        }
        else
        {
            <div class="w-hero__bg w-hero__bg--default"></div>
        }
        <div class="w-hero__overlay"></div>
        <div class="w-hero__content w-hero__content--dv-@Vm.HeroPanelVerticalDesktop w-hero__content--mv-@Vm.HeroPanelVerticalMobile @(Vm.HasCustomHeroPanelPosition ? "w-draggable-positioned" : "") @(AdminPreview ? "w-design-draggable" : "")"
             data-drag-target="heroThankYou"
             style="@Vm.HeroPanelStyle">
            <div class="w-hero__top w-panel">
                <h1 class="w-hero__title">Thank You</h1>
                <p class="w-hero__names">@Vm.CoupleName</p>
                <p class="w-hero__date">@Vm.WeddingDate.ToString("yyyy년 MM월 dd일"), 소중한 자리에 함께해 주셔서 감사합니다.</p>
            </div>
        </div>
    </section>
    }

    @if (!UsePremiumLayout && (!UseTabs || ActiveTab == "message"))
    {
    <section class="w-thankyou-msg glass-panel w-invite-tab-page">
        <h2 class="w-section-title">감사 인사</h2>
        <p>
            @Vm.WeddingDate.ToString("yyyy년 MM월 dd일"), @(Vm.VenueName)에서의 결혼식을<br />
            많은 분들의 축복 속에 무사히 마쳤습니다. 🙇‍♂️🙇‍♀️
        </p>
        <p>
            따뜻한 마음과 귀한 발걸음을 보내주신 모든 분들께<br />
            진심으로 감사드립니다.
        </p>
        @if (!string.IsNullOrWhiteSpace(Vm.Story))
        {
            <hr class="w-divider" />
            <p>@Vm.Story</p>
        }
        @if (!string.IsNullOrWhiteSpace(Vm.Story2))
        {
            <p>@Vm.Story2</p>
        }
    </section>
    }

    @if ((HasVideo) && (!UsePremiumLayout && (!UseTabs || ActiveTab == "video")))
    {
        <section class="w-video w-invite-tab-page">
            <h2 class="w-section-title">우리의 영상</h2>
            <div class="w-video__grid">
                @for (int i = 0; i < Vm.VideoUrls.Count; i++)
                {
                    var idx = i;
                    <button class="w-video__item" @onclick="() => OpenVideoLightbox(idx)">
                        <video src="@Vm.VideoUrls[idx]" preload="metadata" muted playsinline></video>
                        <span class="w-video__play">▶</span>
                    </button>
                }
            </div>
        </section>

        @if (videoLightboxOpen)
        {
            <div class="w-lightbox" role="dialog" tabindex="-1" @ref="vlbRef" @onkeydown="OnVideoKeyDown">
                <button class="w-lb__close" @onclick="CloseVideoLightbox">✕</button>
                @if (Vm.VideoUrls.Count > 1)
                {
                    <button class="w-lb__prev" @onclick="VideoPrev">‹</button>
                }
                <video class="w-lb__video" src="@Vm.VideoUrls[videoLightboxIdx]" controls autoplay playsinline @onplay="PauseMusicForVideo"></video>
                @if (Vm.VideoUrls.Count > 1)
                {
                    <button class="w-lb__next" @onclick="VideoNext">›</button>
                    <span class="w-lb__counter">@(videoLightboxIdx + 1) / @Vm.VideoUrls.Count</span>
                }
            </div>
            <div class="w-lb__backdrop" @onclick="CloseVideoLightbox"></div>
        }
    }

    @if ((HasGallery) && (!UsePremiumLayout && (!UseTabs || ActiveTab == "gallery")))
    {
        <section class="w-gallery w-invite-tab-page">
            <h2 class="w-section-title">우리의 사진</h2>
            <div class="w-gallery__controls">
                <button class="w-btn" @onclick="ToggleAutoPlay">
                    @(isAutoPlaying ? "⏸ 정지" : "▶ 자동재생")
                </button>
                <span class="w-gallery__count">최근 @(Vm.Gallery.Count)장 / 전체 @(Vm.AllPhotos.Count)장</span>
            </div>
            <div class="w-gallery__grid">
                @for (int i = 0; i < Vm.Gallery.Count; i++)
                {
                    var idx = i;
                    <button class="w-gallery__item" @onclick="() => OpenLightbox(idx)">
                        <img src="@Vm.Gallery[idx].ThumbUrl" alt="사진 @(idx+1)" loading="lazy" />
                    </button>
                }
            </div>
        </section>

        @if (Vm.LightboxOpen)
        {
            <div class="w-lightbox" role="dialog" tabindex="-1" @ref="lbRef"
                 @onkeydown="OnKeyDown" @onpointerdown="OnPointerDown" @onpointerup="OnPointerUp">
                <button class="w-lb__close" @onclick="CloseLightbox">✕</button>
                <button class="w-lb__prev" @onclick="Vm.LightboxPrev">‹</button>
                <img class="w-lb__img" src="@Vm.AllPhotos[Vm.LightboxIdx].Url" alt="사진 @(Vm.LightboxIdx+1)" />
                <button class="w-lb__next" @onclick="Vm.LightboxNext">›</button>
                <span class="w-lb__counter">@(Vm.LightboxIdx+1) / @Vm.AllPhotos.Count</span>
            </div>
            <div class="w-lb__backdrop" @onclick="CloseLightbox"></div>
        }
    }

    @if (!UsePremiumLayout && (!UseTabs || ActiveTab == "guestbook"))
    {
    <section class="w-guestbook w-invite-tab-page">
        <h2 class="w-section-title">📖 감사 방명록</h2>
        <div class="w-gb__form">
            <input class="w-input" type="text" placeholder="이름" @bind="VmGuest.Name" />
            <input class="w-input" type="text" placeholder="연락처 (선택)" @bind="VmGuest.Contact" />
            <textarea class="w-input w-textarea" rows="4" placeholder="감사 메시지를 남겨주세요"
                      @bind="VmGuest.Message"></textarea>
            <div class="w-gb__actions">
                <button class="w-btn w-btn--primary" @onclick="OnGuestbookAdd" disabled="@VmGuest.IsSaving">등록</button>
                <button class="w-btn" @onclick="OnGuestbookReload">새로고침</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(VmGuest.LastStatus))
            {
                <p class="w-status">@VmGuest.LastStatus</p>
            }
        </div>
        <ul class="w-gb__list">
            @foreach (var e in VmGuest.EntriesView)
            {
                <li class="w-gb__entry">
                    <div class="w-gb__meta"><strong>@e.Name</strong><span class="w-gb__date">@e.CreatedLocal.ToString("yyyy-MM-dd HH:mm")</span></div>
                    <div class="w-gb__msg">@e.Message</div>
                </li>
            }
        </ul>
    </section>
    }

    <footer class="w-footer">
        <a href="/@Slug">청첩장 보기</a>
        <span> · </span>
        <a href="/@Slug/admin" class="w-admin-link">⚙ 관리자</a>
    </footer>
    @if (UsePremiumLayout)
    {
        <PhotoLightbox Photos="@Vm.AllPhotos"
                       IsOpen="@premiumPhotoLightboxOpen"
                       CurrentIndex="@premiumPhotoLightboxIndex"
                       CurrentIndexChanged="OnPremiumPhotoIndexChanged"
                       Closed="ClosePremiumPhoto" />
    }
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [SupplyParameterFromQuery(Name = "adminPreview")] public bool AdminPreview { get; set; }

    private ElementReference lbRef;
    private ElementReference vlbRef;
    private ElementReference audioRef;
    private bool isMusicPlaying;
    private bool musicSyncInitialized;
    private double? startX;
    private bool isAutoPlaying;
    private System.Threading.CancellationTokenSource? autoCts;

    private bool videoLightboxOpen;
    private int videoLightboxIdx;
    private bool shouldFocusLightbox;
    private bool shouldFocusVideoLightbox;

    private DotNetObjectReference<ThankYou>? _selfRef;

    // ── 탭 스타일 상태 ─────────────────────────────────
    private string ActiveTab { get; set; } = "hero";
    private bool UseTabs => Vm.LayoutMode == WeddingLayoutMode.TabMenu;
    private bool UseGalleryLayout => Vm.LayoutMode == WeddingLayoutMode.Gallery;
    private bool UseStoryLayout => Vm.LayoutMode == WeddingLayoutMode.Story;

    // ── Gallery 레이아웃 사진 표시 정책 ─────────────────────
    private const int GalleryInitialCount = 12;
    private const int GalleryPageSize = 12;
    private int _galleryVisibleCount = GalleryInitialCount;
    private bool premiumPhotoLightboxOpen;
    private int premiumPhotoLightboxIndex;
    private bool premiumAutoPlaying;
    private System.Threading.CancellationTokenSource? premiumAutoCts;
    private int GalleryTotalCount => Vm.AllPhotos.Count;
    private int GalleryVisibleCount => Math.Min(_galleryVisibleCount, GalleryTotalCount);
    private void LoadMoreGallery()
        => _galleryVisibleCount = Math.Min(_galleryVisibleCount + GalleryPageSize, GalleryTotalCount);

    private void OpenPremiumPhoto(PhotoInfo photo)
    {
        var index = Vm.AllPhotos.ToList().FindIndex(p => string.Equals(p.FileName, photo.FileName, StringComparison.OrdinalIgnoreCase));
        OpenPremiumPhoto(index < 0 ? 0 : index);
    }

    private void OpenPremiumPhoto(int index)
    {
        premiumPhotoLightboxIndex = Math.Clamp(index, 0, Math.Max(0, Vm.AllPhotos.Count - 1));
        premiumPhotoLightboxOpen = Vm.AllPhotos.Count > 0;
    }

    private async Task ClosePremiumPhoto()
    {
        await StopPremiumAutoPlay();
        premiumPhotoLightboxOpen = false;
    }

    private void OnPremiumPhotoIndexChanged(int index) => premiumPhotoLightboxIndex = index;

    private async Task TogglePremiumAutoPlay()
    {
        if (premiumAutoPlaying)
        {
            await StopPremiumAutoPlay();
        }
        else
        {
            await StartPremiumAutoPlay();
        }
    }

    private Task StartPremiumAutoPlay()
    {
        if (Vm.AllPhotos.Count == 0 || premiumAutoPlaying) return Task.CompletedTask;

        if (!premiumPhotoLightboxOpen)
        {
            premiumPhotoLightboxIndex = 0;
            premiumPhotoLightboxOpen = true;
        }

        premiumAutoPlaying = true;
        premiumAutoCts = new System.Threading.CancellationTokenSource();
        var token = premiumAutoCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(Vm.GalleryAutoPlayMs, token).ConfigureAwait(false);
                    await InvokeAsync(() =>
                    {
                        if (premiumPhotoLightboxOpen && Vm.AllPhotos.Count > 0)
                        {
                            premiumPhotoLightboxIndex = (premiumPhotoLightboxIndex + 1) % Vm.AllPhotos.Count;
                            StateHasChanged();
                        }
                    });
                }
            }
            catch (TaskCanceledException) { }
        }, token);

        return Task.CompletedTask;
    }

    private Task StopPremiumAutoPlay()
    {
        premiumAutoPlaying = false;
        premiumAutoCts?.Cancel();
        return Task.CompletedTask;
    }

    private RenderFragment RenderStoryChapterBody(StoryChapter chapter, int chapterIndex) => builder =>
    {
        if (!string.IsNullOrWhiteSpace(chapter.Body))
        {
            builder.OpenElement(0, "p");
            builder.AddContent(1, chapter.Body);
            builder.CloseElement();
            return;
        }

        switch (chapterIndex)
        {
            case 0:
                builder.OpenElement(2, "p");
                builder.AddAttribute(3, "class", "wedding-story-kicker");
                builder.AddContent(4, Vm.HeroTitle);
                builder.CloseElement();
                builder.OpenElement(5, "h1");
                builder.AddContent(6, Vm.CoupleName);
                builder.CloseElement();
                builder.OpenElement(7, "p");
                builder.AddAttribute(8, "class", "wedding-story-lede");
                builder.AddContent(9, $"{Vm.WeddingDate:yyyy년 MM월 dd일}, 소중한 마음을 기억합니다.");
                builder.CloseElement();
                builder.OpenElement(10, "p");
                builder.AddContent(11, string.IsNullOrWhiteSpace(Vm.Story) ? "두 사람의 이야기가 여기서부터 시작됩니다." : Vm.Story);
                builder.CloseElement();
                break;
            case 1:
                builder.OpenElement(12, "p");
                builder.AddContent(13, string.IsNullOrWhiteSpace(Vm.Story2) ? "쌓아온 시간을 담아 전해드립니다." : Vm.Story2);
                builder.CloseElement();
                break;
            case 2:
                builder.OpenElement(14, "p");
                builder.AddContent(15, "함께해 주신 시간과 축복의 순간을 사진과 이야기로 천천히 전해드립니다.");
                builder.CloseElement();
                builder.OpenElement(16, "p");
                builder.AddContent(17, "소중한 마음을 보내주신 모든 분들께 오래 기억될 감사의 인사를 남깁니다.");
                builder.CloseElement();
                break;
            default:
                builder.OpenElement(40, "p");
                builder.AddContent(41, $"{Vm.WeddingDate:yyyy년 MM월 dd일}, {Vm.VenueName}에서의 결혼식을 많은 분들의 축복 속에 무사히 마쳤습니다. 따뜻한 마음과 귀한 발걸음을 보내주신 모든 분들께 진심으로 감사드립니다.");
                builder.CloseElement();
                break;
        }
    };

    private const int StoryStripInitial = 6;
    private const int StoryStripPageSize = 12;
    private int _storyStripVisible = StoryStripInitial;
    private int StoryStripTotal => Vm.AllPhotos.Count;
    private int StoryStripVisible => Math.Min(_storyStripVisible, StoryStripTotal);
    private void LoadMoreStoryStrip()
        => _storyStripVisible = Math.Min(_storyStripVisible + StoryStripPageSize, StoryStripTotal);
    private bool UsePremiumLayout => UseGalleryLayout || UseStoryLayout;
    private bool HasVideo => Vm.VideoUrls.Count > 0;
    private bool HasGallery => Vm.Gallery.Count > 0;
    private bool _mobileTabMenuOpen;
    private IReadOnlyList<TabItem> TabItems =>
        [.. Vm.OrderedSections.Where(IsAvailable).Select(x => new TabItem(x, WeddingSectionOrderCatalog.GetIcon(x), WeddingSectionOrderCatalog.GetLabel(x)))];

    private sealed record TabItem(string Key, string Icon, string Label);

    private void SetTab(string tab)
    {
        ActiveTab = tab;
    }
    private string TabClass(string tab) => ActiveTab == tab ? "active" : "";
    private void ToggleMobileTabMenu() => _mobileTabMenuOpen = !_mobileTabMenuOpen;
    private void SelectTabAndClose(string tab)
    {
        ActiveTab = tab;
        _mobileTabMenuOpen = false;
    }

    private bool IsAvailable(string section) => section switch
    {
        "hero" => true,
        "message" => true,
        "gallery" => HasGallery || UseGalleryLayout || UseStoryLayout,
        "video" => HasVideo,
        "guestbook" => true,
        _ => false,
    };

    protected override async Task OnParametersSetAsync()
    {
        await Vm.LoadAsync(Slug);
        await VmGuest.InitializeAsync(Slug);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("weddingInterop.applyTheme", Vm.ThemeName);
        }

        if (Vm.IsLoaded && !string.IsNullOrWhiteSpace(Vm.MusicUrl) && !musicSyncInitialized)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("weddingInterop.initMusicSync", _selfRef);
            await JS.InvokeVoidAsync("weddingInterop.initMusicAutoplay");
            isMusicPlaying = await JS.InvokeAsync<bool>("weddingInterop.isMusicPlaying");
            musicSyncInitialized = true;
            StateHasChanged();
        }

        // 탭 스타일일 때 폰 FAB 에 드래그 이동 바인딩 (JS 내부에서 중복 방지)
        if (UseTabs)
            await JS.InvokeVoidAsync("weddingInterop.initInviteMenuFab");

        if (Vm.IsLoaded && AdminPreview)
            await JS.InvokeVoidAsync("weddingInterop.initDesignDragTargets");

        if (shouldFocusLightbox)
        {
            shouldFocusLightbox = false;
            await lbRef.FocusAsync();
        }

        if (shouldFocusVideoLightbox)
        {
            shouldFocusVideoLightbox = false;
            await vlbRef.FocusAsync();
        }
    }

    private async Task ToggleMusic()
    {
        // 실제 아이콘 상태는 audio 엘리먼트의 play/pause 이벤트(OnMusicStateChanged)가 동기화합니다.
        try
        {
            isMusicPlaying = await JS.InvokeAsync<bool>(isMusicPlaying ? "weddingInterop.pauseMusic" : "weddingInterop.playMusic");
            StateHasChanged();
        }
        catch { }
    }

    private async Task PauseMusicForVideo()
    {
        if (!isMusicPlaying) return;
        try
        {
            isMusicPlaying = await JS.InvokeAsync<bool>("weddingInterop.pauseMusic");
            StateHasChanged();
        }
        catch { }
    }

    /// <summary>배경 클릭으로 자동재생이 시작되거나, 버튼/브라우저 컨트롤로 정지·재생될 때 JS에서 호출됩니다.</summary>
    [JSInvokable]
    public void OnMusicStateChanged(bool playing)
    {
        isMusicPlaying = playing;
        StateHasChanged();
    }

    private void OpenLightbox(int idx)
    {
        Vm.OpenLightbox(idx);
        shouldFocusLightbox = true;
    }

    private async Task CloseLightbox() { await StopAutoPlay(); Vm.CloseLightbox(); }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape": _ = CloseLightbox(); break;
            case "ArrowRight": Vm.LightboxNext(); break;
            case "ArrowLeft": Vm.LightboxPrev(); break;
        }
    }

    private void OnPointerDown(PointerEventArgs e) => startX = e.ClientX;
    private void OnPointerUp(PointerEventArgs e)
    {
        if (startX is null) return;
        var d = e.ClientX - startX.Value; startX = null;
        if (Math.Abs(d) < 30) return;
        if (d < 0) Vm.LightboxNext(); else Vm.LightboxPrev();
    }

    private async Task OpenVideoLightbox(int idx)
    {
        await PauseMusicForVideo();
        videoLightboxIdx = idx;
        videoLightboxOpen = true;
        shouldFocusVideoLightbox = true;
    }

    private void CloseVideoLightbox() => videoLightboxOpen = false;

    private void VideoNext() => videoLightboxIdx = (videoLightboxIdx + 1) % Vm.VideoUrls.Count;
    private void VideoPrev() => videoLightboxIdx = (videoLightboxIdx - 1 + Vm.VideoUrls.Count) % Vm.VideoUrls.Count;

    private void OnVideoKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape": CloseVideoLightbox(); break;
            case "ArrowRight": VideoNext(); break;
            case "ArrowLeft": VideoPrev(); break;
        }
    }

    private async Task ToggleAutoPlay()
    {
        if (isAutoPlaying) await StopAutoPlay(); else await StartAutoPlay();
    }

    private async Task StartAutoPlay()
    {
        if (Vm.Gallery.Count == 0 || isAutoPlaying) return;
        if (!Vm.LightboxOpen) Vm.OpenLightbox(0);
        isAutoPlaying = true;
        autoCts = new();
        var token = autoCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(Vm.GalleryAutoPlayMs, token);
                    if (Vm.LightboxOpen)
                        await InvokeAsync(() => { Vm.LightboxNext(); StateHasChanged(); });
                }
            }
            catch (TaskCanceledException) { }
        }, token);
        await Task.CompletedTask;
    }

    private Task StopAutoPlay() { isAutoPlaying = false; autoCts?.Cancel(); return Task.CompletedTask; }

    private async Task OnGuestbookAdd() { await VmGuest.AddEntryAsync(Slug); StateHasChanged(); }
    private async Task OnGuestbookReload() { await VmGuest.ReloadAsync(Slug); StateHasChanged(); }

    private RenderFragment RenderPremiumGallerySection(string section) => section switch
    {
        "gallery" => RenderPremiumGallery(),
        "message" or "story" => RenderThankYouMessage(),
        "video" when HasVideo => RenderPremiumVideo(),
        "guestbook" => RenderGuestbook(),
        _ => builder => { },
    };

    private RenderFragment RenderPremiumStorySection(string section) => section switch
    {
        "story" or "message" => RenderStoryChapters(),
        "gallery" when StoryStripTotal > 0 => RenderStoryMomentStrip(),
        "video" when HasVideo => RenderPremiumVideo(),
        "guestbook" => RenderGuestbook(),
        _ => builder => { },
    };

    private RenderFragment RenderPremiumGallery() => @<section class="wedding-gallery-section" id="gallery">
        <div class="wedding-layout-heading">
            <p class="wedding-layout-kicker">Gallery</p>
            <h2>감사의 순간들</h2>
            @if (GalleryTotalCount > 0)
            {
                <span>표시 @(GalleryVisibleCount)장 / 전체 @(GalleryTotalCount)장</span>
            }
        </div>
        @if (GalleryTotalCount == 0)
        {
            <div class="wedding-gallery-empty">아직 등록된 사진이 없습니다.</div>
        }
        else
        {
            <div class="w-gallery__controls">
                <button class="w-btn" type="button" @onclick="TogglePremiumAutoPlay">
                    @(premiumAutoPlaying ? "⏸ 정지" : "▶ 자동재생")
                </button>
            </div>
            <div class="wedding-gallery-grid">
                @for (int i = 0; i < GalleryVisibleCount; i++)
                {
                    var photoIndex = i;
                    <figure class="wedding-gallery-tile">
                        <button type="button" class="wedding-photo-thumb" @onclick="() => OpenPremiumPhoto(photoIndex)" aria-label="사진 @(photoIndex + 1) 크게 보기">
                            <img src="@Vm.AllPhotos[photoIndex].ThumbUrl" alt="사진 @(photoIndex + 1)" loading="lazy" />
                        </button>
                    </figure>
                }
            </div>
            @if (GalleryVisibleCount < GalleryTotalCount)
            {
                <div class="wedding-layout-more">
                    <button type="button" class="w-btn w-btn--primary" @onclick="LoadMoreGallery">
                        사진 더 보기 (+@Math.Min(GalleryPageSize, GalleryTotalCount - GalleryVisibleCount))
                    </button>
                </div>
            }
        }
    </section>;

    private RenderFragment RenderThankYouMessage() => @<section class="wedding-story-section">
        <h2>감사 인사</h2>
        <p>@Vm.WeddingDate.ToString("yyyy년 MM월 dd일"), @(Vm.VenueName)에서의 결혼식을 많은 분들의 축복 속에 무사히 마쳤습니다.</p>
        @if (!string.IsNullOrWhiteSpace(Vm.Story))
        {
            <p>@Vm.Story</p>
        }
        @if (!string.IsNullOrWhiteSpace(Vm.Story2))
        {
            <hr class="w-divider" />
            <p>@Vm.Story2</p>
        }
    </section>;

    private RenderFragment RenderPremiumVideo() => @<section class="w-video">
        <h2 class="w-section-title">우리의 영상</h2>
        <div class="w-video__grid">
            @for (int i = 0; i < Vm.VideoUrls.Count; i++)
            {
                <div class="w-video__item">
                    <video src="@Vm.VideoUrls[i]" preload="metadata" controls playsinline @onplay="PauseMusicForVideo"></video>
                </div>
            }
        </div>
    </section>;

    private RenderFragment RenderStoryChapters() => @<text>
        @for (var i = 0; i < Vm.StoryChapters.Count; i++)
        {
            var chapterIndex = i;
            var chapter = Vm.StoryChapters[chapterIndex];
            var photo = Vm.ResolveStoryChapterPhoto(chapter, chapterIndex);
            var isReverse = chapterIndex % 2 == 1;
            var isClosing = chapterIndex == Vm.StoryChapters.Count - 1;
            <section class="wedding-story-chapter @(isReverse ? "wedding-story-chapter--reverse" : "") @(isClosing ? "wedding-story-chapter--closing" : "")">
                <div class="wedding-story-chapter-label">
                    <span class="wedding-story-chapter-label__no">@chapter.Label</span>
                    <span class="wedding-story-chapter-label__title">@chapter.Title</span>
                </div>
                @if (photo is not null)
                {
                    <figure class="wedding-story-hero-photo @(isReverse ? "wedding-story-hero-photo--portrait" : "")">
                        <button type="button" class="wedding-photo-thumb" @onclick="() => OpenPremiumPhoto(photo)" aria-label="@chapter.Title 사진 크게 보기">
                            <img src="@photo.ThumbUrl" alt="@chapter.Title" loading="@(chapterIndex == 0 ? "eager" : "lazy")" />
                        </button>
                    </figure>
                }
                <div class="wedding-story-text-block @(isClosing ? "wedding-story-text-block--wide" : "")">
                    @RenderStoryChapterBody(chapter, chapterIndex)
                </div>
            </section>
        }
    </text>;

    private RenderFragment RenderStoryMomentStrip() => @<section class="wedding-story-moment-strip" id="gallery">
        <div class="wedding-layout-heading">
            <p class="wedding-layout-kicker">Moments</p>
            <h2>함께한 순간</h2>
            <span>표시 @(StoryStripVisible)장 / 전체 @(StoryStripTotal)장</span>
        </div>
        <div class="w-gallery__controls">
            <button class="w-btn" type="button" @onclick="TogglePremiumAutoPlay">
                @(premiumAutoPlaying ? "⏸ 정지" : "▶ 자동재생")
            </button>
        </div>
        <div class="wedding-story-moment-strip__grid">
            @for (int i = 0; i < StoryStripVisible; i++)
            {
                var photoIndex = i;
                <figure>
                    <button type="button" class="wedding-photo-thumb" @onclick="() => OpenPremiumPhoto(photoIndex)" aria-label="사진 @(photoIndex + 1) 크게 보기">
                        <img src="@Vm.AllPhotos[photoIndex].ThumbUrl" alt="사진 @(photoIndex + 1)" loading="lazy" />
                    </button>
                </figure>
            }
        </div>
        @if (StoryStripVisible < StoryStripTotal)
        {
            <div class="wedding-layout-more">
                <button type="button" class="w-btn w-btn--primary" @onclick="LoadMoreStoryStrip">
                    사진 더 보기 (+@Math.Min(StoryStripPageSize, StoryStripTotal - StoryStripVisible))
                </button>
            </div>
        }
    </section>;

    private RenderFragment RenderGuestbook() => @<section class="w-guestbook">
        <h2 class="w-section-title">📖 감사 방명록</h2>
        <div class="w-gb__form">
            <input class="w-input" type="text" placeholder="이름" @bind="VmGuest.Name" />
            <input class="w-input" type="text" placeholder="연락처 (선택)" @bind="VmGuest.Contact" />
            <textarea class="w-input w-textarea" rows="4" placeholder="감사 메시지를 남겨주세요" @bind="VmGuest.Message"></textarea>
            <div class="w-gb__actions">
                <button class="w-btn w-btn--primary" @onclick="OnGuestbookAdd" disabled="@VmGuest.IsSaving">등록</button>
                <button class="w-btn" @onclick="OnGuestbookReload">새로고침</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(VmGuest.LastStatus))
            {
                <p class="w-status">@VmGuest.LastStatus</p>
            }
        </div>
        <ul class="w-gb__list">
            @foreach (var e in VmGuest.EntriesView)
            {
                <li class="w-gb__entry">
                    <div class="w-gb__meta"><strong>@e.Name</strong><span class="w-gb__date">@e.CreatedLocal.ToString("yyyy-MM-dd HH:mm")</span></div>
                    <div class="w-gb__msg">@e.Message</div>
                </li>
            }
        </ul>
    </section>;

    public async ValueTask DisposeAsync()
    {
        await StopAutoPlay();
        await StopPremiumAutoPlay();
        autoCts?.Dispose();
        premiumAutoCts?.Dispose();
        _selfRef?.Dispose();
    }
}
