@page "/{Slug}/admin"
@layout WeddingThankYou.Blazor.Layout.WeddingLayout
@namespace WeddingThankYou.Blazor.Pages
@rendermode InteractiveServer

@using Microsoft.JSInterop
@using Wedding.Common
@using WeddingThankYou.Models
@inject WeddingThankYou.ViewModels.AdminViewModel Vm
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>관리 — @Slug</PageTitle>

<div class="w-admin">
    @if (!Vm.IsAuthenticated)
    {
        <div class="w-admin__login w-panel">
            <h1 class="w-admin__title">⚙ 감사장 관리 — <code>@Slug</code></h1>
            <h2>관리자 로그인</h2>
            @if (Vm.IsSignedIn)
            {
                <p class="w-hint">현재 공용 로그인: <strong>@Vm.CurrentUserLabel</strong></p>
                <p class="w-hint">기존 관리자 비밀번호를 한 번 입력하면 이 계정이 감사장 관리자로 추가됩니다.</p>
            }
            else
            {
                <p class="w-hint">CodeMaru/Dreamine 계정으로 먼저 로그인하면, 기존 비밀번호 확인 후 이 감사장을 계정에 연결할 수 있습니다.</p>
                <a class="w-btn" href="@LoginUrl">공용 로그인</a>
            }
            <input class="w-input" type="password" placeholder="비밀번호" @bind="Vm.LoginPassword" />
            <button class="w-btn w-btn--primary" @onclick="OnLogin">로그인</button>
            @if (!string.IsNullOrWhiteSpace(Vm.StatusMessage))
            {
                <p class="w-status">@Vm.StatusMessage</p>
            }
        </div>
    }
    else if (!Vm.IsLoaded)
    {
        <div class="w-loading"><div class="w-spinner"></div></div>
    }
    else
    {
        <div class="w-admin-shell @(_previewCollapsed ? "is-preview-collapsed" : "")">
            @if (_navOpen)
            {
                <button class="w-admin-nav__backdrop" @onclick="() => _navOpen = false" aria-label="메뉴 닫기"></button>
            }
            <aside class="w-admin-nav @(_navOpen ? "is-open" : "")">
                <div class="w-admin-nav__head">
                    <div class="w-admin-nav__brand">
                        <span class="w-admin-nav__brand-icon">⚙</span>
                        <div>
                            <strong>관리</strong>
                            <small>@Slug</small>
                        </div>
                    </div>
                    <button class="w-admin-nav__close" @onclick="() => _navOpen = false" aria-label="메뉴 닫기">✕</button>
                </div>

                <nav class="w-admin-nav__list">
                    @foreach (var item in VisibleNavItems)
                    {
                        <button class="w-admin-nav__item @(_selected == item.Key ? "active" : "")"
                                @onclick="() => SelectSection(item.Key)">
                            <span class="w-admin-nav__icon">@((MarkupString)item.Icon)</span>
                            <span class="w-admin-nav__label">@item.Label</span>
                        </button>
                    }
                </nav>

                <div class="w-admin-nav__foot">
                    <button class="w-btn w-btn--primary w-btn--block" @onclick="OnSaveConfig">
                        설정 저장
                    </button>
                    <button class="w-btn w-btn--block" @onclick="OnShareThankYou">
                        공유하기
                    </button>
                    @if (!string.IsNullOrWhiteSpace(Vm.StatusMessage))
                    {
                        <p class="w-status">@Vm.StatusMessage</p>
                    }
                    <a class="w-admin-nav__link" href="@PreviewUrl" target="_blank">감사장 열기</a>
                </div>
            </aside>

            <main class="w-admin-content">
                <div class="w-admin-content__topbar">
                    <button class="w-admin-nav__toggle" @onclick="() => _navOpen = !_navOpen" aria-label="메뉴 열기">☰</button>
                    <h2 class="w-admin-content__title">
                        <span class="w-admin-title__icon">@((MarkupString)CurrentNavItem.Icon)</span>
                        <span class="w-admin-title__text">@CurrentNavItem.Label</span>
                    </h2>
                    <button class="w-admin-preview__toggle" @onclick="OnPreviewToggle" aria-label="미리보기 열기"
                            title="미리보기 열기">
                        <span class="w-admin-preview__toggle-icon">📱</span>
                        <span class="w-admin-preview__toggle-text">@(_previewCollapsed ? "미리보기 펼치기" : "미리보기")</span>
                    </button>
                </div>

                <div class="w-admin-content__body">
                    @if (_selected == "basic")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">기본 정보</h3>
                            <label class="w-label">상단 타이틀 문구</label>
                            <input class="w-input" @bind="Vm.Config!.HeroTitle" placeholder="Thank You" />

                            <label class="w-label">커플 이름</label>
                            <input class="w-input" @bind="Vm.Config!.CoupleName" />

                            <div class="w-coord-row">
                                <div>
                                    <label class="w-label">결혼 날짜</label>
                                    <input class="w-input" type="date" @bind="Vm.Config.WeddingDate" />
                                </div>
                                <div>
                                    <label class="w-label">결혼 시간</label>
                                    <input class="w-input" @bind="Vm.Config.WeddingTime" placeholder="예: PM 12:00" />
                                </div>
                            </div>

                            <label class="w-label">스토리 (한국어)</label>
                            <textarea class="w-input w-textarea" rows="5" @bind="Vm.Config.Story"></textarea>

                            <label class="w-label">스토리 (기타 언어)</label>
                            <textarea class="w-input w-textarea" rows="5" @bind="Vm.Config.Story2"></textarea>

                            <label class="w-label">감사 메시지</label>
                            <div class="w-note-toolbar">
                                <button class="@(Vm.Config.CeremonyNoteFormat == "Markdown" ? "active" : "")"
                                        @onclick='() => Vm.Config.CeremonyNoteFormat = "Markdown"'>Markdown</button>
                                <button class="@(Vm.Config.CeremonyNoteFormat == "Html" ? "active" : "")"
                                        @onclick='() => Vm.Config.CeremonyNoteFormat = "Html"'>HTML</button>
                            </div>
                            <textarea class="w-input w-textarea w-textarea--code" rows="8" @bind="Vm.Config.CeremonyNote"
                                      placeholder="## 감사 인사&#10;&#10;소중한 자리에 함께해 주셔서 진심으로 감사드립니다."></textarea>
                        </section>
                    }
                    else if (_selected == "design")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">감사장 레이아웃</h3>
                            <p class="w-hint">감사장이 하객에게 어떻게 보이는지 결정하는 구조입니다.</p>
                            <div class="w-style-picker">
                                @foreach (var descriptor in WeddingLayoutCatalog.Options)
                                {
                                    var canUse = CanUseLayout(descriptor);
                                    var canSelect = canUse && descriptor.IsImplemented;
                                    <label class="w-style-card @(CurrentLayoutMode == descriptor.Mode ? "active" : "") @(!canSelect ? "is-locked" : "")">
                                        <input type="radio" name="w-layout" value="@descriptor.Key" checked="@(CurrentLayoutMode == descriptor.Mode)"
                                               disabled="@(!canSelect)"
                                               @onchange="() => SelectLayout(descriptor.Mode)" />
                                        <div class="w-style-card__preview w-style-card__preview--@descriptor.Key"></div>
                                        <div class="w-style-card__meta">
                                            <strong>@descriptor.Label @if (!descriptor.IsImplemented) { <span class="w-layout-lock">준비 중</span> } else if (!canUse) { <span class="w-layout-lock">잠금</span> }</strong>
                                            <small>@descriptor.Description</small>
                                            @if (!descriptor.IsImplemented)
                                            {
                                                <small class="w-layout-lock-hint">권한 부여는 가능하지만 아직 화면 렌더러가 준비되지 않았습니다.</small>
                                            }
                                            else if (!canUse)
                                            {
                                                <small class="w-layout-lock-hint">프리미엄 플랜 또는 개별 잠금 해제 후 사용할 수 있습니다.</small>
                                            }
                                        </div>
                                    </label>
                                }
                            </div>
                        </section>

                        <section class="w-admin__section">
                            <div class="w-admin-section-title-row">
                                <div>
                                    <h3 class="w-admin__section-h">모바일 섹션 순서</h3>
                                    <p class="w-hint">감사장 모바일 화면과 탭 메뉴가 이 순서를 따릅니다.</p>
                                </div>
                                <button type="button" class="w-btn w-btn--sm" @onclick="ResetSectionOrder">추천 순서</button>
                            </div>
                            <div class="w-section-order-list">
                                @foreach (var section in OrderedDesignSections)
                                {
                                    <div class="w-section-order-item @(section == "hero" ? "is-fixed" : "")">
                                        <span class="w-section-order-item__icon">@WeddingSectionOrderCatalog.GetIcon(section)</span>
                                        <span class="w-section-order-item__label">@WeddingSectionOrderCatalog.GetLabel(section)</span>
                                        <div class="w-section-order-item__actions">
                                            @if (section == "hero")
                                            {
                                                <span class="w-hint">고정</span>
                                            }
                                            else
                                            {
                                                <button type="button" class="w-btn w-btn--sm" @onclick="() => MoveSection(section, -1)">위</button>
                                                <button type="button" class="w-btn w-btn--sm" @onclick="() => MoveSection(section, 1)">아래</button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🎨 테마 색상</h3>
                            <div class="w-theme-picker">
                                @foreach (var t in ThankYouDesignCatalog.Themes)
                                {
                                    var canUse = CanUseTheme(t);
                                    var canSelect = canUse && t.IsImplemented;
                                    <button class="w-theme-btn @(Vm.Config!.ThemeName == t.Key ? "active" : "") @(!canSelect ? "is-locked" : "")"
                                            style="--tc:@t.Primary;--tca:@t.Accent"
                                            disabled="@(!canSelect)"
                                            @onclick="() => SelectTheme(t.Key)">
                                        <span class="w-theme-swatch"></span>
                                        <span>
                                            @t.DisplayName
                                            @if (!t.IsImplemented)
                                            {
                                                <small class="w-layout-lock">준비 중</small>
                                            }
                                            else if (!canUse)
                                            {
                                                <small class="w-layout-lock">잠금</small>
                                            }
                                        </span>
                                    </button>
                                }
                            </div>
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">히어로 이미지</h3>
                            @if (!string.IsNullOrWhiteSpace(Vm.Config!.HeroImageFileName))
                            {
                                <div class="w-admin__hero-preview">
                                    <img src="@Vm.GetHeroUrl(Slug, Vm.Config.HeroImageFileName)" alt="히어로" />
                                    <span>@Vm.Config.HeroImageFileName</span>
                                </div>
                            }
                            <InputFile class="w-file-input" OnChange="OnHeroUpload" accept="image/*" />
                            @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초)</span> }
                        </section>

                        @if (UsesThankYouHeroPlacement)
                        {
                            <section class="w-admin__section">
                                <h3 class="w-admin__section-h">히어로 문구 위치</h3>
                                <p class="w-hint">오른쪽 미리보기에서 감사장 문구 박스를 끌어 위치를 정합니다. 드래그를 놓으면 자동 저장됩니다.</p>
                                <div class="w-drag-control-card">
                                    <strong>감사장 문구 박스</strong>
                                    <span>@FormatFloatingPosition(Vm.Config!.HeroPanelPlacement)</span>
                                    <button type="button" class="w-btn w-btn--sm" @onclick="AlignHeroPanel">가까운 정렬</button>
                                    <button type="button" class="w-btn w-btn--sm" @onclick="ResetHeroPanel">기본 위치</button>
                                </div>
                            </section>
                        }

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🎵 배경 음악</h3>
                            @if (!string.IsNullOrWhiteSpace(Vm.Config!.MusicFileName))
                            {
                                <div class="w-admin__music-preview">
                                    <audio controls src="@Vm.GetMusicUrl(Slug, Vm.Config.MusicFileName)" style="width:100%"></audio>
                                    <span class="w-hint">현재: @Vm.Config.MusicFileName</span>
                                    <button class="w-btn w-btn--danger w-btn--sm" @onclick="OnRemoveMusic">🗑 음악 제거</button>
                                </div>
                            }
                            else
                            {
                                <p class="w-hint">배경 음악이 없습니다. mp3·ogg·m4a 파일을 업로드하세요.</p>
                            }
                            <InputFile class="w-file-input" OnChange="OnMusicUpload" accept="audio/*" />
                            @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초)</span> }

                            <label class="w-label" style="margin-top:.75rem">음악 버튼 위치</label>
                            <div class="w-drag-control-card">
                                <span>오른쪽 미리보기의 음악 버튼을 원하는 위치로 끌어 놓으면 자동 저장됩니다.</span>
                                <span>@FormatFloatingPosition(Vm.Config!.MusicButtonPlacement)</span>
                                <button type="button" class="w-btn w-btn--sm" @onclick="ResetMusicButtonPosition">기본 위치</button>
                            </div>
                        </section>
                    }
                    else if (_selected == "story")
                    {
                        @if (!IsStoryLayout)
                        {
                            <section class="w-admin__section">
                                <h3 class="w-admin__section-h">스토리 챕터</h3>
                                <p class="w-hint">Story 레이아웃을 선택하면 챕터 문구와 대표 사진을 관리할 수 있습니다.</p>
                            </section>
                        }
                        else
                        {
                            <section class="w-admin__section">
                                <div class="w-admin-section-title-row">
                                    <div>
                                        <h3 class="w-admin__section-h">스토리 챕터</h3>
                                        <p class="w-hint">Story 레이아웃에서 사용할 챕터별 대표 사진과 문구입니다. 기본 4개 챕터는 유지되고, 필요한 챕터를 추가할 수 있습니다.</p>
                                    </div>
                                    <button type="button" class="w-btn w-btn--primary" @onclick="OnAddStoryChapter">챕터 추가</button>
                                </div>
                                <div class="w-story-admin-list">
                                    @foreach (var chapter in Vm.Config!.StoryChapters)
                                    {
                                        <article class="w-story-admin-card">
                                            <div class="w-story-admin-card__head">
                                                <strong>@chapter.Label</strong>
                                                <div class="w-story-admin-card__actions">
                                                    @if (chapter.ChapterNumber <= 4)
                                                    {
                                                        <span class="w-layout-lock">기본</span>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="w-btn w-btn--small" @onclick="() => OnDeleteStoryChapter(chapter.ChapterNumber)">삭제</button>
                                                    }
                                                    <button type="button" class="w-btn w-btn--small" @onclick="() => OnSaveStoryChapter(chapter)">챕터 저장</button>
                                                </div>
                                            </div>
                                            <label class="w-label">챕터 제목</label>
                                            <input class="w-input" @bind="chapter.Title" />
                                            <label class="w-label">챕터 본문</label>
                                            <textarea class="w-input w-textarea" rows="4" @bind="chapter.Body"></textarea>
                                            <label class="w-label">대표 사진</label>
                                            <select class="w-input" @bind="chapter.PhotoPath">
                                                <option value="">자동 선택</option>
                                                @foreach (var photo in Vm.Gallery)
                                                {
                                                    <option value="@photo.FileName">@photo.FileName</option>
                                                }
                                            </select>
                                            @if (!string.IsNullOrWhiteSpace(chapter.PhotoPath))
                                            {
                                                <div class="w-story-admin-photo">
                                                    <img src="@Vm.GetThumbUrl(Slug, chapter.PhotoPath)" alt="선택된 대표 사진" />
                                                    <span>@chapter.PhotoPath</span>
                                                </div>
                                            }
                                        </article>
                                    }
                                </div>
                            </section>
                        }
                    }
                    else if (_selected == "content")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🎬 우리의 영상</h3>
                            <p class="w-hint">브라우저 재생 호환성은 mp4 / webm이 가장 좋습니다. mov / m4v는 기기나 코덱에 따라 재생되지 않을 수 있습니다. @Vm.MaxVideoSizeLabel, @(Vm.MaxVideoCount <= 0 ? "개수 무제한" : $"최대 {Vm.MaxVideoCount}개").</p>

                            @if (Vm.Config!.VideoFileNames.Count > 0)
                            {
                                <div class="w-admin__video-list">
                                    @foreach (var fn in Vm.Config.VideoFileNames.ToList())
                                    {
                                        <div class="w-admin__video-item">
                                            <video src="@Vm.GetVideoUrl(Slug, fn)"
                                                   controls preload="metadata" class="w-admin__video-player"></video>
                                            <div class="w-admin__video-meta">
                                                <span class="w-hint">@fn</span>
                                                <button class="w-btn w-btn--danger w-btn--sm"
                                                        @onclick="() => OnDeleteVideo(fn)">삭제</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            @if (Vm.MaxVideoCount <= 0 || Vm.Config.VideoFileNames.Count < Vm.MaxVideoCount)
                            {
                                <InputFile class="w-file-input" OnChange="OnVideoUpload" accept="video/*" />
                                @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초 경과, 용량에 따라 시간이 걸릴 수 있습니다)</span> }
                            }
                            else
                            {
                                <p class="w-hint" style="color:var(--w-primary)">최대 @(Vm.MaxVideoCount)개 업로드 완료. 삭제 후 추가 가능합니다.</p>
                            }
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🖼 갤러리 사진 (@Vm.Gallery.Count 장)</h3>
                            <label class="w-label">자동재생 간격 — <strong>@Vm.Config!.GalleryAutoPlaySeconds 초</strong></label>
                            <input type="range" class="w-range" min="1" max="10" step="1"
                                   @bind="Vm.Config!.GalleryAutoPlaySeconds" @bind:event="oninput" />
                            <InputFile class="w-file-input" OnChange="OnGalleryUpload" accept="image/*" multiple />
                            @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초)</span> }

                            <div class="w-admin__gallery">
                                @foreach (var p in Vm.Gallery)
                                {
                                    <div class="w-admin__gallery-item">
                                        <img src="@Vm.GetThumbUrl(Slug, p.FileName)" alt="@p.FileName" />
                                        <div class="w-admin__photo-order">
                                            <button type="button" class="w-btn w-btn--sm" title="맨 앞으로" @onclick="() => OnMovePhotoTo(p.FileName, true)">처음</button>
                                            <button type="button" class="w-btn w-btn--sm" title="앞으로" @onclick="() => OnMovePhoto(p.FileName, -1)">↑</button>
                                            <button type="button" class="w-btn w-btn--sm" title="뒤로" @onclick="() => OnMovePhoto(p.FileName, 1)">↓</button>
                                            <button type="button" class="w-btn w-btn--sm" title="맨 뒤로" @onclick="() => OnMovePhotoTo(p.FileName, false)">끝</button>
                                        </div>
                                        <button class="w-btn w-btn--danger w-btn--sm"
                                                @onclick="() => OnDeletePhoto(p.FileName)">삭제</button>
                                        <span class="w-admin__fname">@p.FileName</span>
                                    </div>
                                }
                            </div>
                        </section>
                    }
                    else if (_selected == "map")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">예식장 정보</h3>
                            <label class="w-label">예식장 이름</label>
                            <input class="w-input" @bind="Vm.Config!.VenueName" />

                            <label class="w-label">예식장 주소</label>
                            <input class="w-input" @bind="Vm.Config.VenueAddress" />

                            <div class="w-maplink-header" style="margin-top:.75rem">
                                <span class="w-label" style="margin:0">지도 좌표</span>
                                <button class="w-btn w-btn--sm" type="button" @onclick="OnGeocode"
                                        disabled="@Vm.IsGeocoding">
                                    @(Vm.IsGeocoding ? "검색 중..." : "📍 좌표 자동 검색")
                                </button>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Vm.GeocodeStatus))
                            {
                                <p class="w-hint" style="color:@(Vm.GeocodeStatus.StartsWith("✅") ? "green" : "#e53e3e")">
                                    @Vm.GeocodeStatus
                                </p>
                            }
                            <div class="w-coord-row">
                                <div>
                                    <label class="w-label">위도</label>
                                    <input class="w-input" type="number" step="0.000001" @bind="Vm.Config.VenueLat" />
                                </div>
                                <div>
                                    <label class="w-label">경도</label>
                                    <input class="w-input" type="number" step="0.000001" @bind="Vm.Config.VenueLng" />
                                </div>
                            </div>
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🗺 지도 앱 링크</h3>
                            <div class="w-maplink-header">
                                <span class="w-label" style="margin:0">카카오맵 · 네이버지도 · 아틀란 · T맵</span>
                                <button class="w-btn w-btn--sm" type="button" @onclick="OnAutoGenerateMapLinks"
