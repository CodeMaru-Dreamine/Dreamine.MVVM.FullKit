                    else if (_selected == "account")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">💌 마음 전하실 곳</h3>
                            <p class="w-hint">신랑·신부·부모님 등 최대 8명까지 등록할 수 있습니다. 계좌 또는 연락처만 입력해도 됩니다.</p>

                            @for (int i = 0; i < Vm.Config!.Accounts.Count; i++)
                            {
                                var idx = i;
                                var acc = Vm.Config.Accounts[idx];
                                <div class="w-acc-editor">
                                    <div class="w-acc-editor__header">
                                        <strong>@((idx + 1))번 — @(string.IsNullOrWhiteSpace(acc.Label) ? "(레이블 없음)" : acc.Label)</strong>
                                        <button class="w-btn w-btn--danger w-btn--sm" @onclick="() => RemoveAccount(idx)">✕ 삭제</button>
                                    </div>
                                    <div class="w-acc-editor__grid">
                                        <div>
                                            <label class="w-label">레이블</label>
                                            <select class="w-input" value="@acc.Label" @onchange="e => acc.Label = e.Value?.ToString() ?? string.Empty">
                                                <option>신랑</option>
                                                <option>신부</option>
                                                <option>신랑 아버지</option>
                                                <option>신랑 어머니</option>
                                                <option>신부 아버지</option>
                                                <option>신부 어머니</option>
                                                <option>직접 입력</option>
                                            </select>
                                            @if (acc.Label == "직접 입력" || !_defaultLabels.Contains(acc.Label))
                                            {
                                                <input class="w-input" style="margin-top:.4rem" @bind="acc.Label" placeholder="레이블 직접 입력" />
                                            }
                                        </div>
                                        <div>
                                            <label class="w-label">이름</label>
                                            <input class="w-input" @bind="acc.Name" placeholder="홍길동" />
                                        </div>
                                        <div>
                                            <label class="w-label">연락처</label>
                                            <input class="w-input" @bind="acc.Phone" placeholder="010-0000-0000" />
                                        </div>
                                        <div>
                                            <label class="w-label">은행명</label>
                                            <input class="w-input" @bind="acc.BankName" placeholder="국민은행" />
                                        </div>
                                        <div>
                                            <label class="w-label">계좌번호</label>
                                            <input class="w-input" @bind="acc.Account" placeholder="000-000-000000" />
                                        </div>
                                        <div>
                                            <label class="w-label">예금주</label>
                                            <input class="w-input" @bind="acc.AccountHolder" placeholder="홍길동" />
                                        </div>
                                        <div class="w-acc-editor__full">
                                            <label class="w-label">카카오페이 URL</label>
