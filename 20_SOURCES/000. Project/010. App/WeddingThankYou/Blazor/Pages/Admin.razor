                            {
                                <button class="w-btn" @onclick="AddAccount">+ 계좌 / 연락처 추가</button>
                            }
                        </section>
                    }
                    else if (_selected == "share")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🔗 링크 미리보기</h3>
                            <p class="w-hint">카카오톡·문자 등으로 감사장 링크를 공유할 때 표시되는 제목·설명·이미지입니다.</p>

                            <label class="w-label">연결할 청첩장 URL</label>
                            <input class="w-input" @bind="Vm.Config!.InvitationUrl"
                                   placeholder="https://wedding.example.com/couple" />
                            <p class="w-hint">비워두면 감사장 하단의 청첩장 보기 링크를 숨깁니다.</p>

                            <label class="w-label">미리보기 제목</label>
                            <input class="w-input" @bind="Vm.Config!.OgTitle"
                                   placeholder="@(Vm.Config?.CoupleName + " 감사 인사")" />

                            <label class="w-label">미리보기 설명</label>
                            <textarea class="w-input w-textarea" rows="3" @bind="Vm.Config!.OgDescription"
                                      placeholder="@($"{Vm.Config?.WeddingDate:yyyy년 MM월 dd일} {Vm.Config?.VenueName}에서의 결혼식을 마쳤습니다.")"></textarea>

                            <label class="w-label">미리보기 이미지</label>
                            @if (!string.IsNullOrWhiteSpace(Vm.Config!.OgImageFileName))
                            {
                                <div class="w-admin__hero-preview">
                                    <img src="@Vm.GetOgImageUrl(Slug, Vm.Config.OgImageFileName)" alt="OG 이미지" />
                                    <span>@Vm.Config.OgImageFileName</span>
                                    <button class="w-btn w-btn--sm" @onclick="() => { Vm.Config!.OgImageFileName = string.Empty; }">✕ 제거</button>
                                </div>
                            }
                            <InputFile class="w-file-input" OnChange="OnOgImageUpload" accept="image/*" />
                            @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초)</span> }
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">👥 관리자 계정</h3>
                            <p class="w-hint">공용 로그인 상태에서 기존 관리자 비밀번호를 입력하면 여러 계정이 같은 감사장을 관리할 수 있습니다.</p>
                            @if (Vm.EffectiveAdminUsers.Count == 0)
                            {
                                <p class="w-hint">아직 공용 로그인에 연결된 관리자 계정이 없습니다.</p>
                            }
                            else
                            {
                                <div class="w-admin-users">
                                    @foreach (var admin in Vm.EffectiveAdminUsers)
                                    {
                                        var isOwner = string.Equals(admin.Role, "Owner", StringComparison.OrdinalIgnoreCase);
                                        <div class="w-admin-users__item">
                                            <div>
                                                <strong>@(isOwner ? "대표 관리자" : "관리자")</strong>
                                                <span>@(string.IsNullOrWhiteSpace(admin.DisplayName) ? admin.Provider : admin.DisplayName)</span>
                                                @if (!string.IsNullOrWhiteSpace(admin.Email))
                                                {
                                                    <small>@admin.Email</small>
                                                }
                                                <small>@admin.Provider · @admin.AddedAt.ToString("yyyy-MM-dd HH:mm")</small>
                                            </div>
                                            @if (Vm.IsOwner && !isOwner)
                                            {
                                                <button class="w-btn w-btn--danger w-btn--sm" @onclick="() => OnRemoveAdmin(admin.UserId)">삭제</button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🔒 어드민 비밀번호</h3>
                            <label class="w-label">변경 시 입력</label>
                            <input class="w-input" type="password" @bind="Vm.Config!.PasswordHash" />
                        </section>
                    }
                </div>
            </main>

            <div class="w-admin-splitter" title="드래그: 폭 조정 · 더블클릭: 기본값 복원"></div>

            <aside class="w-admin-preview @(_previewOpen ? "is-open" : "")">
                <div class="w-admin-preview__head">
                    <strong>@PreviewHeaderTitle</strong>
                    <div class="w-admin-preview__actions">
                        <button class="w-admin-preview__mode @(_previewMode == "phone" ? "active" : "")" @onclick='() => SetPreviewMode("phone")'>폰</button>
                        <button class="w-admin-preview__mode @(_previewMode == "pc" ? "active" : "")" @onclick='() => SetPreviewMode("pc")'>PC</button>
                        @if (_previewMode == "phone")
                        {
                            <select class="w-admin-preview__device" value="@_previewDeviceKey" @onchange="SetPreviewDevice" title="폰 미리보기 기기">
                                @foreach (var device in _previewDevices)
                                {
                                    <option value="@device.Key">@device.Label</option>
                                }
                            </select>
                        }
                        <button class="w-btn w-btn--sm" @onclick="ReloadPreview" title="미리보기 새로고침">🔄</button>
                        <a class="w-btn w-btn--sm" href="@PreviewUrl" target="_blank" title="새 탭에서 열기">↗</a>
                        <button class="w-admin-preview__close" @onclick="OnClosePreview" aria-label="미리보기 접기">✕</button>
                    </div>
                </div>
                <div class="w-admin-preview__frame w-admin-preview__frame--@_previewMode" style="@PreviewFrameStyle">
                    <iframe id="w-preview-iframe" src="@PreviewUrl" title="@PreviewTitle"></iframe>
                </div>
                <p class="w-admin-preview__hint">저장 후 자동으로 새로고침됩니다.</p>
            </aside>
        </div>
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private string LoginUrl => $"https://codemaru.co.kr/_identity/login?returnUrl={Uri.EscapeDataString(Nav.Uri)}";

    private string _selected = "basic";
    private bool _navOpen;
    private bool _previewOpen;
    private bool _previewCollapsed;
    private bool _initialStateLoaded;
    private bool _adminInteropInitialized;
    private bool _superAdminAutoLoginChecked;
    private string _previewMode = "phone";
    private string _previewDeviceKey = "galaxyS26";
    private DotNetObjectReference<Admin>? _selfRef;

    private record NavItem(string Key, string Icon, string Label);
    private record PreviewDevice(string Key, string Label, int Width, int Height);

    private static readonly PreviewDevice[] _previewDevices =
    [
        new("galaxyS26", "Galaxy S26 · 360×780", 360, 780),
        new("galaxyS26Plus", "Galaxy S26+ · 384×854", 384, 854),
        new("galaxyS26Ultra", "Galaxy S26 Ultra · 412×915", 412, 915),
        new("galaxyZFlip7", "Galaxy Z Flip 7 · 360×840", 360, 840),
        new("galaxyZFold7", "Galaxy Z Fold 7 · 412×915", 412, 915),
        new("iphone17", "iPhone 17 · 393×852", 393, 852),
        new("iphone17Pro", "iPhone 17 Pro · 402×874", 402, 874),
        new("iphone17Max", "iPhone 17 Pro Max · 430×932", 430, 932),
        new("iphoneSE", "iPhone SE · 375×667", 375, 667),
        new("iphone15", "iPhone 15 · 393×852", 393, 852),
        new("iphone15Max", "iPhone 15 Pro Max · 430×932", 430, 932),
        new("galaxyS24", "Galaxy S24 · 360×780", 360, 780),
        new("galaxyS24Ultra", "Galaxy S24 Ultra · 384×854", 384, 854),
    ];

    private static readonly NavItem[] _navItems =
    [
        new("basic",   Icon("user"), "기본 정보"),
        new("design",  Icon("palette"), "디자인"),
        new("story",   Icon("palette"), "스토리 챕터"),
        new("content", Icon("media"), "사진·동영상"),
        new("share",   Icon("share"), "공유 설정"),
    ];

    private bool IsStoryLayout => CurrentLayoutMode == WeddingLayoutMode.Story;
    private bool UsesThankYouHeroPlacement => CurrentLayoutMode is WeddingLayoutMode.WebPage or WeddingLayoutMode.TabMenu;
    private IEnumerable<NavItem> VisibleNavItems => _navItems.Where(i => i.Key != "story" || IsStoryLayout);
    private NavItem CurrentNavItem => VisibleNavItems.FirstOrDefault(i => i.Key == _selected) ?? _navItems[0];
    private string PreviewUrl => $"/{Slug}/thankyou?adminPreview=true";
    private string PreviewTitle => "감사장 미리보기";
    private PreviewDevice CurrentPreviewDevice =>
        _previewDevices.FirstOrDefault(x => string.Equals(x.Key, _previewDeviceKey, StringComparison.OrdinalIgnoreCase))
        ?? _previewDevices[0];
    private string PreviewHeaderTitle =>
        _previewMode == "phone" ? $"폰 미리보기 · {CurrentPreviewDevice.Label}" : "PC 미리보기";
    private string PreviewFrameStyle =>
        _previewMode == "phone"
            ? $"--w-preview-device-width:{CurrentPreviewDevice.Width}px;--w-preview-device-height:{CurrentPreviewDevice.Height}px;"
            : "";
    private IReadOnlyList<string> OrderedDesignSections =>
        WeddingSectionOrderCatalog.NormalizeThankYouOrder(Vm.Config?.SectionOrder);

    private void SetPreviewMode(string mode)
    {
        _previewMode = mode == "pc" ? "pc" : "phone";
    }

    private void SetPreviewDevice(ChangeEventArgs e)
    {
        var key = e.Value?.ToString();
        if (_previewDevices.Any(x => string.Equals(x.Key, key, StringComparison.OrdinalIgnoreCase)))
        {
            _previewDeviceKey = key!;
            _previewMode = "phone";
        }
    }

    private static string Icon(string name) => name switch
    {
        "user" => """<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="3.5"/><path d="M5.5 20c1.2-4 4-6 6.5-6s5.3 2 6.5 6"/></svg>""",
        "palette" => """<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4a8 8 0 0 0 0 16h1.2a1.8 1.8 0 0 0 1.1-3.2 1.6 1.6 0 0 1 1-2.8H17a3 3 0 0 0 3-3c0-3.9-3.6-7-8-7Z"/><circle cx="8.5" cy="10" r=".8"/><circle cx="11" cy="7.8" r=".8"/><circle cx="14.2" cy="8.3" r=".8"/></svg>""",
        "media" => """<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="5" width="16" height="14" rx="2"/><path d="m8 15 2.8-3 2.2 2.2 1.5-1.6L18 16"/><path d="m10 8 5 3-5 3Z"/></svg>""",
        "pin" => """<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s6-5.7 6-11a6 6 0 0 0-12 0c0 5.3 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg>""",
        "card" => """<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="6" width="16" height="12" rx="2"/><path d="M4 10h16"/><path d="M7 15h4"/></svg>""",
        _ => """<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="18" cy="5" r="2.5"/><circle cx="6" cy="12" r="2.5"/><circle cx="18" cy="19" r="2.5"/><path d="m8.2 11 7.6-4.8M8.2 13l7.6 4.8"/></svg>"""
    };

    private static readonly HashSet<string> _defaultLabels =
        ["신랑", "신부", "신랑 아버지", "신랑 어머니", "신부 아버지", "신부 어머니"];

    private int _uploadElapsedSec;
    private System.Threading.CancellationTokenSource? _uploadTickCts;

    private async Task SelectSection(string key)
    {
        if (string.Equals(_selected, key, StringComparison.OrdinalIgnoreCase)) return;

        if (key == "story" && !IsStoryLayout)
        {
            _selected = "design";
            _navOpen = false;
            return;
        }

        if (Vm.Config is not null)
        {
            await Vm.SaveConfigAsync();
        }

        _selected = key;
        _navOpen = false;
    }

    /// <summary>현재 설정에 반영된 감사장 레이아웃 모드 (Admin UI 활성 카드 표시에 사용).</summary>
    private WeddingLayoutMode CurrentLayoutMode =>
        ThankYouDesignCatalog.ResolveLayoutMode(Vm.Config?.ThankYouStyle);

    /// <summary>레이아웃 카드 선택 시 호출 — legacy 문자열 필드에 저장.</summary>
    private void SelectLayout(WeddingLayoutMode mode)
    {
        if (Vm.Config is null) return;
        var option = WeddingLayoutCatalog.Instance.Find(mode);
        if (option is null || !option.IsImplemented || !CanUseLayout(option)) return;
        Vm.Config.ThankYouStyle = ThankYouDesignCatalog.ToLegacyLayoutKey(mode);
        if (mode != WeddingLayoutMode.Story && _selected == "story")
        {
            _selected = "design";
        }
    }

    private bool CanUseLayout(WeddingLayoutOption option)
    {
        if (Vm.Config is null) return option.Tier == WeddingLayoutTier.Free;
        return new WeddingLayoutAccessPolicy().CanUse(option, BuildLayoutAccessState());
    }

    private WeddingLayoutAccessState BuildLayoutAccessState()
    {
        if (Vm.Config is null) return new WeddingLayoutAccessState();
        return new WeddingLayoutAccessState
        {
            HasPremiumPlan = Vm.Config.HasPremiumPlan,
            UnlockedLayouts = Vm.Config.UnlockedLayoutModes
                .Select(WeddingLayoutCatalog.FromLegacyKey)
                .Where(x => x != WeddingLayoutMode.Unknown)
                .ToArray(),
        };
    }

    private bool CanUseTheme(WeddingThemeOption option)
    {
        if (Vm.Config is null) return option.Tier == WeddingThemeTier.Free;
        return new WeddingThemeAccessPolicy().CanUse(option, BuildThemeAccessState());
    }

    private WeddingThemeAccessState BuildThemeAccessState()
    {
        if (Vm.Config is null) return new WeddingThemeAccessState();
        return new WeddingThemeAccessState
        {
            HasPremiumPlan = Vm.Config.HasPremiumPlan,
            UnlockedThemeKeys = Vm.Config.UnlockedThemeKeys
                .Select(WeddingThemeCatalog.NormalizeKey)
                .Where(WeddingThemeCatalog.IsKnownKey)
                .ToArray(),
        };
    }

    private void SelectTheme(string themeKey)
    {
        if (Vm.Config is null) return;
        var option = WeddingThemeCatalog.Instance.Find(themeKey);
        if (option is null || !option.IsImplemented || !CanUseTheme(option)) return;
        Vm.Config.ThemeName = option.Key;
    }

    private async Task ReloadPreview()
    {
        try
        {
            await JS.InvokeVoidAsync("weddingInterop.reloadPreviewIframe");
        }
        catch { }
    }

    protected override async Task OnInitializedAsync()
    {
        await Vm.InitializeAsync(Slug);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !Vm.IsAuthenticated && !_superAdminAutoLoginChecked)
        {
            _superAdminAutoLoginChecked = true;
            if (await TrySuperAdminAutoLoginAsync())
            {
                StateHasChanged();
                return;
            }
        }

        if (Vm.IsAuthenticated && Vm.IsLoaded)
        {
            if (!_adminInteropInitialized)
            {
                _adminInteropInitialized = true;
                try { await JS.InvokeVoidAsync("weddingInterop.initAdminSplitter"); }
                catch { }

                _selfRef ??= DotNetObjectReference.Create(this);
                try { await JS.InvokeVoidAsync("weddingInterop.initAdminPreviewDesignBridge", _selfRef); }
                catch { }
            }

            if (!_initialStateLoaded)
            {
                _initialStateLoaded = true;
                try
                {
                    _previewCollapsed = await JS.InvokeAsync<bool>("weddingInterop.getPreviewCollapsed");
                    StateHasChanged();
                }
                catch { }
            }
        }
    }

    private async Task OnClosePreview()
    {
        _previewCollapsed = true;
        _previewOpen = false;
        try { await JS.InvokeVoidAsync("weddingInterop.setPreviewCollapsed", true); }
        catch { }
    }

    private async Task OnPreviewToggle()
    {
        if (_previewCollapsed)
        {
            _previewCollapsed = false;
            try { await JS.InvokeVoidAsync("weddingInterop.setPreviewCollapsed", false); }
            catch { }
        }
        _previewOpen = !_previewOpen;
    }

    private async Task RunUploadAsync(Func<Task> action)
    {
        _uploadElapsedSec = 0;
        _uploadTickCts = new System.Threading.CancellationTokenSource();
        var token = _uploadTickCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(1000, token);
                    _uploadElapsedSec++;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (TaskCanceledException) { }
        });

        try { await action(); }
        finally { _uploadTickCts.Cancel(); }
    }

    private async Task<bool> TrySuperAdminAutoLoginAsync()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("weddingInterop.getSuperAdminSessionToken");
            return await Vm.LoginAsSuperAdminAsync(Slug, token);
        }
        catch
        {
            return false;
        }
    }

    private async Task OnLogin()
    {
        if (await Vm.LoginAsync(Slug))
            await Vm.LoadAsync(Slug);
    }

    private async Task OnSaveConfig()
    {
        await Vm.SaveConfigAsync();
        await ReloadPreview();
    }

    private void MoveSection(string section, int offset)
    {
        if (Vm.Config is null || section == "hero") return;
        var order = OrderedDesignSections.ToList();
        var index = order.FindIndex(x => string.Equals(x, section, StringComparison.OrdinalIgnoreCase));
        if (index < 0) return;
        var target = Math.Clamp(index + offset, 1, order.Count - 1);
        if (target == index) return;
        order.RemoveAt(index);
        order.Insert(target, section);
        Vm.Config.SectionOrder = order;
    }

    private void ResetSectionOrder()
    {
        if (Vm.Config is null) return;
        Vm.Config.SectionOrder = WeddingSectionOrderCatalog.ThankYouRecommendedOrder.ToList();
    }

    private async Task ResetMusicButtonPosition()
    {
        if (Vm.Config is null) return;
        Vm.Config.MusicButtonPlacement = new WeddingFloatingPosition();
        Vm.Config.MusicButtonPosition = "bottom";
        await Vm.SaveConfigAsync();
        await ReloadPreview();
    }

    private async Task ResetHeroPanel()
    {
        if (Vm.Config is null) return;
        Vm.Config.HeroPanelPlacement = new WeddingFloatingPosition();
        await Vm.SaveConfigAsync();
        await ReloadPreview();
    }

    private async Task AlignHeroPanel()
    {
        if (Vm.Config is null) return;
        SnapFloatingPosition(Vm.Config.HeroPanelPlacement);
        await Vm.SaveConfigAsync();
        await ReloadPreview();
    }

    [JSInvokable]
    public async Task OnPreviewElementMoved(string target, double xPercent, double yPercent, string viewport)
    {
        if (Vm.Config is null) return;
        var isMobile = string.Equals(viewport, "mobile", StringComparison.OrdinalIgnoreCase);
        switch (target)
        {
            case "music":
                SetFloatingPosition(Vm.Config.MusicButtonPlacement, xPercent, yPercent, isMobile);
                Vm.Config.MusicButtonPosition = "custom";
                break;
            case "heroThankYou":
                SetFloatingPosition(Vm.Config.HeroPanelPlacement, xPercent, yPercent, isMobile);
                break;
            default:
                return;
        }

        await Vm.SaveConfigAsync();
        StateHasChanged();
    }

    private static void SetFloatingPosition(WeddingFloatingPosition position, double xPercent, double yPercent, bool mobile)
    {
        if (mobile)
        {
            position.MobileX = ClampPercent(xPercent);
            position.MobileY = ClampPercent(yPercent);
        }
        else
        {
            position.DesktopX = ClampPercent(xPercent);
            position.DesktopY = ClampPercent(yPercent);
        }
    }

    private static void SnapFloatingPosition(WeddingFloatingPosition position)
    {
        if (position.HasDesktop)
        {
            position.DesktopX = SnapPercent(position.DesktopX!.Value);
            position.DesktopY = SnapPercent(position.DesktopY!.Value);
        }
        if (position.HasMobile)
        {
            position.MobileX = SnapPercent(position.MobileX!.Value);
            position.MobileY = SnapPercent(position.MobileY!.Value);
        }
    }

    private static double SnapPercent(double value)
    {
        var anchors = new[] { 15d, 50d, 85d };
        return anchors.OrderBy(x => Math.Abs(x - value)).First();
    }

    private static double ClampPercent(double value) => Math.Clamp(value, 0, 100);

    private static string FormatFloatingPosition(WeddingFloatingPosition position)
    {
        var mobile = position.HasMobile ? $"모바일 {position.MobileX:0.#}%, {position.MobileY:0.#}%" : "모바일 기본";
        var desktop = position.HasDesktop ? $"PC {position.DesktopX:0.#}%, {position.DesktopY:0.#}%" : "PC 기본";
        return $"{desktop} · {mobile}";
    }

