@namespace WeddingThankYou.Blazor
@using Microsoft.AspNetCore.Components.Web

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="/css/wedding.css?v=20260701" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;600&display=swap" rel="stylesheet" />
    <HeadOutlet />
</head>
<body>
    <WeddingThankYou.Blazor.Routes @rendermode="new InteractiveServerRenderMode(prerender: true)" />
    <script src="/_framework/blazor.web.js" autostart="false"></script>
    <script src="/js/wedding-interop.js"></script>
    <script>
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 10,
                    retryIntervalMilliseconds: (previousAttempts) => {
                        return Math.min(1000 * Math.pow(2, previousAttempts), 30000);
                    }
                },
                configureSignalR: function (builder) {
                    builder.withUrl('/_blazor', {
                        transport: 7 // HttpTransportType.WebSockets | SSE | LongPolling
                    }).withAutomaticReconnect([0, 1000, 2000, 5000, 10000, 15000, 30000, 30000, 30000, 30000]);
                }
            }
        });
    </script>
</body>
</html>
