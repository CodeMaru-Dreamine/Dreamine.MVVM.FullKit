@page "/apply"
@inject ShopOptions ShopOpts
@inject IShopTenantStore TenantStore
@inject TenantDbContextFactory DbFactory

<PageTitle>쇼핑몰 개설 신청 — ShopPlatform</PageTitle>

<div class="sp-apply-wrap">
    <div class="sp-apply-box">

        @if (_submitted)
        {
            <!-- 신청 완료 -->
            <div class="sp-apply-done">
                <div class="sp-apply-done-icon">🎉</div>
                <h2>쇼핑몰이 개설되었습니다!</h2>
                <p class="text-muted">
                    지금 바로 어드민에 로그인해서 상품을 등록할 수 있습니다.
                </p>
                <div class="sp-apply-url-preview">
                    <span class="text-muted small">쇼핑몰 주소</span>
                    <strong>@(ShopOpts.BaseUrl.TrimEnd('/'))/@_slug</strong>
                    <span class="text-muted small mt-1">어드민 주소</span>
                    <strong>@(ShopOpts.BaseUrl.TrimEnd('/'))/@_slug/admin</strong>
                </div>
                <div class="sp-apply-notice mt-3">
                    <p>⚠️ <strong>24시간 이내에 상품을 1개 이상 등록</strong>하지 않으면 쇼핑몰이 자동 삭제됩니다.</p>
                    <p>📧 문의: <a href="mailto:admin@codemaru.co.kr">admin@codemaru.co.kr</a></p>
                </div>
                <div class="d-flex gap-2 justify-content-center mt-4 flex-wrap">
                    <a href="/@_slug/admin" class="btn btn-primary">어드민 바로가기 →</a>
                    <a href="/@_slug" class="btn btn-outline-secondary">쇼핑몰 보기</a>
                </div>
            </div>
        }
        else
        {
            <div class="sp-apply-header">
                <h1>쇼핑몰 개설 신청</h1>
                <p class="text-muted">아래 정보를 입력하시면 관리자가 확인 후 쇼핑몰을 개설해 드립니다.</p>
            </div>

            <!-- 안내 박스 -->
            <div class="sp-apply-alert">
                <div>🆓 <strong>완전 무료</strong>로 운영됩니다. 별도 요금이 없습니다.</div>
                <div>⏰ 개설 후 <strong>24시간 이내 상품 미등록 시 자동 삭제</strong>됩니다.</div>
                <div>⚡ 무료 서비스 특성상 일시적 접속 장애가 발생할 수 있습니다.</div>
            </div>

            <EditForm Model="_form" OnValidSubmit="Submit">
                <DataAnnotationsValidator />

                <div class="sp-form-group">
                    <label>원하는 쇼핑몰 주소 <span class="text-danger">*</span></label>
                    <div class="sp-slug-input-wrap">
                        <span class="sp-slug-prefix">@(ShopOpts.BaseUrl.TrimEnd('/'))/</span>
                        <InputText @bind-Value="_form.Slug" class="form-control sp-slug-field"
                                   placeholder="my-shop" @oninput="OnSlugInput" />
                    </div>
                    @if (!string.IsNullOrEmpty(_slugError))
                    {
                        <div class="text-danger small mt-1">@_slugError</div>
                    }
                    else if (_slugOk)
                    {
                        <div class="text-success small mt-1">✓ 사용 가능한 주소입니다</div>
                    }
                    <div class="form-text">영문 소문자, 숫자, 하이픈(-)만 사용. 예: my-shop, flower-store</div>
                </div>

                <div class="sp-form-group">
                    <label>쇼핑몰 이름 <span class="text-danger">*</span></label>
                    <InputText @bind-Value="_form.ShopName" class="form-control" placeholder="예: 코드마루 꽃집" />
                    <ValidationMessage For="() => _form.ShopName" />
                </div>

                <div class="sp-form-group">
                    <label>어드민 비밀번호 <span class="text-danger">*</span></label>
                    <InputText @bind-Value="_form.AdminPassword" type="password" class="form-control"
                               placeholder="본인만 아는 비밀번호 (8자 이상)" />
                    <div class="form-text">이 비밀번호로 쇼핑몰 어드민에 로그인합니다. 잘 기억해두세요.</div>
                    <ValidationMessage For="() => _form.AdminPassword" />
                </div>

                <div class="sp-form-group">
                    <label>연락처 이메일 <span class="text-danger">*</span></label>
                    <InputText @bind-Value="_form.Email" type="email" class="form-control"
                               placeholder="example@email.com" />
                    <div class="form-text">개설 완료 안내 및 중요 공지를 발송합니다.</div>
                    <ValidationMessage For="() => _form.Email" />
                </div>

                <div class="sp-form-group">
                    <label>간단한 소개 <span class="text-muted">(선택)</span></label>
                    <InputTextArea @bind-Value="_form.Description" class="form-control" rows="2"
                                  placeholder="판매할 상품이나 쇼핑몰에 대해 간단히 적어주세요" />
                </div>

                @if (!string.IsNullOrEmpty(_errorMsg))
                {
                    <div class="alert alert-danger py-2">@_errorMsg</div>
                }

                <div class="sp-apply-terms">
                    <label>
                        <input type="checkbox" @bind="_agreedTerms" />
                        &nbsp;무료 서비스 이용 안내를 확인했으며, 24시간 내 상품 미등록 시 자동 삭제됨에 동의합니다.
                    </label>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 mt-3"
                        disabled="@(_isSubmitting || !_agreedTerms)">
                    @if (_isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>신청 중...</span>
                    }
                    else
                    {
                        <span>쇼핑몰 개설 신청하기 →</span>
                    }
                </button>
            </EditForm>

            <div class="sp-apply-footer-note">
                이미 쇼핑몰을 운영 중이신가요?
                <a href="#" @onclick="GoToAdmin" @onclick:preventDefault>어드민 로그인 →</a>
            </div>
        }
    </div>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private ApplyForm _form = new();
    private bool _submitted;
    private bool _isSubmitting;
    private bool _agreedTerms;
    private string _slugError = string.Empty;
    private bool _slugOk;
    private string _email = string.Empty;
    private string _slug  = string.Empty;
    private string _errorMsg = string.Empty;

    private async Task OnSlugInput(ChangeEventArgs e)
    {
        var raw = (e.Value?.ToString() ?? "").ToLowerInvariant().Trim();
        // 허용 문자 필터
        _form.Slug = System.Text.RegularExpressions.Regex.Replace(raw, @"[^a-z0-9\-]", "");
        _slugError = string.Empty;
        _slugOk    = false;

        if (string.IsNullOrEmpty(_form.Slug)) return;
        if (_form.Slug.Length < 2)  { _slugError = "2자 이상 입력해주세요."; return; }
        if (_form.Slug.Length > 30) { _slugError = "30자 이하로 입력해주세요."; return; }

        // Reserved 경로 체크
        var reserved = new[] { "admin", "apply", "pay", "healthz", "policy", "img", "css", "js" };
        if (reserved.Contains(_form.Slug)) { _slugError = "사용할 수 없는 주소입니다."; return; }

        // 중복 체크
        var existing = await TenantStore.GetAsync(_form.Slug);
        if (existing != null) { _slugError = "이미 사용 중인 주소입니다."; return; }

        _slugOk = true;
    }

    private async Task Submit()
    {
        _errorMsg = string.Empty;

        // 슬러그 재검증
        if (!_slugOk && string.IsNullOrEmpty(_slugError))
            await OnSlugInput(new ChangeEventArgs { Value = _form.Slug });

        if (!string.IsNullOrEmpty(_slugError)) { _errorMsg = "주소를 확인해주세요."; return; }
        if (!_slugOk) { _errorMsg = "주소를 먼저 확인해주세요."; return; }
        if (string.IsNullOrWhiteSpace(_form.Slug)) { _errorMsg = "쇼핑몰 주소를 입력해주세요."; return; }
        if (_form.AdminPassword.Length < 8) { _errorMsg = "비밀번호는 8자 이상이어야 합니다."; return; }

        _isSubmitting = true;

        try
        {
            // 이중 중복 체크
            var existing = await TenantStore.GetAsync(_form.Slug);
            if (existing != null) { _errorMsg = "이미 사용 중인 주소입니다. 다른 주소를 입력해주세요."; return; }

            // 쇼핑몰 즉시 생성
            var config = new ShopPlatform.Models.ShopConfig
            {
                Slug              = _form.Slug,
                ShopName          = _form.ShopName,
                Description       = _form.Description,
                AdminPasswordHash = _form.AdminPassword,   // 평문 저장 (기존 방식 동일)
                IsActive          = true,
                CreatedAt         = DateTime.UtcNow,
                Business          = new ShopPlatform.Models.ShopBusinessInfo
                {
                    Email = _form.Email
                }
            };

            await TenantStore.SaveAsync(config);

            // SQLite DB 초기화 (테이블 생성)
            using var db = DbFactory.Create(_form.Slug);
            // EnsureCreated는 DbContextFactory 내부에서 호출됨

            _email     = _form.Email;
            _slug      = _form.Slug;
            _submitted = true;
        }
        catch (Exception ex)
        {
            _errorMsg = $"개설 중 오류가 발생했습니다. admin@codemaru.co.kr 로 문의해주세요. ({ex.Message})";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void GoToAdmin()
    {
        // 슬러그를 모르므로 루트 admin으로 이동 (SuperAdmin)
        Nav.NavigateTo("/admin");
    }

    public class ApplyForm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "쇼핑몰 이름을 입력해주세요.")]
        public string ShopName { get; set; } = string.Empty;

        public string Slug { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "비밀번호를 입력해주세요.")]
        public string AdminPassword { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "이메일을 입력해주세요.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "올바른 이메일 형식이 아닙니다.")]
        public string Email { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;
    }
}
