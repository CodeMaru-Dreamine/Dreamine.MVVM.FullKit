@page "/{Slug}/admin"
@using Dreamine.Identity
@inject TenantContext Tenant
@inject IShopTenantStore TenantStore
@inject ShopUserContext UserContext
@inject NavigationManager Nav

<PageTitle>어드민 — @(Tenant.Config?.ShopName ?? "쇼핑몰")</PageTitle>

@if (!Tenant.IsResolved)
{
    <div class="container py-5 text-center">
        <h2>존재하지 않는 쇼핑몰입니다.</h2>
    </div>
}
else if (!currentUser.IsAuthenticated)
{
    <div class="container py-5" style="max-width:460px">
        <h2>@Tenant.Config!.ShopName 어드민</h2>
        <p class="text-muted">CodeMaru 계정으로 로그인하면 쇼핑몰을 관리할 수 있습니다.</p>
        <a class="btn btn-primary w-100" href="@LoginUrl">CodeMaru 계정으로 로그인</a>
    </div>
}
else if (!_authenticated)
{
    <div class="container py-5" style="max-width:400px">
        <h2>@Tenant.Config!.ShopName 어드민</h2>
        <p class="text-muted">현재 계정: <strong>@CurrentUserLabel</strong></p>
        <div class="mb-3">
            <label class="form-label">기존 어드민 비밀번호</label>
            <input type="password" class="form-control" @bind="_password" @bind:event="oninput" @onkeypress="OnKeyPress" />
        </div>
        @if (!string.IsNullOrEmpty(_loginError))
        {
            <div class="alert alert-danger">@_loginError</div>
        }
        <button class="btn btn-primary w-100" @onclick="LinkLegacyAdmin">현재 계정에 연결</button>
    </div>
}
else
{
    <div class="container-fluid py-3">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>@Tenant.Config!.ShopName 관리</h2>
            <div>
                <a href="/@Slug" class="btn btn-outline-secondary me-2" target="_blank">쇼핑몰 보기 ↗</a>
                <button class="btn btn-outline-danger" @onclick="Logout">로그아웃</button>
            </div>
        </div>

        <!-- 탭 네비게이션 -->
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <button class="nav-link @(_tab == "products" ? "active" : "")"
                        @onclick='() => _tab = "products"'>상품 관리</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(_tab == "orders" ? "active" : "")"
                        @onclick='() => _tab = "orders"'>주문 관리</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(_tab == "payment" ? "active" : "")"
                        @onclick='() => _tab = "payment"'>결제 설정</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(_tab == "shop" ? "active" : "")"
                        @onclick='() => _tab = "shop"'>쇼핑몰 설정</button>
            </li>
        </ul>

        @if (_tab == "products")
        {
            <ShopPlatform.Components.Pages.Admin.Partials.ProductsTab Slug="@Slug" />
        }
        else if (_tab == "orders")
        {
            <ShopPlatform.Components.Pages.Admin.Partials.OrdersTab Slug="@Slug" />
        }
        else if (_tab == "payment" && _config != null)
        {
            <ShopPlatform.Components.Pages.Admin.Partials.PaymentSettingsTab Config="_config" OnSave="SaveConfig" />
        }
        else if (_tab == "shop" && _config != null)
        {
            <ShopPlatform.Components.Pages.Admin.Partials.ShopSettingsTab Config="_config"
                                                                          CurrentUserId="@currentUser.Id"
                                                                          OnSave="SaveConfig" />
        }
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private ShopConfig? _config;
    private ShopCurrentUser currentUser = ShopCurrentUser.Anonymous;
    private bool _authenticated;
    private string _password = string.Empty;
    private string _loginError = string.Empty;
    private string _tab = "products";

    protected override async Task OnParametersSetAsync()
    {
        // InteractiveServer 회로는 미들웨어를 거치지 않으므로 직접 로드
        if (!Tenant.IsResolved)
        {
            var cfg = await TenantStore.GetAsync(Slug);
            if (cfg != null) Tenant.Config = cfg;
        }
        _config = Tenant.Config;
        currentUser = await UserContext.GetCurrentAsync();
        _authenticated = _config != null && IsAdminUser(_config, currentUser);
    }

    private async Task LinkLegacyAdmin()
    {
        if (_config == null) return;
        var verification = DreaminePasswordHasher.VerifyPassword(_password, _config.AdminPasswordHash, out var upgradedHash);
        if (verification is not PasswordHashVerificationResult.Failed)
        {
            if (verification is PasswordHashVerificationResult.SuccessRehashNeeded && upgradedHash is not null)
            {
                _config.AdminPasswordHash = upgradedHash;
            }

            if (string.IsNullOrWhiteSpace(_config.OwnerUserId))
            {
                _config.OwnerUserId = currentUser.Id;
                _config.OwnerProvider = currentUser.Provider;
                _config.OwnerEmail = currentUser.Email;
                _config.OwnerDisplayName = currentUser.DisplayName;
                _config.OwnerLinkedAt = DateTime.UtcNow;
                EnsureAdminUser(_config, currentUser, "Owner");
            }
            else
            {
                EnsureAdminUser(_config, currentUser, "Admin");
            }

            await TenantStore.SaveAsync(_config);
            _authenticated = true;
            _loginError = string.Empty;
        }
        else
        {
            _loginError = "비밀번호가 올바르지 않습니다.";
        }
    }

    private void Logout()
    {
        _authenticated = false;
        Nav.NavigateTo($"https://codemaru.co.kr/_identity/signout?returnUrl={Uri.EscapeDataString(Nav.BaseUri)}", forceLoad: true);
    }

    private void OnKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = LinkLegacyAdmin();
    }

    private async Task SaveConfig(ShopConfig cfg)
    {
        await TenantStore.SaveAsync(cfg);
        StateHasChanged();
    }

    private string LoginUrl => $"https://codemaru.co.kr/_identity/login?returnUrl={Uri.EscapeDataString(Nav.Uri)}";
    private string CurrentUserLabel => string.IsNullOrWhiteSpace(currentUser.DisplayName) ? currentUser.Email : currentUser.DisplayName;

    private static bool IsAdminUser(ShopConfig config, ShopCurrentUser user)
    {
        if (!user.IsAuthenticated) return false;
        if (string.Equals(config.OwnerUserId, user.Id, StringComparison.Ordinal)) return true;
        return config.AdminUsers.Any(x => string.Equals(x.UserId, user.Id, StringComparison.Ordinal));
    }

    private static void EnsureAdminUser(ShopConfig config, ShopCurrentUser user, string role)
    {
        var existing = config.AdminUsers.FirstOrDefault(x => string.Equals(x.UserId, user.Id, StringComparison.Ordinal));
        if (existing == null)
        {
            config.AdminUsers.Add(new ShopAdminUser
            {
                UserId = user.Id,
                Provider = user.Provider,
                Email = user.Email,
                DisplayName = user.DisplayName,
                Role = role,
                AddedAt = DateTime.UtcNow
            });
            return;
        }

        existing.Provider = user.Provider;
        existing.Email = user.Email;
        existing.DisplayName = user.DisplayName;
        existing.Role = role;
    }
}
