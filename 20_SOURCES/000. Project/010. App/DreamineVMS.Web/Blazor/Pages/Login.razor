@page "/login"
@namespace DreamineVMS.Web.Blazor.Pages
@inject NavigationManager Nav

<PageTitle>로그인 — Dreamine VMS</PageTitle>

<div class="page-shell auth-shell">
    <div class="auth-card">
        <h1>로그인</h1>
        <p class="muted">CodeMaru 공통 로그인으로 이동합니다.</p>
        <a class="primary link-button full-btn" href="@LoginUrl">로그인 계속하기</a>
    </div>
</div>

@code {
    private string LoginUrl => $"https://codemaru.co.kr/_identity/login?returnUrl={Uri.EscapeDataString(Nav.BaseUri)}";

    protected override void OnInitialized()
    {
        Nav.NavigateTo(LoginUrl, forceLoad: true);
    }
}
