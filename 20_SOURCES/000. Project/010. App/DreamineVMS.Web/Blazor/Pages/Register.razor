@page "/register"
@namespace DreamineVMS.Web.Blazor.Pages
@inject NavigationManager Nav

<PageTitle>회원가입 — Dreamine VMS</PageTitle>

<div class="page-shell auth-shell">
    <div class="auth-card">
        <h1>회원가입</h1>
        <p class="muted">CodeMaru 공통 계정 생성 화면으로 이동합니다.</p>
        <a class="primary link-button full-btn" href="@SignupUrl">회원가입 계속하기</a>
    </div>
</div>

@code {
    private string SignupUrl => $"https://codemaru.co.kr/_identity/login?mode=signup&returnUrl={Uri.EscapeDataString(Nav.BaseUri)}";

    protected override void OnInitialized()
    {
        Nav.NavigateTo(SignupUrl, forceLoad: true);
    }
}
