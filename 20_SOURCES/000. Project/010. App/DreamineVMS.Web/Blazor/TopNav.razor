@namespace DreamineVMS.Web.Blazor
@using Microsoft.AspNetCore.Components.Routing
@using DreamineVMS.Web.Services.Auth
@implements IDisposable
@inject VmsAuthState AuthState
@inject NavigationManager Nav
@inject IJSRuntime JS

<header class="vms-topnav">
    <a class="vms-topnav__brand" href="https://codemaru.co.kr">
        <img class="vms-topnav__mark" src="/images/Codemaru_Bloom.jpg" alt="" />
        <span>CodeMaru</span>
    </a>
    <nav id="vmsTopnavMenu" class="vms-topnav__links @(isNavOpen ? "open" : null)" aria-label="CodeMaru 서비스">
        <a href="https://codemaru.co.kr">Home</a>
        <a href="https://dreamine.kr/" target="_blank" rel="noopener">Dreamine</a>
        <a href="https://codemaru.co.kr/cardhybrid">CardHybrid</a>
        <a href="https://wedding.codemaru.co.kr">Wedding</a>
        <a href="https://thankyou.codemaru.co.kr/">ThankYou</a>
        <a href="https://families.codemaru.co.kr">Families</a>
        <a href="https://portfolio.codemaru.co.kr/">Portfolio</a>
        <a href="/" class="active" aria-current="page">CCTV</a>
        <a href="https://shop.codemaru.co.kr/">ShopStore</a>
        <a href="https://codemaru.co.kr/contact">Contact</a>
        @if (hasLoadedCurrentUser && AuthState.IsAuthenticated)
        {
            <a class="vms-topnav__auth" href="@AccountUrl">@NavUserLabel</a>
            <a class="vms-topnav__auth" href="/logout">로그아웃</a>
        }
        else
        {
            <a class="vms-topnav__auth" href="@LoginUrl">로그인</a>
        }
    </nav>
    <button class="vms-topnav__burger"
            type="button"
            @onclick="ToggleNav"
            aria-label="메뉴 열기/닫기"
            aria-expanded="@isNavOpen"
            aria-controls="vmsTopnavMenu">
        <span></span><span></span><span></span>
    </button>
</header>

@code {
    private bool hasLoadedCurrentUser;
    private bool isNavOpen;

    private string LoginUrl => $"https://codemaru.co.kr/_identity/login?returnUrl={Uri.EscapeDataString(Nav.Uri)}";
    private string AccountUrl => $"https://codemaru.co.kr/_identity/account?returnUrl={Uri.EscapeDataString(Nav.Uri)}";
    private string NavUserLabel => string.IsNullOrWhiteSpace(AuthState.CurrentUser?.DisplayName) ? "내 계정" : AuthState.CurrentUser.DisplayName;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AuthState.RestoreAsync(JS);
        hasLoadedCurrentUser = true;
        StateHasChanged();
    }

    private void ToggleNav()
    {
        isNavOpen = !isNavOpen;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (!isNavOpen)
        {
            return;
        }

        isNavOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
