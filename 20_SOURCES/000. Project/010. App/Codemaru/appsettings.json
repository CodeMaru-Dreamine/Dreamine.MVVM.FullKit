{
  "CodemaruServer": {
    "Port": 3080,
    "ListenAnyIp": true
  },
  "MailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "User": "",
    "Password": "",
    "From": "",
    "FromName": "",
    "To": "",
