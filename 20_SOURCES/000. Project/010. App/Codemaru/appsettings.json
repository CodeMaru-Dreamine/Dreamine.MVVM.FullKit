    "WacsPath": "D:\\win-acme\\wacs.exe",
    "NginxPath": "C:\\nginx\\nginx.exe",
    "NginxWorkingDirectory": "C:\\nginx",
    "NginxReloadArguments": "-s reload",
    "WarningDays": 30,
    "CriticalDays": 15,
    "MaxCommandOutputChars": 6000
