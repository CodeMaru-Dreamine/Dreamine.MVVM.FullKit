@page "/guide"
@page "/guide/{Service}"
@namespace Codemaru.Blazor.Pages

<PageTitle>이용 설명서 — @CurrentGuide.Title</PageTitle>

<section class="guide-page">
    <nav class="guide-nav">
        <h2>이용 설명서</h2>
        <ul>
            @foreach (var g in Guides)
            {
                <li>
                    <a class="@(g.Key == ActiveKey ? "active" : "")" href="/guide/@g.Key">
                        <span>@g.Value.Icon</span> @g.Value.ShortTitle
                    </a>
                </li>
            }
        </ul>
    </nav>

    <article class="guide-content">
        <header class="guide-header">
            <span class="guide-icon">@CurrentGuide.Icon</span>
            <div>
                <h1>@CurrentGuide.Title</h1>
                <p class="guide-subtitle">@CurrentGuide.Subtitle</p>
            </div>
        </header>

        @CurrentGuide.Body
    </article>
</section>

@code {
    [Parameter] public string? Service { get; set; }

    private string ActiveKey => string.IsNullOrWhiteSpace(Service) ? "cardhybrid" : Service.ToLowerInvariant();

    private GuideEntry CurrentGuide => Guides.TryGetValue(ActiveKey, out var g) ? g : Guides["cardhybrid"];

    private static readonly Dictionary<string, GuideEntry> Guides = new()
    {
        ["cardhybrid"] = new("💼", "CardHybrid", "CardHybrid — 디지털 명함", "QR 코드 + 모바일 랜딩 + vCard + 명함 디자인을 하나의 화면에서",
            @<div class="guide-body">
                <section>
                    <h2>CardHybrid란?</h2>
                    <p>
                        종이 명함 대신 QR 코드 하나로 내 정보를 전달하는 디지털 명함 도구입니다.
                        상대방이 QR을 스캔하면 앱 설치 없이 모바일 랜딩 페이지가 열리고, 버튼 하나로
                        스마트폰 연락처(vCard)에 저장됩니다. 앞·뒤 명함 레이아웃을 직접 편집하고
                        SVG·HTML 파일로 인쇄 출력도 가능합니다.
