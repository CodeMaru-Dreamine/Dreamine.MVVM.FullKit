                        </label>
                    </div>
                }
            </section>

            <section class="history-panel" aria-label="лӘ…н•Ё мқҙл Ҙ">
                <div class="panel-header">
                    <h2>мқҙл Ҙ</h2>
                    <button type="button" class="icon-button" title="мқҙл Ҙ л№„мҡ°кё°" @onclick="ClearHistory">мҙҲкё°нҷ”</button>
