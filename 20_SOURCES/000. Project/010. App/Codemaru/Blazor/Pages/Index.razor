                        </div>

                        <div class="landing-page-render @LandingThemeClass">
                            <section class="landing-card">
                                <div class="landing-logo" style="border-color:@accentColor">
                                    @if (string.IsNullOrWhiteSpace(logoImageDataUrl))
                                    {
