            <section class="preview-panel" aria-label="лӘ…н•Ё л°Ҹ лһңл”© лҜёлҰ¬ліҙкё°">
                <div class="preview-tabs" role="tablist" aria-label="лҜёлҰ¬ліҙкё° нғӯ">
                    <button type="button" class="@TabClass("card")" @onclick='() => activePreviewTab = "card"'>лӘ…н•Ё</button>
