                    </label>
                    <label>
                        нҸ°нҠё
                        <select @bind="frontFontFamily">
                            @foreach (var font in FontOptions)
                            {
                                <option value="@font">@font</option>
                            }
                        </select>
                    </label>
                    <label>
                        нҒ¬кё°
                        <input type="number" min="10" max="40" step="1" @bind="frontCategoryFontSize" @bind:event="oninput" />
