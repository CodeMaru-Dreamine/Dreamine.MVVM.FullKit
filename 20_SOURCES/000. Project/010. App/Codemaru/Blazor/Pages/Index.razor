    private static string DisplayValue(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static double Clamp(double value, double min, double max)
    {
        return Math.Min(Math.Max(value, min), max);
    }

    private static string CssString(string value)
    {
        var safe = string.IsNullOrWhiteSpace(value) ? "Segoe UI" : value.Replace("'", string.Empty, StringComparison.Ordinal);
        return $"'{safe}'";
    }

    private static bool TryReadDataUrl(string dataUrl, out byte[] bytes, out string contentType)
    {
        bytes = [];
        contentType = "application/octet-stream";

        const string marker = ";base64,";
        var markerIndex = dataUrl.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        if (!dataUrl.StartsWith("data:", StringComparison.OrdinalIgnoreCase) || markerIndex < 0)
        {
            return false;
        }

        contentType = dataUrl[5..markerIndex];
        bytes = Convert.FromBase64String(dataUrl[(markerIndex + marker.Length)..]);
        return true;
    }

    private static bool IsSupportedImageImport(IBrowserFile file)
    {
        var extension = Path.GetExtension(file.Name);
        return file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase) ||
            extension.Equals(".svg", StringComparison.OrdinalIgnoreCase) ||
            extension.Equals(".png", StringComparison.OrdinalIgnoreCase) ||
            extension.Equals(".jpg", StringComparison.OrdinalIgnoreCase) ||
            extension.Equals(".jpeg", StringComparison.OrdinalIgnoreCase) ||
            extension.Equals(".webp", StringComparison.OrdinalIgnoreCase) ||
            extension.Equals(".ico", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetImageContentType(IBrowserFile file)
    {
        if (!string.IsNullOrWhiteSpace(file.ContentType) &&
            file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            return file.ContentType;
        }

        return Path.GetExtension(file.Name).ToLowerInvariant() switch
        {
            ".svg" => "image/svg+xml",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".webp" => "image/webp",
            ".ico" => "image/x-icon",
            _ => "image/png"
        };
    }

    private static (string Name, string Side) ParseCardImageFileName(string fileName)
    {
        var name = Path.GetFileNameWithoutExtension(fileName).Trim();
        if (name.EndsWith("_front", StringComparison.OrdinalIgnoreCase))
        {
            return (name[..^"_front".Length].Trim(), "front");
        }

        if (name.EndsWith("_back", StringComparison.OrdinalIgnoreCase))
        {
            return (name[..^"_back".Length].Trim(), "back");
        }

        if (name.EndsWith("_м•һл©ҙ", StringComparison.OrdinalIgnoreCase) ||
            name.EndsWith("_м•һ", StringComparison.OrdinalIgnoreCase))
        {
            var marker = name.EndsWith("_м•һл©ҙ", StringComparison.OrdinalIgnoreCase) ? "_м•һл©ҙ" : "_м•һ";
            return (name[..^marker.Length].Trim(), "front");
        }

        if (name.EndsWith("_л’·л©ҙ", StringComparison.OrdinalIgnoreCase) ||
            name.EndsWith("_л’Ө", StringComparison.OrdinalIgnoreCase))
        {
            var marker = name.EndsWith("_л’·л©ҙ", StringComparison.OrdinalIgnoreCase) ? "_л’·л©ҙ" : "_л’Ө";
            return (name[..^marker.Length].Trim(), "back");
        }

        return (name, string.Empty);
    }

    private static async Task<string> ReadImageDataUrlAsync(IBrowserFile file)
    {
        await using var stream = file.OpenReadStream(maxAllowedSize: 8 * 1024 * 1024);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);

        return $"data:{GetImageContentType(file)};base64,{Convert.ToBase64String(memory.ToArray())}";
    }

    private static string DecodeText(byte[] bytes)
    {
        if (bytes.Length >= 3 && bytes[0] == 0xEF && bytes[1] == 0xBB && bytes[2] == 0xBF)
        {
            return Encoding.UTF8.GetString(bytes, 3, bytes.Length - 3);
        }

        if (bytes.Length >= 2 && bytes[0] == 0xFF && bytes[1] == 0xFE)
        {
            return Encoding.Unicode.GetString(bytes, 2, bytes.Length - 2);
        }

        if (bytes.Length >= 2 && bytes[0] == 0xFE && bytes[1] == 0xFF)
        {
            return Encoding.BigEndianUnicode.GetString(bytes, 2, bytes.Length - 2);
        }

        return Encoding.UTF8.GetString(bytes);
    }

