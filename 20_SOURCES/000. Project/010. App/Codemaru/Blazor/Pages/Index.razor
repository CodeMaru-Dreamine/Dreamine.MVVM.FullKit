                        }

                        <div class="theme-row" role="radiogroup" aria-label="лһңл”© нҺҳмқҙм§Җ н…Ңл§Ҳ">
                            <button type="button" class="@ThemeClass("light")" @onclick='() => SetTheme("light")'>л°қмқҖ</button>
                            <button type="button" class="@ThemeClass("dark")" @onclick='() => SetTheme("dark")'>м–ҙл‘җмҡҙ</button>
                            <button type="button" class="@ThemeClass("blue")" @onclick='() => SetTheme("blue")'>лё”лЈЁ</button>
                            <button type="button" class="@ThemeClass("green")" @onclick='() => SetTheme("green")'>к·ёлҰ°</button>
                        </div>

                        <div class="vcard-options" aria-label="vCard кіөк°ң н•ӯлӘ©">
                            <label class="check-row compact">
                                <input type="checkbox" @bind="includePhoneInVCard" />
                                vCardм—җ м „нҷ” нҸ¬н•Ё
                            </label>
                            <label class="check-row compact">
                                <input type="checkbox" @bind="includeAddressInVCard" />
                                vCardм—җ мЈјмҶҢ нҸ¬н•Ё
