            BackNameFontSize: Clamp(backNameFontSize, 10, 36),
            BackRoleFontSize: Clamp(backRoleFontSize, 9, 30),
            LandingTheme: landingTheme,
            IncludePhoneInVCard: includePhoneInVCard,
            IncludeAddressInVCard: includeAddressInVCard,
