                    <InputFile OnChange="OnImportSelectedAsync" multiple accept=".vcf,text/vcard,text/x-vcard,image/png,image/jpeg,image/webp,image/svg+xml,image/x-icon,image/vnd.microsoft.icon,.ico" />
                </label>

                @if (State.History.Count == 0)
                {
                    <p class="empty-text">м ҖмһҘлҗң лӘ…н•Ё мқҙл Ҙмқҙ м—ҶмҠөлӢҲлӢӨ.</p>
                }
                else
                {
                    <div class="history-list">
                        @foreach (var entry in State.History)
                        {
