    private async Task OnImportSelectedAsync(InputFileChangeEventArgs args)
    {
        var files = args.GetMultipleFiles(10);
        if (files.Count == 0)
        {
            lastSavedText = "м„ нғқлҗң нҢҢмқј м—ҶмқҢ";
            return;
        }

        var file = files[0];
        var extension = Path.GetExtension(file.Name);

        if (extension.Equals(".vcf", StringComparison.OrdinalIgnoreCase) ||
            file.ContentType.Contains("vcard", StringComparison.OrdinalIgnoreCase))
        {
            await ImportVCardAsync(file);
            return;
        }

        if (IsSupportedImageImport(file))
        {
            await ImportImagesAsync(files);
            return;
        }

        lastSavedText = "м§Җмӣҗн•ҳм§Җ м•ҠлҠ” нҢҢмқј";
    }

    private async Task ImportVCardAsync(IBrowserFile file)
    {
        await using var stream = file.OpenReadStream(maxAllowedSize: 4 * 1024 * 1024);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);

        var content = DecodeText(memory.ToArray());
        var profile = Importer.ImportVCard(content, CreateProfile());
        SaveImportedProfile(profile, $"{Path.GetFileName(file.Name)} к°Җм ёмҳҙ");
    }

    private async Task ImportImagesAsync(IReadOnlyList<IBrowserFile> files)
    {
        var imageFiles = files.Where(IsSupportedImageImport).Take(2).ToArray();
        var images = new List<(IBrowserFile File, string Name, string Side, string DataUrl)>();

        foreach (var imageFile in imageFiles)
        {
            var (name, side) = ParseCardImageFileName(imageFile.Name);
            images.Add((imageFile, name, side, await ReadImageDataUrlAsync(imageFile)));
        }

        if (images.Count == 0)
        {
            lastSavedText = "мқҙлҜём§Җ м—ҶмқҢ";
            return;
        }

        var displayName = images.Select(static image => image.Name)
            .FirstOrDefault(static value => !string.IsNullOrWhiteSpace(value)) ?? "Imported Card";
        var frontImage = images.FirstOrDefault(static image => image.Side == "front").DataUrl;
        var backImage = images.FirstOrDefault(static image => image.Side == "back").DataUrl;

        frontImage = string.IsNullOrWhiteSpace(frontImage) ? images[0].DataUrl : frontImage;
        if (string.IsNullOrWhiteSpace(backImage) && images.Count > 1)
        {
            backImage = images.First(image => image.DataUrl != frontImage).DataUrl;
        }

        var profile = CreateProfile() with
        {
            Brand = displayName,
            BackBrand = displayName,
            Name = displayName,
            Role = "мқҙлҜём§Җ лӘ…н•Ё",
            BackTagline = "к°Җм ёмҳЁ лӘ…н•Ё мқҙлҜём§Җ",
            LogoImageDataUrl = null,
            RemoveLogoBackground = false,
            ImportedFrontImageDataUrl = frontImage,
            ImportedBackImageDataUrl = backImage
        };

        logoOriginalBytes = null;
        logoOriginalContentType = null;
        SaveImportedProfile(profile, string.IsNullOrWhiteSpace(backImage) ? $"{displayName} м•һл©ҙ м ҖмһҘ" : $"{displayName} м•һ/л’Ө м ҖмһҘ");
    }

