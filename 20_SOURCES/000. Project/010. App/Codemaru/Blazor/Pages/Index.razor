    private async Task OnLogoSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        await using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);

        logoOriginalBytes = memory.ToArray();
        logoOriginalContentType = string.IsNullOrWhiteSpace(file.ContentType)
            ? "application/octet-stream"
            : file.ContentType;
        logoImageDataUrl = BackgroundRemover.CreateDataUrl(logoOriginalBytes, logoOriginalContentType, removeLogoBackground);
        ApplyProfile();
    }

    private Task OnRemoveBackgroundChangedAsync(ChangeEventArgs args)
    {
        removeLogoBackground = args.Value is bool value && value;

        if (logoOriginalBytes is not null && logoOriginalContentType is not null)
        {
            logoImageDataUrl = BackgroundRemover.CreateDataUrl(logoOriginalBytes, logoOriginalContentType, removeLogoBackground);
        }
        else if (!string.IsNullOrWhiteSpace(logoImageDataUrl) && TryReadDataUrl(logoImageDataUrl, out var bytes, out var contentType))
        {
            logoOriginalBytes = bytes;
            logoOriginalContentType = contentType;
            logoImageDataUrl = BackgroundRemover.CreateDataUrl(bytes, contentType, removeLogoBackground);
        }

        ApplyProfile();
        return Task.CompletedTask;
    }

    private void RemoveLogo()
    {
        logoImageDataUrl = null;
        logoOriginalBytes = null;
        logoOriginalContentType = null;
        removeLogoBackground = false;
        ApplyProfile();
    }

