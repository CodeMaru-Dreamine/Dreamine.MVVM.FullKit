                                <div class="history-actions" aria-label="мқҙл Ҙ н•ӯлӘ© мһ‘м—…">
                                    <button type="button" class="history-action-button" @onclick="() => LoadHistory(entry)">нҺём§‘</button>
                                    <button type="button" class="history-action-button danger" @onclick="() => DeleteHistory(entry)">мӮӯм ң</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>
        </div>
    </section>
</main>

@code {
    private CardHybridState State => Session.State;
    private static readonly string[] FontOptions =
    [
        "Segoe UI",
        "Malgun Gothic",
        "л§‘мқҖ кі л”•",
        "Arial",
        "Calibri",
        "Noto Sans KR",
        "Pretendard",
        "Gulim",
        "Batang"
    ];

    private string brand = string.Empty;
    private string tagline = string.Empty;
    private string backBrand = string.Empty;
    private string backTagline = string.Empty;
    private string category = string.Empty;
    private string name = string.Empty;
    private string role = string.Empty;
    private string email = string.Empty;
    private string phone = string.Empty;
    private string address = string.Empty;
    private string website = string.Empty;
    private string slug = string.Empty;
    private string accentColor = "#5d7f57";
    private string shortBio = string.Empty;
    private string landingDescription = string.Empty;
    private string vCardNote = string.Empty;
    private string internalMemo = string.Empty;
    private string? logoImageDataUrl;
    private string? importedFrontImageDataUrl;
    private string? importedBackImageDataUrl;
    private byte[]? logoOriginalBytes;
    private string? logoOriginalContentType;
    private bool removeLogoBackground;
    private double cardWidthMm = 90;
    private double cardHeightMm = 50;
    private string frontFontFamily = "Segoe UI";
    private string backFontFamily = "Segoe UI";
    private double frontBrandFontSize = 28;
    private double frontTaglineFontSize = 18;
    private double frontCategoryFontSize = 18;
    private double frontEmailFontSize = 14;
    private double backBrandFontSize = 22;
    private double backTaglineFontSize = 14;
    private double backNameFontSize = 16;
    private double backRoleFontSize = 14;
    private string landingTheme = "light";
    private bool includePhoneInVCard;
    private bool includeAddressInVCard;
    private string activePreviewTab = "card";
    private string lastSavedText = "м•„м§Ғ м ҖмһҘ м „";
    private string loginEmail = string.Empty;
    private string loginPassword = string.Empty;
    private string signinMessage = string.Empty;
    private bool signinMessageIsError;
    private string landingPublishMessage = string.Empty;
    private bool landingPublishMessageIsError;
    private Guid? editingHistoryId;

    private string CardStyle
    {
        get
        {
