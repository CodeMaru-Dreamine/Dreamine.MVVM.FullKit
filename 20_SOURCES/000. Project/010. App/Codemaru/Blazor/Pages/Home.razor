@code {
    private static string PreviewSrc(string key, string fallback)
    {
        var path = Path.Combine(AppContext.BaseDirectory, "wwwroot", "img", "previews", $"{key}.jpg");
        return File.Exists(path)
            ? $"img/previews/{key}.jpg?v={File.GetLastWriteTime(path).Ticks}"
            : fallback;
    }
}
