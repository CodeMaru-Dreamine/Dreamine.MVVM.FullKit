@namespace Codemaru.Blazor.Layout
@implements IDisposable
@inject NavigationManager Navigation

<header class="cm-topbar">
    <a class="cm-brand" href="/">
        <img class="cm-brand-logo" src="/img/Codemaru_Bloom_Light.jpg" alt="Codemaru" />
        <span class="cm-brand-text">CodeMaru</span>
    </a>

    <div class="cm-right">
        <nav id="cmMenu" class="cm-nav cm-nav-menu @(isOpen ? "open" : null)">
            <NavLink href="/" Match="NavLinkMatch.All" ActiveClass="active">Home</NavLink>
            <a href="https://dreamine.kr/" target="_blank" rel="noopener">Dreamine</a>
            <NavLink href="/cardhybrid" ActiveClass="active">CardHybrid</NavLink>
            <a href="https://wedding.codemaru.co.kr">Wedding</a>
            <a href="https://thankyou.codemaru.co.kr/">ThankYou</a>
            <a href="https://families.codemaru.co.kr">Families</a>
            <a href="https://portfolio.codemaru.co.kr/">Portfolio</a>
            <a href="https://cctvviewer.codemaru.co.kr">CCTV</a>
            <a href="https://shop.codemaru.co.kr/">ShopStore</a>
            <NavLink href="/contact" Match="NavLinkMatch.All" ActiveClass="active">Contact</NavLink>

            <AuthorizeView>
                <Authorized>
                    <a class="cm-user-badge" href="/account?returnUrl=@ReturnUrl" title="내 계정">
                        <i class="fa-solid fa-user"></i>
                        @DisplayNameOf(context)
                    </a>
                    <a class="cm-auth-link" href="/signout?returnUrl=@ReturnUrl">로그아웃</a>
                </Authorized>
                <NotAuthorized>
                    <a class="cm-auth-link" href="/login?returnUrl=@ReturnUrl">로그인</a>
                </NotAuthorized>
            </AuthorizeView>
        </nav>

        <button class="cm-nav-burger"
                type="button"
                @onclick="ToggleMenu"
                aria-label="메뉴 열기/닫기"
                aria-expanded="@isOpen"
                aria-controls="cmMenu">
            <span></span><span></span><span></span>
        </button>
    </div>
</header>

@code {
    private bool isOpen;

    private string ReturnUrl => Uri.EscapeDataString(new Uri(Navigation.Uri).PathAndQuery);

    private static string DisplayNameOf(AuthenticationState context)
    {
        var name = context.User.Identity?.Name;
        return string.IsNullOrWhiteSpace(name) ? "로그인됨" : name;
    }

    private void ToggleMenu()
    {
        isOpen = !isOpen;
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (!isOpen)
        {
            return;
        }

        isOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
