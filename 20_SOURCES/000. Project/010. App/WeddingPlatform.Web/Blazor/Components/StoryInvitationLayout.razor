@namespace WeddingPlatform.Blazor.Components
@using Microsoft.AspNetCore.Components.Rendering
@using Wedding.Common
@using WeddingPlatform.Models
@using WeddingPlatform.ViewModels
@implements IAsyncDisposable

@*
    Story 레이아웃 — 챕터/타임라인 흐름형 (앨범형인 Gallery와 시각적으로 확실히 구분).
    2열 썸네일 그리드 금지. 큰 이미지 + 넓은 텍스트 블록 + 세로 흐름.
*@
<section class="wedding-layout-story @Vm.LayoutDescriptor.CssClass">
    @foreach (var activeSection in Vm.OrderedSections.Where(x => x != "hero"))
    {
        if (activeSection == "story")
        {
            @for (var i = 0; i < Vm.StoryChapters.Count; i++)
            {
                var chapterIndex = i;
                var chapter = Vm.StoryChapters[chapterIndex];
                var photo = Vm.ResolveStoryChapterPhoto(chapter, chapterIndex);
                var isReverse = chapterIndex % 2 == 1;
                var isClosing = chapterIndex == Vm.StoryChapters.Count - 1;
                <section class="wedding-story-chapter @(isReverse ? "wedding-story-chapter--reverse" : "") @(isClosing ? "wedding-story-chapter--closing" : "")">
                    <div class="wedding-story-chapter-label">
                        <span class="wedding-story-chapter-label__no">@chapter.Label</span>
                        <span class="wedding-story-chapter-label__title">@chapter.Title</span>
                    </div>
                    @if (photo is not null)
                    {
                        <figure class="wedding-story-hero-photo @(isReverse ? "wedding-story-hero-photo--portrait" : "")">
                            <button type="button" class="wedding-photo-thumb" @onclick="() => OpenPhoto(photo)" aria-label="@chapter.Title 사진 크게 보기">
                                <img src="@photo.ThumbUrl" alt="@chapter.Title" loading="@(chapterIndex == 0 ? "eager" : "lazy")" />
                            </button>
                        </figure>
                    }
                    <div class="wedding-story-text-block @(isClosing ? "wedding-story-text-block--wide" : "")">
                        @RenderChapterBody(chapter, chapterIndex)
                    </div>
                </section>
            }
        }
        else if (activeSection == "gallery" && StripTotal > 0)
        {
            <section class="wedding-story-moment-strip" id="gallery">
                <div class="wedding-layout-heading">
                    <p class="wedding-layout-kicker">Moments</p>
                    <h2>함께한 순간</h2>
                    <span>표시 @(StripVisible)장 / 전체 @(StripTotal)장</span>
                </div>
                <div class="w-gallery__controls">
                    <button class="w-btn" type="button" @onclick="ToggleAutoPlay">
                        @(_autoPlaying ? "⏸ 정지" : "▶ 자동재생")
                    </button>
                </div>
                <div class="wedding-story-moment-strip__grid">
                    @for (int i = 0; i < StripVisible; i++)
                    {
                        var photoIndex = i;
                        <figure>
                            <button type="button" class="wedding-photo-thumb" @onclick="() => OpenPhoto(photoIndex)" aria-label="사진 @(photoIndex + 1) 크게 보기">
                                <img src="@Vm.AllPhotos[photoIndex].ThumbUrl" alt="사진 @(photoIndex + 1)" loading="lazy" />
                            </button>
                        </figure>
                    }
                </div>
                @if (StripVisible < StripTotal)
                {
                    <div class="wedding-layout-more">
                        <button type="button" class="w-btn w-btn--primary" @onclick="LoadMoreStrip">
                            사진 더 보기 (+@Math.Min(PageSize, StripTotal - StripVisible))
                        </button>
                    </div>
                }
            </section>
        }
        else
        {
            <InvitationSections Slug="@Slug" Vm="@Vm" VmGuest="@VmGuest" IsTabbed="true" ActiveSection="@activeSection" PauseMusicRequested="@PauseMusicRequested" />
        }
    }
    <PhotoLightbox Photos="@Vm.AllPhotos"
                   IsOpen="@_photoLightboxOpen"
                   CurrentIndex="@_photoLightboxIndex"
                   CurrentIndexChanged="OnPhotoIndexChanged"
                   Closed="ClosePhoto" />
</section>

@code {
    [Parameter, EditorRequired] public string Slug { get; set; } = "";
    [Parameter, EditorRequired] public WeddingInvitationViewModel Vm { get; set; } = default!;
    [Parameter, EditorRequired] public WeddingGuestbookViewModel VmGuest { get; set; } = default!;
    [Parameter] public EventCallback PauseMusicRequested { get; set; }

    private RenderFragment RenderChapterBody(StoryChapter chapter, int chapterIndex) => builder =>
    {
        if (!string.IsNullOrWhiteSpace(chapter.Body))
        {
            builder.OpenElement(0, "p");
            builder.AddContent(1, chapter.Body);
            builder.CloseElement();
            return;
        }

        switch (chapterIndex)
        {
            case 0:
                builder.OpenElement(2, "p");
                builder.AddAttribute(3, "class", "wedding-story-kicker");
                builder.AddContent(4, Vm.HeroTitle);
                builder.CloseElement();
                builder.OpenElement(5, "h1");
                builder.AddContent(6, Vm.CoupleName);
                builder.CloseElement();
                builder.OpenElement(7, "p");
                builder.AddAttribute(8, "class", "wedding-story-lede");
                builder.AddContent(9, $"{Vm.WeddingDate:yyyy년 MM월 dd일 (ddd)} · {Vm.WeddingTime}");
                builder.CloseElement();
                builder.OpenElement(10, "p");
                builder.AddContent(11, string.IsNullOrWhiteSpace(Vm.Story) ? "두 사람의 이야기가 여기서부터 시작됩니다." : Vm.Story);
                builder.CloseElement();
                break;
            case 1:
                builder.OpenElement(12, "p");
                builder.AddContent(13, string.IsNullOrWhiteSpace(Vm.Story2) ? "쌓아온 시간을 담아 전해드립니다." : Vm.Story2);
                builder.CloseElement();
                break;
            case 2:
                builder.OpenElement(14, "p");
                builder.AddContent(15, "가장 소중한 날의 분위기와 마음을 사진과 이야기로 천천히 전해드립니다.");
                builder.CloseElement();
                builder.OpenElement(16, "p");
                builder.AddContent(17, "자세한 일시와 장소 안내는 예식 안내 섹션에서 확인하실 수 있습니다.");
                builder.CloseElement();
                break;
            default:
                builder.OpenElement(40, "p");
                builder.AddContent(41, "귀한 시간을 내어 함께해 주시는 모든 분들께 전하고 싶은 마음을 이곳에 담아 주세요.");
                builder.CloseElement();
                break;
        }
    };

    private const int InitialCount = 6;
    private const int PageSize = 12;
    private int _stripVisible = InitialCount;
    private bool _photoLightboxOpen;
    private int _photoLightboxIndex;
    private bool _autoPlaying;
    private CancellationTokenSource? _autoPlayCts;

    private int StripTotal => Vm.AllPhotos.Count;
    private int StripVisible => Math.Min(_stripVisible, StripTotal);

    private void LoadMoreStrip()
        => _stripVisible = Math.Min(_stripVisible + PageSize, StripTotal);

    private void OpenPhoto(PhotoInfo photo)
    {
        var index = Vm.AllPhotos.ToList().FindIndex(p => string.Equals(p.FileName, photo.FileName, StringComparison.OrdinalIgnoreCase));
        OpenPhoto(index < 0 ? 0 : index);
    }

    private void OpenPhoto(int index)
    {
        _photoLightboxIndex = Math.Clamp(index, 0, Math.Max(0, Vm.AllPhotos.Count - 1));
        _photoLightboxOpen = Vm.AllPhotos.Count > 0;
    }

    private async Task ClosePhoto()
    {
        await StopAutoPlay();
        _photoLightboxOpen = false;
    }

    private void OnPhotoIndexChanged(int index) => _photoLightboxIndex = index;

    private async Task ToggleAutoPlay()
    {
        if (_autoPlaying)
        {
            await StopAutoPlay();
        }
        else
        {
            await StartAutoPlay();
        }
    }

    private Task StartAutoPlay()
    {
        if (Vm.AllPhotos.Count == 0 || _autoPlaying) return Task.CompletedTask;

        if (!_photoLightboxOpen)
        {
            _photoLightboxIndex = 0;
            _photoLightboxOpen = true;
        }

        _autoPlaying = true;
        _autoPlayCts = new CancellationTokenSource();
        var token = _autoPlayCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(Vm.GalleryAutoPlayMs, token).ConfigureAwait(false);
                    await InvokeAsync(() =>
                    {
                        if (_photoLightboxOpen && Vm.AllPhotos.Count > 0)
                        {
                            _photoLightboxIndex = (_photoLightboxIndex + 1) % Vm.AllPhotos.Count;
                            StateHasChanged();
                        }
                    });
                }
            }
            catch (TaskCanceledException) { }
        }, token);

        return Task.CompletedTask;
    }

    private Task StopAutoPlay()
    {
        _autoPlaying = false;
        _autoPlayCts?.Cancel();
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        await StopAutoPlay();
        _autoPlayCts?.Dispose();
    }
}
