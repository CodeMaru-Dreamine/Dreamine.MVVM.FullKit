@namespace WeddingPlatform.Blazor.Components
@using Microsoft.JSInterop
@using WeddingPlatform.Models
@using WeddingPlatform.ViewModels
@inject IJSRuntime JS
@implements IAsyncDisposable

@foreach (var section in SectionsToRender)
{
    @switch (section)
    {
        case "story":
            if (HasStory)
            {
                <section class="w-story w-invite-tab-page" id="story">
                    <h2 class="w-section-title">우리 이야기</h2>
                    @if (!string.IsNullOrWhiteSpace(Vm.Story))
                    {
                        <p>@Vm.Story</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Vm.Story2))
                    {
                        <hr class="w-divider" />
                        <p>@Vm.Story2</p>
                    }
                </section>
            }
            break;
        case "info":
            if (HasInfo)
            {
                <section class="w-details w-invite-tab-page" id="invite-tab-info">
                    @if (Vm.Mode == WeddingSiteMode.ThankYou)
                    {
                        <h2 class="w-section-title">감사 인사</h2>
                    }
                    else
                    {
                        <h2 class="w-section-title">예식 안내</h2>
                        <ul class="w-info-list">
                            <li><strong>일시</strong>@Vm.WeddingDate.ToString("yyyy년 MM월 dd일 (ddd)") @Vm.WeddingTime</li>
                            <li><strong>장소</strong>@Vm.VenueName</li>
                            <li><strong>주소</strong>@Vm.VenueAddress</li>
                        </ul>
                    }

                    @if (!string.IsNullOrWhiteSpace(Vm.CeremonyNoteHtml))
                    {
                        <div class="@CeremonyNoteClass">
                            @((MarkupString)Vm.CeremonyNoteHtml)
                        </div>
                    }
                </section>
            }
            break;
        case "details":
            if (Vm.Mode != WeddingSiteMode.ThankYou)
            {
                <section class="w-details w-invite-tab-page" id="invite-tab-content">
                    <h2 class="w-section-title" id="details">오시는 길</h2>

                    <div class="w-tabs" role="tablist">
                        <button class="w-tab @Vm.TabClass("map")" role="tab" @onclick="Vm.SetMap">지도</button>
                        <button class="w-tab @Vm.TabClass("road")" role="tab" @onclick="Vm.SetRoad">약도</button>
                    </div>
                    @if (Vm.SelectedTab == "map")
                    {
                        <div class="w-map-links">
                            @if (!string.IsNullOrWhiteSpace(Vm.MapLinkKakao))
                            {
                                <a href="@Vm.MapLinkKakao" target="_blank" class="w-map-btn w-map-btn--kakao">카카오맵</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(Vm.MapLinkNaver))
                            {
                                <a href="@Vm.MapLinkNaver" target="_blank" class="w-map-btn w-map-btn--naver">네이버지도</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(Vm.MapLinkAtlan))
                            {
                                <a href="@Vm.MapLinkAtlan" target="_blank" class="w-map-btn w-map-btn--atlan">아틀란</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(Vm.MapLinkTmap))
                            {
                                <a href="@Vm.MapLinkTmap" target="_blank" class="w-map-btn w-map-btn--tmap">T맵</a>
                            }
                        </div>
                        @if (Vm.HasVenueCoords)
                        {
                            <div id="w-leaflet-map" class="w-osm__frame" data-lat="@Vm.VenueLat.ToString("F6")" data-lng="@Vm.VenueLng.ToString("F6")" data-name="@Vm.VenueName"></div>
                        }
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(Vm.RoadMapUrl))
                        {
                            <div class="w-roadmap">
                                <img src="@Vm.RoadMapUrl" alt="약도" />
                            </div>
                        }
                        else
                        {
                            <div class="w-road-placeholder">
                                <p>약도 이미지를 어드민에서 업로드 해주세요.</p>
                            </div>
                        }
                    }
                </section>
            }
            break;
        case "video":
            if (Vm.VideoUrls.Count > 0)
            {
                <section class="w-video w-invite-tab-page" id="video">
                    <h2 class="w-section-title">우리의 영상</h2>
                    <div class="w-video__grid">
                        @for (int i = 0; i < Vm.VideoUrls.Count; i++)
                        {
                            var idx = i;
                            <button class="w-video__item" @onclick="() => OpenVideoLightbox(idx)">
                                <video src="@Vm.VideoUrls[idx]" preload="metadata" muted playsinline></video>
                                <span class="w-video__play">▶</span>
                            </button>
                        }
                    </div>
                </section>
            }
            break;
        case "gallery":
            if (Vm.Gallery.Count > 0)
            {
                <section class="w-gallery w-invite-tab-page" id="gallery" aria-labelledby="galleryTitle">
                    <h2 class="w-section-title" id="galleryTitle">우리의 사진</h2>

                    <div class="w-gallery__controls">
                        <button class="w-btn" @onclick="ToggleAutoPlay">
                            @(isAutoPlaying ? "⏸ 정지" : "▶ 자동재생")
                        </button>
                        <span class="w-gallery__count">최근 @(Vm.Gallery.Count)장 / 전체 @(Vm.AllPhotos.Count)장</span>
                    </div>

                    <div class="w-gallery__grid">
                        @for (int i = 0; i < Vm.Gallery.Count; i++)
                        {
                            var idx = i;
                            <button class="w-gallery__item" @onclick="() => OpenLightbox(idx)">
                                <img src="@Vm.Gallery[idx].ThumbUrl" alt="사진 @(idx + 1)" loading="lazy" />
                            </button>
                        }
                    </div>
                </section>
            }
            break;
        case "gift":
            if (Vm.Accounts.Count > 0)
            {
                <section class="w-gift w-invite-tab-page" id="gift" aria-labelledby="giftTitle">
                    <h2 class="w-section-title" id="giftTitle">마음 전하실 곳</h2>
                    <div class="w-gift__cards">
                        @foreach (var acc in Vm.Accounts)
                        {
                            <div class="w-gift__card">
                                <h3 class="w-gift__who">@acc.Label @acc.Name</h3>
                                @if (!string.IsNullOrWhiteSpace(acc.Account))
                                {
                                    <div class="w-gift__account">
                                        <span class="w-gift__bank">@acc.BankName</span>
                                        <span class="w-gift__num">@acc.Account</span>
                                        @if (!string.IsNullOrWhiteSpace(acc.AccountHolder))
                                        {
                                            <span class="w-gift__holder">(@acc.AccountHolder)</span>
                                        }
                                    </div>
                                    <button class="w-btn w-btn--copy" @onclick='() => CopyToClipboard(acc.Account)'>
                                        📋 계좌번호 복사
                                    </button>
                                }
                                @if (!string.IsNullOrWhiteSpace(acc.KakaoPayUrl))
                                {
                                    <a href="@acc.KakaoPayUrl" target="_blank" class="w-btn w-btn--kakaopay">💛 카카오페이</a>
                                }
                                @if (!string.IsNullOrWhiteSpace(acc.Phone))
                                {
                                    <div class="w-gift__contact">
                                        <a href="tel:@acc.Phone" class="w-btn w-btn--tel">📞 전화</a>
                                        <a href="sms:@acc.Phone" class="w-btn w-btn--sms">💬 문자</a>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(copyFeedback))
                    {
                        <p class="w-copy-feedback">@copyFeedback</p>
                    }
                </section>
            }
            break;
        case "guestbook":
            <section class="w-guestbook w-invite-tab-page" id="guestbook" aria-labelledby="gbTitle">
                <h2 class="w-section-title" id="gbTitle">📖 방명록</h2>

                <div class="w-gb__form">
                    <input class="w-input" type="text" placeholder="이름" @bind="VmGuest.Name" />
                    <input class="w-input" type="text" placeholder="연락처 (선택)" @bind="VmGuest.Contact" />
                    <textarea class="w-input w-textarea" rows="4" placeholder="축하 메시지를 남겨주세요"
                              @bind="VmGuest.Message"></textarea>
                    <div class="w-gb__actions">
                        <button class="w-btn w-btn--primary" @onclick="OnGuestbookAdd" disabled="@VmGuest.IsSaving">등록</button>
                        <button class="w-btn" @onclick="OnGuestbookReload">새로고침</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(VmGuest.LastStatus))
                    {
                        <p class="w-status">@VmGuest.LastStatus</p>
                    }
                </div>

                <ul class="w-gb__list">
                    @foreach (var e in VmGuest.EntriesView)
                    {
                        <li class="w-gb__entry">
                            <div class="w-gb__meta">
                                <strong>@e.Name</strong>
                                <span class="w-gb__date">@e.CreatedLocal.ToString("yyyy-MM-dd HH:mm")</span>
                            </div>
                            <div class="w-gb__msg">@e.Message</div>
                        </li>
                    }
                </ul>
            </section>
            break;
    }
}

@if (videoLightboxOpen)
{
    <div class="w-lightbox" role="dialog" tabindex="-1" @ref="vlbRef" @onkeydown="OnVideoKeyDown">
        <button class="w-lb__close" @onclick="CloseVideoLightbox">✕</button>
        @if (Vm.VideoUrls.Count > 1)
        {
            <button class="w-lb__prev" @onclick="VideoPrev">‹</button>
        }
        <video class="w-lb__video" src="@Vm.VideoUrls[videoLightboxIdx]" controls autoplay playsinline @onplay="PauseMusicForVideo"></video>
        @if (Vm.VideoUrls.Count > 1)
        {
            <button class="w-lb__next" @onclick="VideoNext">›</button>
            <span class="w-lb__counter">@(videoLightboxIdx + 1) / @Vm.VideoUrls.Count</span>
        }
    </div>
    <div class="w-lb__backdrop" @onclick="CloseVideoLightbox"></div>
}

@if (Vm.LightboxOpen)
{
    <div class="w-lightbox"
         role="dialog" aria-modal="true"
         tabindex="-1"
         @ref="lbRef"
         @onkeydown="OnKeyDown"
         @onpointerdown="OnPointerDown"
         @onpointerup="OnPointerUp">
        <button class="w-lb__close" @onclick="CloseLightbox" aria-label="닫기">✕</button>
        <button class="w-lb__prev" @onclick="Vm.LightboxPrev" aria-label="이전">‹</button>
        <img class="w-lb__img" src="@Vm.AllPhotos[Vm.LightboxIdx].Url" alt="사진 @(Vm.LightboxIdx + 1)" />
        <button class="w-lb__next" @onclick="Vm.LightboxNext" aria-label="다음">›</button>
        <span class="w-lb__counter">@(Vm.LightboxIdx + 1) / @Vm.AllPhotos.Count</span>
    </div>
    <div class="w-lb__backdrop" @onclick="CloseLightbox"></div>
}

@code {
    [Parameter, EditorRequired] public string Slug { get; set; } = "";
    [Parameter, EditorRequired] public WeddingInvitationViewModel Vm { get; set; } = default!;
    [Parameter, EditorRequired] public WeddingGuestbookViewModel VmGuest { get; set; } = default!;
    [Parameter] public bool IsTabbed { get; set; }
    [Parameter] public string ActiveSection { get; set; } = "";
    [Parameter] public EventCallback PauseMusicRequested { get; set; }

    private ElementReference lbRef;
    private ElementReference vlbRef;
    private string copyFeedback = "";
    private CancellationTokenSource? feedbackCts;
    private double? startX;
    private bool videoLightboxOpen;
    private int videoLightboxIdx;
    private bool shouldFocusLightbox;
    private bool shouldFocusVideoLightbox;
    private bool isAutoPlaying;
    private CancellationTokenSource? autoCts;

    private bool HasStory => !string.IsNullOrWhiteSpace(Vm.Story) || !string.IsNullOrWhiteSpace(Vm.Story2);
    private bool HasInfo => Vm.Mode != WeddingSiteMode.ThankYou || !string.IsNullOrWhiteSpace(Vm.CeremonyNoteHtml);
    private string CeremonyNoteClass => Vm.IsCeremonyNoteHtml
        ? "w-ceremony-note w-ceremony-note--html"
        : "w-ceremony-note w-ceremony-note--markdown";
    private bool HasDetails =>
        Vm.Mode != WeddingSiteMode.ThankYou
        && (!string.IsNullOrWhiteSpace(Vm.VenueName)
            || !string.IsNullOrWhiteSpace(Vm.VenueAddress)
            || !string.IsNullOrWhiteSpace(Vm.MapLinkKakao)
            || !string.IsNullOrWhiteSpace(Vm.MapLinkNaver)
            || !string.IsNullOrWhiteSpace(Vm.MapLinkAtlan)
            || !string.IsNullOrWhiteSpace(Vm.MapLinkTmap)
            || Vm.HasVenueCoords
            || !string.IsNullOrWhiteSpace(Vm.RoadMapUrl));

    private IEnumerable<string> SectionsToRender =>
        IsTabbed
            ? string.IsNullOrWhiteSpace(ActiveSection) || !IsSectionVisible(ActiveSection) ? [] : [ActiveSection]
            : Vm.OrderedSections.Where(IsSectionVisible);

    private bool IsSectionVisible(string section) =>
        section != "hero"
        && Vm.LayoutDescriptor.SupportedSections.Contains(section)
        && (!Vm.DesignSettings.SectionVisibility.TryGetValue(section, out var visible) || visible)
        && section switch
        {
            "details" => HasDetails,
            "story" => HasStory,
            "gallery" => Vm.Gallery.Count > 0,
            "video" => Vm.VideoUrls.Count > 0,
            "gift" => Vm.Accounts.Count > 0,
            "info" => HasInfo,
            _ => true,
        };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Vm.HasVenueCoords)
            await JS.InvokeVoidAsync("weddingInterop.initLeafletMap");

        if (shouldFocusLightbox)
        {
            shouldFocusLightbox = false;
            await lbRef.FocusAsync();
        }

        if (shouldFocusVideoLightbox)
        {
            shouldFocusVideoLightbox = false;
            await vlbRef.FocusAsync();
        }
    }

    private void OpenLightbox(int idx)
    {
        Vm.OpenLightbox(idx);
        shouldFocusLightbox = true;
    }

    private async Task CloseLightbox()
    {
        await StopAutoPlay();
        Vm.CloseLightbox();
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape": _ = CloseLightbox(); break;
            case "ArrowRight": Vm.LightboxNext(); break;
            case "ArrowLeft": Vm.LightboxPrev(); break;
        }
    }

    private async Task OpenVideoLightbox(int idx)
    {
        await PauseMusicForVideo();
        videoLightboxIdx = idx;
        videoLightboxOpen = true;
        shouldFocusVideoLightbox = true;
    }

    private void CloseVideoLightbox() => videoLightboxOpen = false;
    private void VideoNext() => videoLightboxIdx = (videoLightboxIdx + 1) % Vm.VideoUrls.Count;
    private void VideoPrev() => videoLightboxIdx = (videoLightboxIdx - 1 + Vm.VideoUrls.Count) % Vm.VideoUrls.Count;

    private void OnVideoKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape": CloseVideoLightbox(); break;
            case "ArrowRight": VideoNext(); break;
            case "ArrowLeft": VideoPrev(); break;
        }
    }

    private void OnPointerDown(PointerEventArgs e) => startX = e.ClientX;
    private void OnPointerUp(PointerEventArgs e)
    {
        if (startX is null) return;
        var delta = e.ClientX - startX.Value;
        startX = null;
        if (Math.Abs(delta) < 30) return;
        if (delta < 0) Vm.LightboxNext(); else Vm.LightboxPrev();
    }

    private async Task ToggleAutoPlay()
    {
        if (isAutoPlaying) await StopAutoPlay(); else await StartAutoPlay();
    }

    private async Task StartAutoPlay()
    {
        if (Vm.Gallery.Count == 0 || isAutoPlaying) return;
        if (!Vm.LightboxOpen) Vm.OpenLightbox(0);
        isAutoPlaying = true;
        autoCts = new();
        var token = autoCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(Vm.GalleryAutoPlayMs, token);
                    if (Vm.LightboxOpen)
                        await InvokeAsync(() => { Vm.LightboxNext(); StateHasChanged(); });
                }
            }
            catch (TaskCanceledException) { }
        }, token);
        await Task.CompletedTask;
    }

    private Task StopAutoPlay()
    {
        isAutoPlaying = false;
        autoCts?.Cancel();
        return Task.CompletedTask;
    }

    private async Task PauseMusicForVideo()
    {
        if (PauseMusicRequested.HasDelegate)
            await PauseMusicRequested.InvokeAsync();
    }

    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("weddingInterop.copyToClipboard", text);
            feedbackCts?.Cancel();
            feedbackCts = new();
            copyFeedback = "✅ 복사되었습니다!";
            StateHasChanged();
            await Task.Delay(2500, feedbackCts.Token);
            copyFeedback = "";
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
        catch { copyFeedback = "복사에 실패했습니다. 직접 선택해주세요."; StateHasChanged(); }
    }

    private async Task OnGuestbookAdd()
    {
        await VmGuest.AddEntryAsync(Slug);
        StateHasChanged();
    }

    private async Task OnGuestbookReload()
    {
        await VmGuest.ReloadAsync(Slug);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        await StopAutoPlay();
        autoCts?.Dispose();
        feedbackCts?.Dispose();
    }
}
