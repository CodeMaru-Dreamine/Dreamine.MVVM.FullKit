@page "/{Slug}/thankyou"
@layout WeddingPlatform.Blazor.Layout.WeddingLayout
@namespace WeddingPlatform.Blazor.Pages
@rendermode InteractiveServer

@using Microsoft.JSInterop
@inject WeddingInvitationViewModel Vm
@inject WeddingGuestbookViewModel VmGuest
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>@Vm.CoupleName 감사 인사</PageTitle>

<HeadContent>
    <meta property="og:title" content="@Vm.OgTitle" />
    <meta property="og:description" content="@Vm.OgDescription" />
    <meta property="og:image" content="@(string.IsNullOrWhiteSpace(Vm.OgImageUrl) ? "/img/og-platform.jpg" : Vm.OgImageUrl)" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
</HeadContent>

@if (!Vm.IsLoaded)
{
    <div class="w-loading"><div class="w-spinner"></div></div>
}
else if (Vm.NotFound)
{
    <div class="w-notfound"><h1>404</h1><p>페이지를 찾을 수 없습니다.</p><a href="/">홈으로</a></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(Vm.MusicUrl))
    {
        <div class="w-music-bar @(Vm.MusicButtonPosition == "top" ? "w-music-bar--top" : "")">
            <audio @ref="audioRef" src="@Vm.MusicUrl" loop preload="auto"></audio>
            <button class="w-music-btn" @onclick="ToggleMusic" title="@(isMusicPlaying ? "음악 끄기" : "음악 켜기")">
                @(isMusicPlaying ? "⏸" : "🎵")
            </button>
            <span class="w-music-label">@(isMusicPlaying ? "재생 중" : "음악 켜기")</span>
        </div>
    }

    <section class="w-hero w-hero--thankyou w-hero--dh-@Vm.HeroPanelHorizontalDesktop w-hero--mh-@Vm.HeroPanelHorizontalMobile" role="banner">
        @if (!string.IsNullOrWhiteSpace(Vm.HeroImageUrl))
        {
            <div class="w-hero__bg" style="background-image:url('@Vm.HeroImageUrl')"></div>
        }
        else
        {
            <div class="w-hero__bg w-hero__bg--default"></div>
        }
        <div class="w-hero__overlay"></div>
        <div class="w-hero__content w-hero__content--dv-@Vm.HeroPanelVerticalDesktop w-hero__content--mv-@Vm.HeroPanelVerticalMobile">
            <div class="w-hero__top w-panel">
                <h1 class="w-hero__title">Thank You</h1>
                <p class="w-hero__names">@Vm.CoupleName</p>
                <p class="w-hero__date">@Vm.WeddingDate.ToString("yyyy년 MM월 dd일"), 소중한 자리에 함께해 주셔서 감사합니다.</p>
            </div>
        </div>
    </section>

    <section class="w-thankyou-msg glass-panel">
        <h2 class="w-section-title">감사 인사</h2>
        <p>
            @Vm.WeddingDate.ToString("yyyy년 MM월 dd일"), @(Vm.VenueName)에서의 결혼식을<br />
            많은 분들의 축복 속에 무사히 마쳤습니다. 🙇‍♂️🙇‍♀️
        </p>
        <p>
            따뜻한 마음과 귀한 발걸음을 보내주신 모든 분들께<br />
            진심으로 감사드립니다.
        </p>
        @if (!string.IsNullOrWhiteSpace(Vm.Story))
        {
            <hr class="w-divider" />
            <p>@Vm.Story</p>
        }
        @if (!string.IsNullOrWhiteSpace(Vm.Story2))
        {
            <p>@Vm.Story2</p>
        }
    </section>

    @if (Vm.VideoUrls.Count > 0)
    {
        <section class="w-video">
            <h2 class="w-section-title">우리의 영상</h2>
            <div class="w-video__grid">
                @for (int i = 0; i < Vm.VideoUrls.Count; i++)
                {
                    var idx = i;
                    <button class="w-video__item" @onclick="() => OpenVideoLightbox(idx)">
                        <video src="@Vm.VideoUrls[idx]" preload="metadata" muted playsinline></video>
                        <span class="w-video__play">▶</span>
                    </button>
                }
            </div>
        </section>

        @if (videoLightboxOpen)
        {
            <div class="w-lightbox" role="dialog" tabindex="-1" @ref="vlbRef" @onkeydown="OnVideoKeyDown">
                <button class="w-lb__close" @onclick="CloseVideoLightbox">✕</button>
                @if (Vm.VideoUrls.Count > 1)
                {
                    <button class="w-lb__prev" @onclick="VideoPrev">‹</button>
                }
                <video class="w-lb__video" src="@Vm.VideoUrls[videoLightboxIdx]" controls autoplay playsinline @onplay="PauseMusicForVideo"></video>
                @if (Vm.VideoUrls.Count > 1)
                {
                    <button class="w-lb__next" @onclick="VideoNext">›</button>
                    <span class="w-lb__counter">@(videoLightboxIdx + 1) / @Vm.VideoUrls.Count</span>
                }
            </div>
            <div class="w-lb__backdrop" @onclick="CloseVideoLightbox"></div>
        }
    }

    @if (Vm.Gallery.Count > 0)
    {
        <section class="w-gallery">
            <h2 class="w-section-title">우리의 사진</h2>
            <div class="w-gallery__controls">
                <button class="w-btn" @onclick="ToggleAutoPlay">
                    @(isAutoPlaying ? "⏸ 정지" : "▶ 자동재생")
                </button>
                <span class="w-gallery__count">최근 @(Vm.Gallery.Count)장 / 전체 @(Vm.AllPhotos.Count)장</span>
            </div>
            <div class="w-gallery__grid">
                @for (int i = 0; i < Vm.Gallery.Count; i++)
                {
                    var idx = i;
                    <button class="w-gallery__item" @onclick="() => OpenLightbox(idx)">
                        <img src="@Vm.Gallery[idx].ThumbUrl" alt="사진 @(idx+1)" loading="lazy" />
                    </button>
                }
            </div>
        </section>

        @if (Vm.LightboxOpen)
        {
            <div class="w-lightbox" role="dialog" tabindex="-1" @ref="lbRef"
                 @onkeydown="OnKeyDown" @onpointerdown="OnPointerDown" @onpointerup="OnPointerUp">
                <button class="w-lb__close" @onclick="CloseLightbox">✕</button>
                <button class="w-lb__prev" @onclick="Vm.LightboxPrev">‹</button>
                <img class="w-lb__img" src="@Vm.AllPhotos[Vm.LightboxIdx].Url" alt="사진 @(Vm.LightboxIdx+1)" />
                <button class="w-lb__next" @onclick="Vm.LightboxNext">›</button>
                <span class="w-lb__counter">@(Vm.LightboxIdx+1) / @Vm.AllPhotos.Count</span>
            </div>
            <div class="w-lb__backdrop" @onclick="CloseLightbox"></div>
        }
    }

    <section class="w-guestbook">
        <h2 class="w-section-title">📖 감사 방명록</h2>
        <div class="w-gb__form">
            <input class="w-input" type="text" placeholder="이름" @bind="VmGuest.Name" />
            <input class="w-input" type="text" placeholder="연락처 (선택)" @bind="VmGuest.Contact" />
            <textarea class="w-input w-textarea" rows="4" placeholder="감사 메시지를 남겨주세요"
                      @bind="VmGuest.Message"></textarea>
            <div class="w-gb__actions">
                <button class="w-btn w-btn--primary" @onclick="OnGuestbookAdd" disabled="@VmGuest.IsSaving">등록</button>
                <button class="w-btn" @onclick="OnGuestbookReload">새로고침</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(VmGuest.LastStatus))
            {
                <p class="w-status">@VmGuest.LastStatus</p>
            }
        </div>
        <ul class="w-gb__list">
            @foreach (var e in VmGuest.EntriesView)
            {
                <li class="w-gb__entry">
                    <div class="w-gb__meta"><strong>@e.Name</strong><span class="w-gb__date">@e.CreatedLocal.ToString("yyyy-MM-dd HH:mm")</span></div>
                    <div class="w-gb__msg">@e.Message</div>
                </li>
            }
        </ul>
    </section>

    <footer class="w-footer">
        <a href="/@Slug">청첩장 보기</a>
        <span> · </span>
        <a href="/@Slug/admin" class="w-admin-link">⚙ 관리자</a>
    </footer>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private ElementReference lbRef;
    private ElementReference vlbRef;
    private ElementReference audioRef;
    private bool isMusicPlaying;
    private bool musicSyncInitialized;
    private double? startX;
    private bool isAutoPlaying;
    private System.Threading.CancellationTokenSource? autoCts;

    private bool videoLightboxOpen;
    private int videoLightboxIdx;
    private bool shouldFocusLightbox;
    private bool shouldFocusVideoLightbox;

    private DotNetObjectReference<ThankYou>? _selfRef;

    protected override async Task OnParametersSetAsync()
    {
        await Vm.LoadAsync(Slug);
        await VmGuest.InitializeAsync(Slug);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("weddingInterop.applyTheme", Vm.ThemeName);
        }

        if (Vm.IsLoaded && !string.IsNullOrWhiteSpace(Vm.MusicUrl) && !musicSyncInitialized)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("weddingInterop.initMusicSync", _selfRef);
            await JS.InvokeVoidAsync("weddingInterop.initMusicAutoplay");
            isMusicPlaying = await JS.InvokeAsync<bool>("weddingInterop.isMusicPlaying");
            musicSyncInitialized = true;
            StateHasChanged();
        }

        if (shouldFocusLightbox)
        {
            shouldFocusLightbox = false;
            await lbRef.FocusAsync();
        }

        if (shouldFocusVideoLightbox)
        {
            shouldFocusVideoLightbox = false;
            await vlbRef.FocusAsync();
        }
    }

    private async Task ToggleMusic()
    {
        // 실제 아이콘 상태는 audio 엘리먼트의 play/pause 이벤트(OnMusicStateChanged)가 동기화합니다.
        try
        {
            isMusicPlaying = await JS.InvokeAsync<bool>(isMusicPlaying ? "weddingInterop.pauseMusic" : "weddingInterop.playMusic");
            StateHasChanged();
        }
        catch { }
    }

    private async Task PauseMusicForVideo()
    {
        if (!isMusicPlaying) return;
        try
        {
            isMusicPlaying = await JS.InvokeAsync<bool>("weddingInterop.pauseMusic");
            StateHasChanged();
        }
        catch { }
    }

    /// <summary>배경 클릭으로 자동재생이 시작되거나, 버튼/브라우저 컨트롤로 정지·재생될 때 JS에서 호출됩니다.</summary>
    [JSInvokable]
    public void OnMusicStateChanged(bool playing)
    {
        isMusicPlaying = playing;
        StateHasChanged();
    }

    private void OpenLightbox(int idx)
    {
        Vm.OpenLightbox(idx);
        shouldFocusLightbox = true;
    }

    private async Task CloseLightbox() { await StopAutoPlay(); Vm.CloseLightbox(); }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape": _ = CloseLightbox(); break;
            case "ArrowRight": Vm.LightboxNext(); break;
            case "ArrowLeft": Vm.LightboxPrev(); break;
        }
    }

    private void OnPointerDown(PointerEventArgs e) => startX = e.ClientX;
    private void OnPointerUp(PointerEventArgs e)
    {
        if (startX is null) return;
        var d = e.ClientX - startX.Value; startX = null;
        if (Math.Abs(d) < 30) return;
        if (d < 0) Vm.LightboxNext(); else Vm.LightboxPrev();
    }

    private async Task OpenVideoLightbox(int idx)
    {
        await PauseMusicForVideo();
        videoLightboxIdx = idx;
        videoLightboxOpen = true;
        shouldFocusVideoLightbox = true;
    }

    private void CloseVideoLightbox() => videoLightboxOpen = false;

    private void VideoNext() => videoLightboxIdx = (videoLightboxIdx + 1) % Vm.VideoUrls.Count;
    private void VideoPrev() => videoLightboxIdx = (videoLightboxIdx - 1 + Vm.VideoUrls.Count) % Vm.VideoUrls.Count;

    private void OnVideoKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape": CloseVideoLightbox(); break;
            case "ArrowRight": VideoNext(); break;
            case "ArrowLeft": VideoPrev(); break;
        }
    }

    private async Task ToggleAutoPlay()
    {
        if (isAutoPlaying) await StopAutoPlay(); else await StartAutoPlay();
    }

    private async Task StartAutoPlay()
    {
        if (Vm.Gallery.Count == 0 || isAutoPlaying) return;
        if (!Vm.LightboxOpen) Vm.OpenLightbox(0);
        isAutoPlaying = true;
        autoCts = new();
        var token = autoCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(3000, token);
                    if (Vm.LightboxOpen)
                        await InvokeAsync(() => { Vm.LightboxNext(); StateHasChanged(); });
                }
            }
            catch (TaskCanceledException) { }
        }, token);
        await Task.CompletedTask;
    }

    private Task StopAutoPlay() { isAutoPlaying = false; autoCts?.Cancel(); return Task.CompletedTask; }

    private async Task OnGuestbookAdd() { await VmGuest.AddEntryAsync(Slug); StateHasChanged(); }
    private async Task OnGuestbookReload() { await VmGuest.ReloadAsync(Slug); StateHasChanged(); }

    public async ValueTask DisposeAsync() { await StopAutoPlay(); autoCts?.Dispose(); _selfRef?.Dispose(); }
}
