@page "/{Slug}/admin"
@layout WeddingPlatform.Blazor.Layout.WeddingLayout
@namespace WeddingPlatform.Blazor.Pages
@rendermode InteractiveServer

@using Markdig
@using Wedding.Common
@using WeddingPlatform.Models
@using Microsoft.JSInterop
@inject WeddingAdminViewModel Vm
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>어드민 — @Slug</PageTitle>

<div class="w-admin">
    @if (!Vm.IsAuthenticated)
    {
        <h1 class="w-admin__title">⚙ 어드민 — <code>@Slug</code></h1>
        <div class="w-admin__login w-panel">
            <h2>관리자 로그인</h2>
            @if (Vm.IsSignedIn)
            {
                <p class="w-hint">현재 공용 로그인: <strong>@Vm.CurrentUserLabel</strong></p>
                <p class="w-hint">기존 관리자 비밀번호를 한 번 입력하면 이 계정이 청첩장 관리자로 추가됩니다.</p>
            }
            else
            {
                <p class="w-hint">CodeMaru/Dreamine 계정으로 먼저 로그인하면, 기존 비밀번호 확인 후 이 웨딩 사이트를 계정에 연결할 수 있습니다.</p>
                <a class="w-btn" href="@LoginUrl">공용 로그인</a>
            }
            <input class="w-input" type="password" placeholder="비밀번호" @bind="Vm.LoginPassword" />
            <button class="w-btn w-btn--primary" @onclick="OnLogin">로그인</button>
            @if (!string.IsNullOrWhiteSpace(Vm.StatusMessage))
            {
                <p class="w-status">@Vm.StatusMessage</p>
            }
        </div>
    }
    else if (!Vm.IsLoaded)
    {
        <div class="w-loading"><div class="w-spinner"></div></div>
    }
    else
    {
        <div class="w-admin-shell @(_previewCollapsed ? "is-preview-collapsed" : "")">

            <!-- ══════ 사이드바 ══════ -->
            <aside class="w-admin-nav @(_navOpen ? "is-open" : "")">
                <div class="w-admin-nav__head">
                    <div class="w-admin-nav__brand">
                        <span class="w-admin-nav__brand-icon">⚙</span>
                        <div>
                            <strong>관리</strong>
                            <small><code>@Slug</code></small>
                        </div>
                    </div>
                    <button class="w-admin-nav__close" @onclick="() => _navOpen = false" aria-label="메뉴 닫기">✕</button>
                </div>

                <nav class="w-admin-nav__list">
                    @foreach (var item in _navItems)
                    {
                        <button class="w-admin-nav__item @(_selected == item.Key ? "active" : "")"
                                @onclick="() => SelectSection(item.Key)">
                            <span class="w-admin-nav__icon">@((MarkupString)item.Icon)</span>
                            <span class="w-admin-nav__label">@item.Label</span>
                        </button>
                    }
                </nav>

                <div class="w-admin-nav__foot">
                    <button class="w-btn w-btn--primary w-btn--block" @onclick="OnSaveConfig">
                        설정 저장
                    </button>
                    <button class="w-btn w-btn--block" @onclick="OnShareInvitation">
                        공유하기
                    </button>
                    @if (!string.IsNullOrWhiteSpace(Vm.StatusMessage))
                    {
                        <p class="w-status w-status--compact">@Vm.StatusMessage</p>
                    }
                    <a class="w-admin-nav__link" href="/@Slug" target="_blank">청첩장 열기</a>
                    <a class="w-admin-nav__link" href="/@Slug/thankyou" target="_blank">감사장 열기</a>
                </div>
            </aside>

            <!-- ══════ 콘텐츠 ══════ -->
            <main class="w-admin-content">

                <div class="w-admin-content__topbar">
                    <button class="w-admin-nav__toggle" @onclick="() => _navOpen = !_navOpen" aria-label="메뉴 열기">☰</button>
                    <h2 class="w-admin-content__title">
                        <span class="w-admin-title__icon">@((MarkupString)CurrentNavItem.Icon)</span>
                        <span class="w-admin-title__text">@CurrentNavItem.Label</span>
                    </h2>
                    <button class="w-admin-preview__toggle" @onclick="OnPreviewToggle" aria-label="미리보기 열기"
                            title="@(_previewCollapsed ? "미리보기 펼치기" : "미리보기")">
                        <span class="w-admin-preview__toggle-icon">📱</span>
                        <span class="w-admin-preview__toggle-text">@(_previewCollapsed ? "미리보기 펼치기" : "미리보기")</span>
                    </button>
                </div>

                <div class="w-admin-content__body">

                    @if (Vm.IsSignedIn)
                    {
                        <p class="w-status w-status--compact">공용 로그인: @Vm.CurrentUserLabel · @(Vm.IsOwner ? "대표 관리자" : "관리자")</p>
                    }

                    @* ─────────── 기본 정보 ─────────── *@
                    @if (_selected == "basic")
                    {
                        <section class="w-admin__section">
                            <label class="w-label">상단 타이틀 문구</label>
                            <input class="w-input" @bind="Vm.Config!.HeroTitle" placeholder="Save The Date" />

                            <label class="w-label">커플 이름</label>
                            <input class="w-input" @bind="Vm.Config!.CoupleName" />

                            <label class="w-label">결혼 날짜</label>
                            <input class="w-input" type="date" @bind="Vm.Config.WeddingDate" />

                            <label class="w-label">결혼 시간</label>
                            <input class="w-input" @bind="Vm.Config.WeddingTime" placeholder="예: PM 12:00" />

                            <label class="w-label">예식장 이름</label>
                            <input class="w-input" @bind="Vm.Config.VenueName" />

                            <label class="w-label">예식장 주소</label>
                            <input class="w-input" @bind="Vm.Config.VenueAddress" />

                            <label class="w-label">스토리 (한국어)</label>
                            <textarea class="w-input w-textarea" rows="4" @bind="Vm.Config.Story"></textarea>

                            <label class="w-label">스토리 (기타 언어)</label>
                            <textarea class="w-input w-textarea" rows="4" @bind="Vm.Config.Story2"></textarea>
                        </section>
                    }

                    @* ─────────── 예식 안내 ─────────── *@
                    else if (_selected == "notice")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">예식 안내</h3>
                            <p class="w-hint">청첩장 안내 섹션에 표시할 추가 문구입니다. 비워두면 표시하지 않습니다.</p>
                            <p class="w-hint">Markdown이나 HTML이 익숙하지 않아도 웹 AI에게 원하는 분위기를 말하고 문구를 받아 붙여넣으면 편합니다.</p>

                            <div class="w-note-examples" aria-label="예식 안내 예시">
                                <button class="w-btn w-btn--sm" type="button" @onclick='() => ApplyCeremonyNoteExample("warm")'>따뜻한 톤</button>
                                <button class="w-btn w-btn--sm" type="button" @onclick='() => ApplyCeremonyNoteExample("formal")'>정중한 톤</button>
                                <button class="w-btn w-btn--sm" type="button" @onclick='() => ApplyCeremonyNoteExample("simple")'>간결한 톤</button>
                                <button class="w-btn w-btn--sm" type="button" @onclick='() => ApplyCeremonyNoteExample("ai")'>AI 요청 예시</button>
                            </div>

                            <div class="w-note-toolbar">
                                <button class="@(Vm.Config!.CeremonyNoteFormat == "Markdown" ? "active" : "")"
                                        @onclick='() => Vm.Config!.CeremonyNoteFormat = "Markdown"'>Markdown (추천)</button>
                                <button class="@(Vm.Config!.CeremonyNoteFormat == "Html" ? "active" : "")"
                                        @onclick='() => Vm.Config!.CeremonyNoteFormat = "Html"'>HTML</button>
                            </div>
                            <div class="w-note-editor-grid">
                                <div class="w-note-editor">
                                    @if (Vm.Config.CeremonyNoteFormat == "Markdown")
                                    {
                                        <textarea class="w-input w-textarea w-textarea--code w-textarea--notice" rows="18"
                                                  @bind="Vm.Config.CeremonyNote" @bind:event="oninput"
                                                  placeholder="## 예식 안내&#10;&#10;하객분들께 전할 안내 문구를 입력하세요."></textarea>
                                        <p class="w-hint">마크다운 형식 — **굵게** *기울임* ## 제목 · 빈 줄이 문단 구분.</p>
                                    }
                                    else
                                    {
                                        <textarea class="w-input w-textarea w-textarea--code w-textarea--notice" rows="18"
                                                  @bind="Vm.Config.CeremonyNote" @bind:event="oninput"
                                                  placeholder="&lt;p&gt;하객분들께 전할 안내 문구를 입력하세요.&lt;/p&gt;"></textarea>
                                        <p class="w-hint">HTML 태그 직접 입력.</p>
                                    }
                                </div>
                                <div class="w-note-preview">
                                    <div class="w-note-preview__head">HTML 미리보기</div>
                                    <div class="w-note-preview__body">
                                        @if (string.IsNullOrWhiteSpace(Vm.Config.CeremonyNote))
                                        {
                                            <p class="w-note-preview__empty">입력한 내용이 여기에 표시됩니다.</p>
                                        }
                                        else
                                        {
                                            @((MarkupString)CeremonyNotePreviewHtml)
                                        }
                                    </div>
                                </div>
                            </div>
                        </section>
                    }

                    @* ─────────── 디자인 ─────────── *@
                    else if (_selected == "design")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">청첩장 레이아웃</h3>
                            <p class="w-hint">청첩장이 하객에게 어떻게 보이는지 결정하는 구조입니다.</p>
                            <div class="w-style-picker">
                                @foreach (var descriptor in WeddingLayoutCatalog.Options)
                                {
                                    var canUse = CanUseLayout(descriptor);
                                    var canSelect = canUse && descriptor.IsImplemented;
                                    <label class="w-style-card @(Vm.Config!.DesignSettings.LayoutMode == descriptor.Mode ? "active" : "") @(!canSelect ? "is-locked" : "")">
                                        <input type="radio" name="w-layout" value="@descriptor.Key" checked="@(Vm.Config!.DesignSettings.LayoutMode == descriptor.Mode)"
                                               disabled="@(!canSelect)"
                                               @onchange="() => SelectLayout(descriptor.Mode)" />
                                        <div class="w-style-card__preview w-style-card__preview--@descriptor.Key"></div>
                                        <div class="w-style-card__meta">
                                            <strong>@descriptor.Label @if (!descriptor.IsImplemented) { <span class="w-layout-lock">준비 중</span> } else if (!canUse) { <span class="w-layout-lock">잠금</span> }</strong>
                                            <small>@descriptor.Description</small>
                                            @if (!descriptor.IsImplemented)
                                            {
                                                <small class="w-layout-lock-hint">권한 부여는 가능하지만 아직 화면 렌더러가 준비되지 않았습니다.</small>
                                            }
                                            else if (!canUse)
                                            {
                                                <small class="w-layout-lock-hint">프리미엄 플랜 또는 개별 잠금 해제 후 사용할 수 있습니다.</small>
                                            }
                                        </div>
                                    </label>
                                }
                            </div>
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🎨 테마 색상</h3>
                            <div class="w-theme-picker">
                                @foreach (var t in InvitationDesignCatalog.Themes)
                                {
                                    <button class="w-theme-btn @(Vm.Config!.DesignSettings.ThemeKey == t.Key ? "active" : "")"
                                            style="--tc:@t.Primary;--tca:@t.Accent"
                                            @onclick="() => SelectTheme(t.Key)">
                                        <span class="w-theme-swatch"></span>
                                        <span>@t.Label</span>
                                    </button>
                                }
                            </div>
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🖼 히어로 이미지</h3>
                            @if (!string.IsNullOrWhiteSpace(Vm.Config!.HeroImageFileName))
                            {
                                <div class="w-admin__hero-preview">
                                    <img src="@Vm.GetHeroUrl(Slug, Vm.Config.HeroImageFileName)" alt="히어로" />
                                    <span>@Vm.Config.HeroImageFileName</span>
                                </div>
                            }
                            <InputFile class="w-file-input" OnChange="OnHeroUpload" accept="image/*" />
                            @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초)</span> }
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">히어로 문구 위치</h3>
                            <p class="w-hint">청첩장 상단 문구와 하단 장소·방명록 박스를 따로 배치합니다.</p>

                            <h4 class="w-admin__sub-h">청첩장 상단 문구</h4>
                            <label class="w-label">PC 화면</label>
                            <div class="w-coord-row">
                                <div>
                                    <label class="w-label">세로</label>
                                    <select class="w-input" @bind="Vm.Config!.InviteHeroTopVerticalDesktop">
                                        <option value="top">위</option>
                                        <option value="middle">가운데</option>
                                        <option value="bottom">아래</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="w-label">가로</label>
                                    <select class="w-input" @bind="Vm.Config!.InviteHeroTopHorizontalDesktop">
                                        <option value="left">왼쪽</option>
                                        <option value="center">가운데</option>
                                        <option value="right">오른쪽</option>
                                    </select>
                                </div>
                            </div>

                            <label class="w-label" style="margin-top:.75rem">모바일 화면</label>
                            <div class="w-coord-row">
                                <div>
                                    <label class="w-label">세로</label>
                                    <select class="w-input" @bind="Vm.Config!.InviteHeroTopVerticalMobile">
                                        <option value="top">위</option>
                                        <option value="middle">가운데</option>
                                        <option value="bottom">아래</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="w-label">가로</label>
                                    <select class="w-input" @bind="Vm.Config!.InviteHeroTopHorizontalMobile">
                                        <option value="left">왼쪽</option>
                                        <option value="center">가운데</option>
                                        <option value="right">오른쪽</option>
                                    </select>
                                </div>
                            </div>

                            <h4 class="w-admin__sub-h">청첩장 하단 장소·방명록</h4>
                            <label class="w-label">PC 화면</label>
                            <div class="w-coord-row">
                                <div>
                                    <label class="w-label">세로</label>
                                    <select class="w-input" @bind="Vm.Config!.InviteHeroBottomVerticalDesktop">
                                        <option value="top">위</option>
                                        <option value="middle">가운데</option>
                                        <option value="bottom">아래</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="w-label">가로</label>
                                    <select class="w-input" @bind="Vm.Config!.InviteHeroBottomHorizontalDesktop">
                                        <option value="left">왼쪽</option>
                                        <option value="center">가운데</option>
                                        <option value="right">오른쪽</option>
                                    </select>
                                </div>
                            </div>

                            <label class="w-label" style="margin-top:.75rem">모바일 화면</label>
                            <div class="w-coord-row">
                                <div>
                                    <label class="w-label">세로</label>
                                    <select class="w-input" @bind="Vm.Config!.InviteHeroBottomVerticalMobile">
                                        <option value="top">위</option>
                                        <option value="middle">가운데</option>
                                        <option value="bottom">아래</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="w-label">가로</label>
                                    <select class="w-input" @bind="Vm.Config!.InviteHeroBottomHorizontalMobile">
                                        <option value="left">왼쪽</option>
                                        <option value="center">가운데</option>
                                        <option value="right">오른쪽</option>
                                    </select>
                                </div>
                            </div>
                        </section>
                    }

                    @* ─────────── 콘텐츠 ─────────── *@
                    else if (_selected == "content")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🎵 배경 음악</h3>
                            @if (!string.IsNullOrWhiteSpace(Vm.Config!.MusicFileName))
                            {
                                <div class="w-admin__music-preview">
                                    <audio controls src="@Vm.GetMusicUrl(Slug, Vm.Config.MusicFileName)" style="width:100%"></audio>
                                    <span class="w-hint">현재: @Vm.Config.MusicFileName</span>
                                    <button class="w-btn w-btn--danger w-btn--sm" @onclick="OnRemoveMusic">🗑 음악 제거</button>
                                </div>
                            }
                            else
                            {
                                <p class="w-hint">배경 음악이 없습니다. mp3·ogg·m4a 파일을 업로드하세요. (최대 30MB)</p>
                            }
                            <InputFile class="w-file-input" OnChange="OnMusicUpload" accept="audio/*" />
                            @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초)</span> }

                            <label class="w-label" style="margin-top:.75rem">음악 버튼 위치</label>
                            <div class="w-note-toolbar">
                                <button class="@(Vm.Config!.MusicButtonPosition == "bottom" ? "active" : "")"
                                        @onclick='() => Vm.Config!.MusicButtonPosition = "bottom"'>화면 하단</button>
                                <button class="@(Vm.Config!.MusicButtonPosition == "top" ? "active" : "")"
                                        @onclick='() => Vm.Config!.MusicButtonPosition = "top"'>화면 상단</button>
                            </div>
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🎬 우리의 영상</h3>
                            <p class="w-hint">갤러리 위에 표시됩니다. mp4 / webm / mov 권장, @Vm.MaxVideoSizeLabel, @(Vm.MaxVideoCount <= 0 ? "개수 무제한" : $"최대 {Vm.MaxVideoCount}개").</p>

                            @if (Vm.Config!.VideoFileNames.Count > 0)
                            {
                                <div class="w-admin__video-list">
                                    @foreach (var fn in Vm.Config.VideoFileNames.ToList())
                                    {
                                        <div class="w-admin__video-item">
                                            <video src="@Vm.GetVideoUrl(Slug, fn)"
                                                   controls preload="metadata" class="w-admin__video-player"></video>
                                            <div class="w-admin__video-meta">
                                                <span class="w-hint">@fn</span>
                                                <button class="w-btn w-btn--danger w-btn--sm"
                                                        @onclick="() => OnDeleteVideo(fn)">삭제</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            @if (Vm.MaxVideoCount <= 0 || Vm.Config.VideoFileNames.Count < Vm.MaxVideoCount)
                            {
                                <InputFile class="w-file-input" OnChange="OnVideoUpload" accept="video/*" />
                                @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초 경과, 용량에 따라 시간이 걸릴 수 있습니다)</span> }
                            }
                            else
                            {
                                <p class="w-hint" style="color:var(--w-primary)">최대 @(Vm.MaxVideoCount)개 업로드 완료. 삭제 후 추가 가능합니다.</p>
                            }
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🖼 갤러리 사진 (@Vm.Gallery.Count 장)</h3>

                            <label class="w-label">자동재생 간격 — <strong>@Vm.Config!.GalleryAutoPlaySeconds 초</strong></label>
                            <input type="range" class="w-range" min="1" max="10" step="1"
                                   @bind="Vm.Config!.GalleryAutoPlaySeconds" @bind:event="oninput" />
                            <p class="w-hint">1 ~ 10초 · 설정 저장 후 청첩장에 반영됩니다.</p>

                            <InputFile class="w-file-input" OnChange="OnGalleryUpload" accept="image/*" multiple />
                            @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초)</span> }

                            <div class="w-admin__gallery">
                                @foreach (var p in Vm.Gallery)
                                {
                                    <div class="w-admin__gallery-item">
                                        <img src="@Vm.GetThumbUrl(Slug, p.FileName)" alt="@p.FileName" />
                                        <button class="w-btn w-btn--danger w-btn--sm"
                                                @onclick="() => OnDeletePhoto(p.FileName)">삭제</button>
                                        <span class="w-admin__fname">@p.FileName</span>
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    @* ─────────── 지도 ─────────── *@
                    else if (_selected == "map")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">지도 좌표</h3>
                            <div class="w-maplink-header">
                                <span class="w-label" style="margin:0">위도 · 경도</span>
                                <button class="w-btn w-btn--sm" type="button" @onclick="OnGeocode"
                                        disabled="@Vm.IsGeocoding"
                                        title="예식장 이름/주소로 위도·경도를 자동으로 찾아줍니다">
                                    @(Vm.IsGeocoding ? "검색 중..." : "📍 좌표 자동 검색")
                                </button>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Vm.GeocodeStatus))
                            {
                                <p class="w-hint" style="color:@(Vm.GeocodeStatus.StartsWith("✅") ? "green" : "#e53e3e")">
                                    @Vm.GeocodeStatus
                                </p>
                            }
                            <div class="w-coord-row">
                                <div>
                                    <label class="w-label">위도</label>
                                    <input class="w-input" type="number" step="0.000001" @bind="Vm.Config!.VenueLat" placeholder="자동 검색 또는 직접 입력" />
                                </div>
                                <div>
                                    <label class="w-label">경도</label>
                                    <input class="w-input" type="number" step="0.000001" @bind="Vm.Config.VenueLng" placeholder="자동 검색 또는 직접 입력" />
                                </div>
                            </div>
                            <p class="w-hint">좌표가 있으면 청첩장에 지도가 표시됩니다. 예식장 이름·주소는 <strong>기본 정보</strong> 탭에서 먼저 입력하세요.</p>
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🗺 지도 앱 링크</h3>
                            <div class="w-maplink-header">
                                <span class="w-label" style="margin:0">카카오맵 · 네이버지도 · 아틀란 · T맵</span>
                                <button class="w-btn w-btn--sm" type="button" @onclick="OnAutoGenerateMapLinks"
                                        title="예식장 이름·주소·좌표를 이용해 링크를 자동으로 채워드립니다">
                                    ✨ 자동 생성
                                </button>
                            </div>
                            <p class="w-hint">예식장 이름/주소/좌표를 먼저 입력한 후 <strong>자동 생성</strong> 버튼을 누르세요.</p>
                            @if (Vm.Config!.MapLinkKakao != "" || Vm.Config.MapLinkNaver != "" || Vm.Config.MapLinkAtlan != "" || Vm.Config.MapLinkTmap != "")
                            {
                                <p class="w-hint" style="color:green">✅ 링크 생성 완료 (카카오맵 · 네이버지도 · 아틀란 · T맵)</p>
                            }
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">약도 이미지</h3>
                            @if (!string.IsNullOrWhiteSpace(Vm.Config!.RoadMapFileName))
                            {
                                <div class="w-admin__hero-preview">
                                    <img src="@Vm.GetRoadMapUrl(Slug, Vm.Config.RoadMapFileName)" alt="약도" />
                                    <span>@Vm.Config.RoadMapFileName</span>
                                </div>
                            }
                            else
                            {
                                <p class="w-hint">아직 약도 이미지가 없습니다. 업로드하면 청첩장 약도 탭에 표시됩니다.</p>
                            }
                            <InputFile class="w-file-input" OnChange="OnRoadMapUpload" accept="image/*" />
                            @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초)</span> }
                        </section>
                    }

                    @* ─────────── 계좌 안내 ─────────── *@
                    else if (_selected == "account")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">💌 마음 전하실 곳</h3>
                            <p class="w-hint">신랑·신부·부모님 등 최대 8명까지 등록할 수 있습니다. 계좌 또는 연락처만 입력해도 됩니다.</p>

                            @for (int i = 0; i < Vm.Config!.Accounts.Count; i++)
                            {
                                var idx = i;
                                var acc = Vm.Config.Accounts[idx];
                                <div class="w-acc-editor">
                                    <div class="w-acc-editor__header">
                                        <strong>@((idx + 1))번 — @(string.IsNullOrWhiteSpace(acc.Label) ? "(레이블 없음)" : acc.Label)</strong>
                                        <button class="w-btn w-btn--danger w-btn--sm" @onclick="() => RemoveAccount(idx)">✕ 삭제</button>
                                    </div>
                                    <div class="w-acc-editor__grid">
                                        <div>
                                            <label class="w-label">레이블 (표시 이름)</label>
                                            <select class="w-input" value="@acc.Label" @onchange="e => acc.Label = e.Value?.ToString() ?? string.Empty">
                                                <option>신랑</option>
                                                <option>신부</option>
                                                <option>신랑 아버지</option>
                                                <option>신랑 어머니</option>
                                                <option>신부 아버지</option>
                                                <option>신부 어머니</option>
                                                <option>직접 입력</option>
                                            </select>
                                            @if (acc.Label == "직접 입력" || !_defaultLabels.Contains(acc.Label))
                                            {
                                                <input class="w-input" style="margin-top:.4rem" @bind="acc.Label" placeholder="레이블 직접 입력" />
                                            }
                                        </div>
                                        <div>
                                            <label class="w-label">이름</label>
                                            <input class="w-input" @bind="acc.Name" placeholder="홍길동" />
                                        </div>
                                        <div>
                                            <label class="w-label">연락처</label>
                                            <input class="w-input" @bind="acc.Phone" placeholder="010-0000-0000" />
                                        </div>
                                        <div>
                                            <label class="w-label">은행명</label>
                                            <input class="w-input" @bind="acc.BankName" placeholder="국민은행" />
                                        </div>
                                        <div>
                                            <label class="w-label">계좌번호</label>
                                            <input class="w-input" @bind="acc.Account" placeholder="000-000-000000" />
                                        </div>
                                        <div>
                                            <label class="w-label">예금주</label>
                                            <input class="w-input" @bind="acc.AccountHolder" placeholder="홍길동" />
                                        </div>
                                        <div class="w-acc-editor__full">
                                            <label class="w-label">카카오페이 URL (선택)</label>
                                            <input class="w-input" @bind="acc.KakaoPayUrl" placeholder="https://qr.kakaopay.com/..." />
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (Vm.Config.Accounts.Count < 8)
                            {
                                <button class="w-btn" @onclick="AddAccount">+ 계좌 / 연락처 추가</button>
                            }
                        </section>
                    }

                    @* ─────────── 공유 설정 ─────────── *@
                    else if (_selected == "share")
                    {
                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">사이트 모드</h3>
                            <select class="w-input" @bind="Vm.Config!.Mode">
                                <option value="@WeddingSiteMode.Invite">청첩장 (예식 안내)</option>
                                <option value="@WeddingSiteMode.ThankYou">감사장 (예식 후)</option>
                                <option value="@WeddingSiteMode.Both">청첩장 + 감사장</option>
                            </select>
                            <p class="w-hint">예식 완료 후 <strong>감사장</strong>으로 바꾸면 지도·예식 안내 대신 감사 인사가 표시됩니다.</p>

                            <label class="w-label">감사장 URL (외부, 선택)</label>
                            <input class="w-input" @bind="Vm.Config.ThankYouUrl" placeholder="https://thankyou.example.com" />

                            <label class="w-label">메인 페이지 노출</label>
                            <label class="w-toggle">
                                <input type="checkbox" @bind="Vm.Config.ShowOnHome" />
                                <span class="w-toggle__track"></span>
                                <span class="w-toggle__label">@(Vm.Config.ShowOnHome ? "ON — 메인 페이지에 표시됨" : "OFF — 메인 페이지에 숨김")</span>
                            </label>
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🔗 링크 미리보기 (OG)</h3>
                            <p class="w-hint">카카오톡·문자 등으로 청첩장 링크를 공유할 때 표시되는 제목·설명·이미지입니다.</p>

                            <label class="w-label">미리보기 제목</label>
                            <input class="w-input" @bind="Vm.Config!.OgTitle"
                                   placeholder="@(Vm.Config?.CoupleName + " 청첩장")" />

                            <label class="w-label">미리보기 설명</label>
                            <textarea class="w-input w-textarea" rows="3" @bind="Vm.Config!.OgDescription"
                                      placeholder="@($"{Vm.Config?.WeddingDate:yyyy년 MM월 dd일} {Vm.Config?.VenueName}에서 함께해 주세요.")"></textarea>

                            <label class="w-label">미리보기 이미지 (비우면 히어로 이미지 사용)</label>
                            @if (!string.IsNullOrWhiteSpace(Vm.Config!.OgImageFileName))
                            {
                                <div class="w-admin__hero-preview">
                                    <img src="@Vm.GetOgImageUrl(Slug, Vm.Config.OgImageFileName)" alt="OG 이미지" />
                                    <span>@Vm.Config.OgImageFileName</span>
                                    <button class="w-btn w-btn--sm" @onclick="() => { Vm.Config!.OgImageFileName = string.Empty; }">✕ 제거</button>
                                </div>
                            }
                            <InputFile class="w-file-input" OnChange="OnOgImageUpload" accept="image/*" />
                            <p class="w-hint">권장 크기: 1200×630px (가로형). 카카오톡 미리보기는 링크 캐시가 있어 바로 반영 안 될 수 있습니다.</p>
                            @if (Vm.IsUploading) { <span class="w-uploading">업로드 중... (@_uploadElapsedSec 초)</span> }
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">👥 관리자 계정</h3>
                            <p class="w-hint">공용 로그인 상태에서 기존 관리자 비밀번호를 입력하면 여러 계정이 같은 청첩장을 관리할 수 있습니다.</p>
                            @if (Vm.EffectiveAdminUsers.Count == 0)
                            {
                                <p class="w-hint">아직 공용 로그인에 연결된 관리자 계정이 없습니다.</p>
                            }
                            else
                            {
                                <div class="w-admin-users">
                                    @foreach (var admin in Vm.EffectiveAdminUsers)
                                    {
                                        var isOwner = string.Equals(admin.Role, "Owner", StringComparison.OrdinalIgnoreCase);
                                        <div class="w-admin-users__item">
                                            <div>
                                                <strong>@(isOwner ? "대표 관리자" : "관리자")</strong>
                                                <span>@(string.IsNullOrWhiteSpace(admin.DisplayName) ? admin.Provider : admin.DisplayName)</span>
                                                @if (!string.IsNullOrWhiteSpace(admin.Email))
                                                {
                                                    <small>@admin.Email</small>
                                                }
                                                <small>@admin.Provider · @admin.AddedAt.ToString("yyyy-MM-dd HH:mm")</small>
                                            </div>
                                            @if (Vm.IsOwner && !isOwner)
                                            {
                                                <button class="w-btn w-btn--danger w-btn--sm" @onclick="() => OnRemoveAdmin(admin.UserId)">삭제</button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        <section class="w-admin__section">
                            <h3 class="w-admin__section-h">🔒 어드민 비밀번호</h3>
                            <label class="w-label">비밀번호 (변경 시 입력)</label>
                            <input class="w-input" type="password" @bind="Vm.Config!.PasswordHash" />
                        </section>
                    }

                </div>
            </main>

            <!-- ══════ 스플리터 (드래그로 프리뷰 폭 조정) ══════ -->
            <div class="w-admin-splitter" title="드래그: 폭 조정 · 더블클릭: 기본값 복원"></div>

            <!-- ══════ 프리뷰 ══════ -->
            <aside class="w-admin-preview @(_previewOpen ? "is-open" : "")">
                <div class="w-admin-preview__head">
                    <strong>@(_previewMode == "phone" ? "폰 미리보기" : "PC 미리보기")</strong>
                    <div class="w-admin-preview__actions">
                        <button class="w-admin-preview__mode @(_previewMode == "phone" ? "active" : "")" @onclick='() => SetPreviewMode("phone")'>폰</button>
                        <button class="w-admin-preview__mode @(_previewMode == "pc" ? "active" : "")" @onclick='() => SetPreviewMode("pc")'>PC</button>
                        <button class="w-btn w-btn--sm" @onclick="ReloadPreview" title="새로고침">🔄</button>
                        <a class="w-btn w-btn--sm" href="@PreviewUrl" target="_blank" title="새 탭에서 열기">↗</a>
                        <button class="w-admin-preview__close" @onclick="OnClosePreview" aria-label="미리보기 접기">✕</button>
                    </div>
                </div>
                <div class="w-admin-preview__frame w-admin-preview__frame--@_previewMode">
                    <iframe id="w-preview-iframe" src="@PreviewUrl" title="@PreviewTitle"></iframe>
                </div>
                <p class="w-admin-preview__hint">저장 후 자동으로 새로고침됩니다.</p>
            </aside>

        </div>
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private string LoginUrl => $"https://codemaru.co.kr/_identity/login?returnUrl={Uri.EscapeDataString(Nav.Uri)}";

    private string _selected = "basic";
    private bool _navOpen = false;
    private bool _previewOpen = false;
    private bool _previewCollapsed = false;
    private bool _initialStateLoaded = false;
    private string _previewMode = "phone";

    private record NavItem(string Key, string Icon, string Label);

    private static readonly NavItem[] _navItems = new[]
    {
        new NavItem("basic",   Icon("user"), "기본 정보"),
        new NavItem("notice",  Icon("note"), "예식 안내"),
        new NavItem("design",  Icon("palette"), "디자인"),
        new NavItem("content", Icon("media"), "사진·동영상"),
        new NavItem("map",     Icon("pin"), "지도"),
        new NavItem("account", Icon("card"), "계좌 안내"),
        new NavItem("share",   Icon("share"), "공유 설정"),
    };

    private NavItem CurrentNavItem => _navItems.FirstOrDefault(i => i.Key == _selected) ?? _navItems[0];
    private string PreviewUrl => $"/{Slug}";
    private string PreviewTitle => "청첩장 미리보기";
    private string CeremonyNotePreviewHtml
    {
        get
        {
            var raw = Vm.Config?.CeremonyNote ?? "";
            if (string.IsNullOrWhiteSpace(raw)) return "";
            if (string.Equals(Vm.Config?.CeremonyNoteFormat, "Html", StringComparison.OrdinalIgnoreCase))
                return raw;
            return Markdown.ToHtml(raw, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build());
        }
    }

    private void SetPreviewMode(string mode)
    {
        _previewMode = mode == "pc" ? "pc" : "phone";
    }

    private static string Icon(string name) => name switch
    {
        "user" => """<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="3.5"/><path d="M5.5 20c1.2-4 4-6 6.5-6s5.3 2 6.5 6"/></svg>""",
        "note" => """<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="4" width="14" height="16" rx="2"/><path d="M8 9h8M8 13h8M8 17h5"/></svg>""",
        "palette" => """<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4a8 8 0 0 0 0 16h1.2a1.8 1.8 0 0 0 1.1-3.2 1.6 1.6 0 0 1 1-2.8H17a3 3 0 0 0 3-3c0-3.9-3.6-7-8-7Z"/><circle cx="8.5" cy="10" r=".8"/><circle cx="11" cy="7.8" r=".8"/><circle cx="14.2" cy="8.3" r=".8"/></svg>""",
        "media" => """<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="5" width="16" height="14" rx="2"/><path d="m8 15 2.8-3 2.2 2.2 1.5-1.6L18 16"/><path d="m10 8 5 3-5 3Z"/></svg>""",
        "pin" => """<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s6-5.7 6-11a6 6 0 0 0-12 0c0 5.3 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg>""",
        "card" => """<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="6" width="16" height="12" rx="2"/><path d="M4 10h16"/><path d="M7 15h4"/></svg>""",
        _ => """<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="18" cy="5" r="2.5"/><circle cx="6" cy="12" r="2.5"/><circle cx="18" cy="19" r="2.5"/><path d="m8.2 11 7.6-4.8M8.2 13l7.6 4.8"/></svg>"""
    };

    private static readonly HashSet<string> _defaultLabels =
        ["신랑", "신부", "신랑 아버지", "신랑 어머니", "신부 아버지", "신부 어머니"];

    private int _uploadElapsedSec;
    private System.Threading.CancellationTokenSource? _uploadTickCts;

    private bool CanUseLayout(WeddingLayoutOption option)
    {
        if (Vm.Config is null) return option.Tier == WeddingLayoutTier.Free;
        var policy = new WeddingLayoutAccessPolicy();
        return policy.CanUse(option, BuildLayoutAccessState());
    }

    private WeddingLayoutAccessState BuildLayoutAccessState()
    {
        if (Vm.Config is null) return new WeddingLayoutAccessState();
        return new WeddingLayoutAccessState
        {
            HasPremiumPlan = Vm.Config.HasPremiumPlan,
            UnlockedLayouts = Vm.Config.UnlockedLayoutModes
                .Select(WeddingLayoutCatalog.FromLegacyKey)
                .Where(x => x != WeddingLayoutMode.Unknown)
                .ToArray(),
        };
    }

    private void SelectLayout(WeddingLayoutMode mode)
    {
        if (Vm.Config is null) return;
        var option = WeddingLayoutCatalog.Instance.Find(mode);
        if (option is null || !option.IsImplemented || !CanUseLayout(option)) return;
        Vm.Config.DesignSettings.LayoutMode = mode;
        Vm.Config.InvitationStyle = InvitationDesignCatalog.ToLegacyLayoutKey(mode);
    }

    private void SelectTheme(string themeKey)
    {
        if (Vm.Config is null) return;
        Vm.Config.DesignSettings.ThemeKey = InvitationDesignCatalog.GetTheme(themeKey).Key;
        Vm.Config.ThemeName = Vm.Config.DesignSettings.ThemeKey;
    }

    private void ApplyCeremonyNoteExample(string tone)
    {
        if (Vm.Config is null) return;

        Vm.Config.CeremonyNoteFormat = "Markdown";
        Vm.Config.CeremonyNote = tone switch
        {
            "formal" => "## 예식 안내\n\n귀한 걸음으로 함께해 주시는 모든 분들께 깊이 감사드립니다.\n\n예식 당일 혼잡할 수 있으니 여유 있게 도착해 주시면 감사하겠습니다. 주차 및 식장 안내는 현장 안내 표지와 직원 안내를 따라주세요.",
            "simple" => "## 예식 안내\n\n소중한 자리에 함께해 주셔서 감사합니다.\n\n예식은 정시에 시작될 예정입니다. 편안한 마음으로 오셔서 저희의 시작을 축복해 주세요.",
            "ai" => "웹 AI에게 이렇게 요청해 보세요.\n\n> 모바일 청첩장에 넣을 예식 안내 문구를 작성해줘. 따뜻하고 정중한 톤으로, 주차 안내와 감사 인사를 포함하고, Markdown 형식으로 만들어줘.",
            _ => "## 예식 안내\n\n먼 길 귀한 걸음으로 함께해 주시는 모든 분들께 진심으로 감사드립니다.\n\n저희 두 사람이 새로운 시작을 하는 자리에 따뜻한 축복으로 함께해 주세요. 오시는 길에 불편함 없도록 아래 안내를 참고해 주시면 감사하겠습니다.",
        };
    }

    private void SelectSection(string key)
    {
        _selected = key;
        _navOpen = false;
    }

    private async Task ReloadPreview()
    {
        try
        {
            await JS.InvokeVoidAsync("weddingInterop.reloadPreviewIframe");
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Vm.IsAuthenticated && Vm.IsLoaded)
        {
            try { await JS.InvokeVoidAsync("weddingInterop.initAdminSplitter"); }
            catch { }

            if (!_initialStateLoaded)
            {
                _initialStateLoaded = true;
                try
                {
                    _previewCollapsed = await JS.InvokeAsync<bool>("weddingInterop.getPreviewCollapsed");
                    StateHasChanged();
                }
                catch { }
            }
        }
    }

    private async Task OnClosePreview()
    {
        _previewCollapsed = true;
        _previewOpen = false;
        try { await JS.InvokeVoidAsync("weddingInterop.setPreviewCollapsed", true); }
        catch { }
    }

    private async Task OnPreviewToggle()
    {
        if (_previewCollapsed)
        {
            _previewCollapsed = false;
            try { await JS.InvokeVoidAsync("weddingInterop.setPreviewCollapsed", false); }
            catch { }
        }
        _previewOpen = !_previewOpen;
    }

    /// <summary>업로드 중 1초마다 경과 시간을 갱신합니다. "업로드 중..."이 멈춘 건지 실제로 느린 건지 구분하기 위함.</summary>
    private async Task RunUploadAsync(Func<Task> action)
    {
        _uploadElapsedSec = 0;
        _uploadTickCts = new System.Threading.CancellationTokenSource();
        var token = _uploadTickCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(1000, token);
                    _uploadElapsedSec++;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (TaskCanceledException) { }
        });

        try { await action(); }
        finally { _uploadTickCts.Cancel(); }
    }

    protected override async Task OnInitializedAsync()
    {
        await Vm.InitializeAsync(Slug);
    }

    private async Task OnLogin()
    {
        if (await Vm.LoginAsync(Slug))
            await Vm.LoadAsync(Slug);
    }

    private async Task OnSaveConfig()
    {
        await Vm.SaveConfigAsync();
        await ReloadPreview();
    }

    private async Task OnShareInvitation()
    {
        var url = new Uri(new Uri(Nav.BaseUri), Slug).ToString();
        var result = await JS.InvokeAsync<string>("weddingInterop.shareOrCopy", url, $"{Vm.Config?.CoupleName} 청첩장");
        Vm.SetStatusMessage(result == "shared" ? "공유 창을 열었습니다." : "청첩장 링크를 복사했습니다.");
    }

    private async Task OnRemoveAdmin(string userId)
    {
        await Vm.RemoveAdminAsync(userId);
        StateHasChanged();
    }

    private void AddAccount()
    {
        Vm.Config?.Accounts.Add(new AccountInfo { Label = "신랑" });
        StateHasChanged();
    }

    private void RemoveAccount(int idx)
    {
        if (idx >= 0 && idx < Vm.Config?.Accounts.Count)
        {
            Vm.Config.Accounts.RemoveAt(idx);
            StateHasChanged();
        }
    }

    private async Task OnVideoUpload(InputFileChangeEventArgs e)
    {
        await RunUploadAsync(() => Vm.UploadVideoAsync(Slug, e.File));
        StateHasChanged();
    }

    private async Task OnDeleteVideo(string fileName)
    {
        await Vm.DeleteVideoAsync(Slug, fileName);
        StateHasChanged();
    }

    private async Task OnMusicUpload(InputFileChangeEventArgs e)
    {
        await RunUploadAsync(() => Vm.UploadMusicAsync(Slug, e.File));
        StateHasChanged();
    }

    private async Task OnRemoveMusic()
    {
        if (Vm.Config is not null)
        {
            Vm.Config.MusicFileName = "";
            await Vm.SaveConfigAsync();
            StateHasChanged();
        }
    }

    private async Task OnOgImageUpload(InputFileChangeEventArgs e)
    {
        await RunUploadAsync(() => Vm.UploadOgImageAsync(Slug, e.File));
        StateHasChanged();
    }

    private async Task OnRoadMapUpload(InputFileChangeEventArgs e)
    {
        await RunUploadAsync(() => Vm.UploadRoadMapAsync(Slug, e.File));
        StateHasChanged();
    }

    private async Task OnGeocode()
    {
        await Vm.GeocodeAsync();
        StateHasChanged();
    }

    private void OnAutoGenerateMapLinks()
    {
        if (Vm.Config is null) return;
        Vm.GenerateMapLinks();
        StateHasChanged();
    }

    private async Task OnHeroUpload(InputFileChangeEventArgs e)
    {
        await RunUploadAsync(() => Vm.UploadHeroAsync(Slug, e.File));
        StateHasChanged();
    }

    private async Task OnGalleryUpload(InputFileChangeEventArgs e)
    {
        await RunUploadAsync(async () =>
        {
            foreach (var f in e.GetMultipleFiles(30))
            {
                await Vm.UploadGalleryAsync(Slug, f);
                StateHasChanged();
            }
        });
    }

    private async Task OnDeletePhoto(string fileName)
    {
        await Vm.DeletePhotoAsync(Slug, fileName);
        StateHasChanged();
    }
