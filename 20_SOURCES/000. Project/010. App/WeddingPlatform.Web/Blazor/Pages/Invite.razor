@page "/{Slug}"
@layout WeddingPlatform.Blazor.Layout.WeddingLayout
@namespace WeddingPlatform.Blazor.Pages
@rendermode InteractiveServer

@using Microsoft.JSInterop
@using Wedding.Common
@using WeddingPlatform.Models
@inject WeddingInvitationViewModel Vm
@inject WeddingGuestbookViewModel VmGuest
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>@Vm.CoupleName 청첩장</PageTitle>

<HeadContent>
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@Vm.OgTitle" />
    <meta property="og:description" content="@Vm.OgDescription" />
    @if (!string.IsNullOrWhiteSpace(Vm.OgImageUrl))
    {
        <meta property="og:image" content="@Vm.OgImageUrl" />
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@Vm.OgTitle" />
    <meta name="twitter:description" content="@Vm.OgDescription" />
    @if (!string.IsNullOrWhiteSpace(Vm.OgImageUrl))
    {
        <meta name="twitter:image" content="@Vm.OgImageUrl" />
    }
</HeadContent>

@if (!Vm.IsLoaded)
{
    <div class="w-loading"><div class="w-spinner"></div></div>
}
else if (Vm.NotFound)
{
    <div class="w-notfound">
        <h1>404</h1>
        <p>청첩장을 찾을 수 없습니다.</p>
        <a href="/">홈으로</a>
    </div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(Vm.MusicUrl))
    {
        <div class="w-music-bar @(Vm.MusicButtonPosition == "top" ? "w-music-bar--top" : "") @(Vm.UsesBottomNavigation ? "w-music-bar--with-tabs" : "") @(Vm.HasCustomMusicButtonPosition ? "w-draggable-positioned" : "") @(AdminPreview ? "w-design-draggable" : "")"
             data-drag-target="music"
             style="@Vm.MusicButtonStyle">
            <audio @ref="audioRef" src="@Vm.MusicUrl" loop preload="auto"></audio>
            <button class="w-music-btn" @onclick="ToggleMusic" title="@(isMusicPlaying ? "음악 끄기" : "음악 켜기")">
                @(isMusicPlaying ? "⏸" : "🎵")
            </button>
            <span class="w-music-label">@(isMusicPlaying ? "재생 중" : "음악 켜기")</span>
        </div>
    }

    @switch (Vm.LayoutMode)
    {
        case WeddingLayoutMode.TabMenu:
            <TabsInvitationLayout Slug="@Slug"
                                  Vm="@Vm"
                                  VmGuest="@VmGuest"
                                  PauseMusicRequested="@PauseMusicForVideo" />
            break;
        case WeddingLayoutMode.Gallery:
            <GalleryInvitationLayout Slug="@Slug"
                                     Vm="@Vm"
                                     VmGuest="@VmGuest"
                                     PauseMusicRequested="@PauseMusicForVideo" />
            break;
        case WeddingLayoutMode.Story:
            <StoryInvitationLayout Slug="@Slug"
                                   Vm="@Vm"
                                   VmGuest="@VmGuest"
                                   PauseMusicRequested="@PauseMusicForVideo" />
            break;
        default:
            <OnePageInvitationLayout Slug="@Slug"
                                     Vm="@Vm"
                                     VmGuest="@VmGuest"
                                     PauseMusicRequested="@PauseMusicForVideo" />
            break;
    }

    <footer class="w-footer">
        <a href="/@Slug/admin" class="w-admin-link" title="관리자">·</a>
    </footer>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [SupplyParameterFromQuery(Name = "adminPreview")] public bool AdminPreview { get; set; }

    private ElementReference audioRef;
    private bool isMusicPlaying;
    private bool musicSyncInitialized;
    private DotNetObjectReference<Invite>? _selfRef;

    protected override async Task OnParametersSetAsync()
    {
        await Vm.LoadAsync(Slug);
        await VmGuest.InitializeAsync(Slug);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            VmGuest.ApplyDefaultMessage();
            await JS.InvokeVoidAsync("weddingInterop.applyTheme", Vm.ThemeName);
        }

        if (Vm.IsLoaded && !string.IsNullOrWhiteSpace(Vm.MusicUrl) && !musicSyncInitialized)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("weddingInterop.initMusicSync", _selfRef);
            await JS.InvokeVoidAsync("weddingInterop.initMusicAutoplay");
            isMusicPlaying = await JS.InvokeAsync<bool>("weddingInterop.isMusicPlaying");
            musicSyncInitialized = true;
            StateHasChanged();
        }

        if (Vm.IsLoaded && AdminPreview)
        {
            await JS.InvokeVoidAsync("weddingInterop.initDesignDragTargets");
        }
    }

    private async Task ToggleMusic()
    {
        try
        {
            isMusicPlaying = await JS.InvokeAsync<bool>(isMusicPlaying ? "weddingInterop.pauseMusic" : "weddingInterop.playMusic");
            StateHasChanged();
        }
        catch { }
    }

    private async Task PauseMusicForVideo()
    {
        if (!isMusicPlaying) return;
        try
        {
            isMusicPlaying = await JS.InvokeAsync<bool>("weddingInterop.pauseMusic");
            StateHasChanged();
        }
        catch { }
    }

    [JSInvokable]
    public void OnMusicStateChanged(bool playing)
    {
        isMusicPlaying = playing;
        StateHasChanged();
    }

    public ValueTask DisposeAsync()
    {
        _selfRef?.Dispose();
        return ValueTask.CompletedTask;
    }
}
