@page "/admin"
@layout PortfolioApp.Blazor.Layout.PortfolioLayout
@namespace PortfolioApp.Blazor.Pages
@rendermode InteractiveServer

@inject PortfolioHomeViewModel Vm
@inject NavigationManager Nav

<PageTitle>통합 어드민 — Codemaru Portfolio</PageTitle>

<div class="pf-page sa-page">

    <div class="sa-header">
        <div class="sa-header__title">
            <span class="sa-header__icon">🧑‍💻</span>
            <div>
                <h1>Portfolio 통합 어드민</h1>
                <p>등록된 포트폴리오 계정을 관리하고 노출 순서를 설정합니다.</p>
            </div>
        </div>
    </div>

    @if (!Vm.IsAuthenticated)
    {
        <div class="sa-login">
            <h2>🔑 슈퍼 관리자 로그인</h2>
            @if (!string.IsNullOrWhiteSpace(Vm.StatusMessage))
            {
                <p class="pf-status pf-status--err">@Vm.StatusMessage</p>
            }
            <input class="pf-input" type="password"
                   value="@Vm.LoginPassword"
                   @oninput="OnPasswordInput"
                   @onkeydown="OnLoginKey"
                   placeholder="슈퍼 관리자 비밀번호" />
            <button class="pf-btn pf-btn--primary pf-btn--full" @onclick="OnLogin">로그인</button>
        </div>
    }
    else
    {
        <!-- ── 새 포트폴리오 만들기 ── -->
        <section class="sa-section">
            <h2 class="sa-section__title">+ 새 포트폴리오 만들기</h2>
            @if (!string.IsNullOrWhiteSpace(Vm.StatusMessage))
            {
                <p class="pf-status @(Vm.StatusMessage.StartsWith("✅") ? "pf-status--ok" : "pf-status--err")">
                    @Vm.StatusMessage
                </p>
            }
            <div class="sa-create-form">
                <div class="pf-form__row">
                    <label class="pf-label">슬러그 (URL ID)</label>
                    <input class="pf-input" @bind="Vm.NewSlug" placeholder="예: gildong (영문·숫자·하이픈)" />
                </div>
                <div class="pf-form__row">
                    <label class="pf-label">소유자 이름</label>
                    <input class="pf-input" @bind="Vm.NewOwnerName" placeholder="예: 홍길동" />
                </div>
                <div class="pf-form__row">
                    <label class="pf-label">어드민 비밀번호</label>
                    <input class="pf-input" type="password" @bind="Vm.NewPassword" placeholder="계정 어드민 접속 시 사용" />
                </div>
                <button class="pf-btn pf-btn--primary sa-create-btn" @onclick="OnCreate">포트폴리오 생성</button>
            </div>
        </section>

        <!-- ── 등록된 포트폴리오 목록 ── -->
        <section class="sa-section">
            <h2 class="sa-section__title">📋 등록된 포트폴리오 (@(Vm.Tenants.Count) 개)</h2>

            <div class="sa-table-wrap">
                <table class="sa-table">
                    <thead>
                        <tr>
                            <th>슬러그</th>
                            <th>소유자</th>
                            <th>직함</th>
                            <th>생성일</th>
                            <th>테마</th>
                            <th>프로젝트</th>
                            <th>홈 노출</th>
                            <th>핀 순서</th>
                            <th>링크</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Vm.Tenants.OrderBy(x => x.PinOrder == 0 ? int.MaxValue : x.PinOrder).ThenByDescending(x => x.CreatedAt))
                        {
                            var projCount = Vm.ProjectCounts.TryGetValue(t.Slug, out var c) ? c : 0;
                            <tr>
                                <td><span class="sa-slug">@t.Slug</span></td>
                                <td>@t.OwnerName</td>
                                <td class="sa-title">@(string.IsNullOrWhiteSpace(t.Title) ? "-" : t.Title)</td>
                                <td class="sa-date">@t.CreatedAt.ToString("yy.MM.dd")</td>
                                <td><span class="sa-theme-badge sa-theme--@t.ThemeName">@t.ThemeName</span></td>
                                <td class="sa-center">
                                    <span class="sa-count">@projCount 개</span>
                                </td>
                                <td class="sa-center">
                                    <label class="sa-toggle">
                                        <input type="checkbox" checked="@t.ShowOnHome"
                                               @onchange="async e => { t.ShowOnHome = (bool)(e.Value ?? false); await Vm.SaveTenantAsync(t); }" />
                                        <span class="sa-toggle__track"></span>
                                    </label>
                                </td>
                                <td class="sa-center">
                                    <input class="sa-pin-input" type="number" min="0" value="@t.PinOrder"
                                           @onchange="async e => { if(int.TryParse(e.Value?.ToString(), out var v)) { t.PinOrder = v; await Vm.SaveTenantAsync(t); } }" />
                                </td>
                                <td>
                                    <div class="sa-link-group">
                                        <a href="/@t.Slug" target="_blank" class="pf-btn pf-btn--sm pf-btn--ghost">포트폴리오</a>
                                        <a href="/@t.Slug/admin" target="_blank" class="pf-btn pf-btn--sm pf-btn--ghost">어드민</a>
                                    </div>
                                </td>
                                <td>
                                    <button class="pf-btn pf-btn--sm pf-btn--danger"
                                            @onclick="() => OnDelete(t.Slug)">삭제</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <div class="sa-footer">
            <button class="pf-btn pf-btn--ghost" @onclick="OnRefresh">🔄 새로고침</button>
        </div>
    }
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (Vm.IsAuthenticated) await Vm.LoadAsync();
    }

    private void OnPasswordInput(ChangeEventArgs e) => Vm.LoginPassword = e.Value?.ToString() ?? string.Empty;

    private async Task OnLogin()
    {
        var ok = await Vm.LoginAsync();
        if (ok) await Vm.LoadAsync();
    }

    private async Task OnLoginKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await OnLogin();
    }

    private async Task OnRefresh() => await Vm.LoadAsync();

    private async Task OnCreate()
    {
        var ok = await Vm.CreateTenantAsync();
        if (ok) await Vm.LoadAsync();
    }

    private async Task OnDelete(string slug)
    {
        await Vm.DeleteTenantAsync(slug);
    }
}
