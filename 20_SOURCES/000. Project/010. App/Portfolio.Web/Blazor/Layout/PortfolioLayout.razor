@inherits LayoutComponentBase
@namespace PortfolioApp.Blazor.Layout
@implements IDisposable
@inject PortfolioUserContext UserContext
@inject NavigationManager Nav

<header class="pf-topnav">
    <a class="pf-topnav__brand" href="https://codemaru.co.kr">
        <img class="pf-topnav__mark" src="/img/Codemaru_Bloom.jpg" alt="" />
        <span>CodeMaru</span>
    </a>
    <nav id="pfTopnavMenu" class="pf-topnav__links @(isNavOpen ? "open" : null)" aria-label="CodeMaru 서비스">
        <a href="https://codemaru.co.kr">Home</a>
        <a href="https://dreamine.kr/" target="_blank" rel="noopener">Dreamine</a>
        <a href="https://codemaru.co.kr/cardhybrid">CardHybrid</a>
        <a href="https://wedding.codemaru.co.kr">Wedding</a>
        <a href="https://thankyou.codemaru.co.kr/">ThankYou</a>
        <a href="https://families.codemaru.co.kr">Families</a>
        <a href="https://portfolio.codemaru.co.kr/" class="active" aria-current="page">Portfolio</a>
        <a href="https://cctvviewer.codemaru.co.kr">CCTV</a>
        <a href="https://shop.codemaru.co.kr/">ShopStore</a>
        <a href="https://codemaru.co.kr/contact">Contact</a>
        @if (!hasLoadedCurrentUser)
        {
            <span class="pf-topnav__auth pf-topnav__auth--pending" aria-hidden="true"></span>
        }
        else if (currentUser.IsAuthenticated)
        {
            <a class="pf-topnav__auth" href="@AccountUrl">@NavUserLabel</a>
            <a class="pf-topnav__auth" href="@SignoutUrl">로그아웃</a>
        }
        else
        {
            <a class="pf-topnav__auth" href="@LoginUrl">로그인</a>
        }
    </nav>
    <button class="pf-topnav__burger"
            type="button"
            @onclick="ToggleNav"
            aria-label="메뉴 열기/닫기"
            aria-expanded="@isNavOpen"
            aria-controls="pfTopnavMenu">
        <span></span><span></span><span></span>
    </button>
</header>

<div id="main-content" tabindex="-1">
    @Body
</div>

@code {
    private PortfolioCurrentUser currentUser = PortfolioCurrentUser.Anonymous;
    private bool hasLoadedCurrentUser;
    private bool isNavOpen;

    private string LoginUrl => $"https://codemaru.co.kr/_identity/login?returnUrl={Uri.EscapeDataString(Nav.Uri)}";
    private string AccountUrl => $"https://codemaru.co.kr/_identity/account?returnUrl={Uri.EscapeDataString(Nav.Uri)}";
    private string SignoutUrl => $"https://codemaru.co.kr/_identity/signout?returnUrl={Uri.EscapeDataString(Nav.Uri)}";
    private string NavUserLabel => string.IsNullOrWhiteSpace(currentUser.DisplayName) ? "내 계정" : currentUser.DisplayName;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        currentUser = await UserContext.GetCurrentAsync();
        hasLoadedCurrentUser = true;
    }

    private void ToggleNav()
    {
        isNavOpen = !isNavOpen;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (!isNavOpen)
        {
            return;
        }

        isNavOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
