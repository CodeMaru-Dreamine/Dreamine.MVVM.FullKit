@namespace DreamineWeb.Blazor
@using Microsoft.AspNetCore.Components.Web
@using DreamineWeb.Services
@inject SiteSettingsService SiteSettings
@inject NavigationManager Navigation

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    @{
        var og = SiteSettings.Current;
        var requestUri = new Uri(Navigation.Uri);
        var requestPath = requestUri.AbsolutePath.TrimEnd('/');
        var isKnowledgeHub = requestPath.Equals("/knowledge", StringComparison.OrdinalIgnoreCase);
        var isEnglish = requestUri.Query.Contains("lang=en", StringComparison.OrdinalIgnoreCase);
        var siteRoot = og.OgUrl.TrimEnd('/');
        var ogTitle = isKnowledgeHub
            ? (isEnglish ? "Dreamine FullKit Documentation Hub" : "Dreamine FullKit 프로젝트 문서 허브")
            : (string.IsNullOrEmpty(og.OgTitle) ? og.Title : og.OgTitle);
        var ogDesc = isKnowledgeHub
            ? (isEnglish
                ? "Explore 80 FullKit apps, reusable libraries, tests, and samples with bilingual Doxygen API docs and focused knowledge graphs."
                : "FullKit의 80개 앱·라이브러리·테스트·샘플을 분류별로 탐색하고, 한글·영문 Doxygen API 문서와 프로젝트별 지식 그래프를 확인하세요.")
            : (string.IsNullOrEmpty(og.OgDescription) ? og.Description : og.OgDescription);
        var ogImg = isKnowledgeHub
            ? $"{siteRoot}/img/og-documentation-hub.png"
            : (og.OgImageUrl.StartsWith("http") ? og.OgImageUrl : siteRoot + og.OgImageUrl);
        var ogUrl = isKnowledgeHub ? $"{siteRoot}/knowledge" : og.OgUrl;
    }
    <title>@ogTitle</title>
    <meta name="description" content="@ogDesc" />
    <link rel="canonical" href="@ogUrl" />
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="@og.OgSiteName" />
    <meta property="og:url"         content="@ogUrl" />
    <meta property="og:title"       content="@ogTitle" />
    <meta property="og:description" content="@ogDesc" />
    <meta property="og:image"       content="@ogImg" />
    <meta property="og:image:alt"   content="Dreamine FullKit Documentation Hub" />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale"       content="@(isEnglish ? "en_US" : "ko_KR")" />
    <meta name="twitter:card"        content="@og.TwitterCard" />
    <meta name="twitter:title"       content="@ogTitle" />
    <meta name="twitter:description" content="@ogDesc" />
    <meta name="twitter:image"       content="@ogImg" />
    <meta name="twitter:image:alt"   content="Dreamine FullKit Documentation Hub" />

    <link rel="icon" href="@(string.IsNullOrEmpty(og.IconUrl) ? "/img/icon.ico" : og.IconUrl)" />
    <link rel="stylesheet" href="/css/dreamine.css?v=20260718-knowledge" />
    @* Blazor scoped CSS 번들 — Dreamine.UI.Blazor 컴포넌트(.razor.css)를 이 안에서 @import 로 로드 *@
    <link rel="stylesheet" href="Dreamine.Web.styles.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <HeadOutlet />
</head>
<body>
    <DreamineWeb.Blazor.Routes @rendermode="new InteractiveServerRenderMode(prerender: true)" />
    <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
    <script>
        mermaid.initialize({
            startOnLoad: false,
            theme: 'base',
            themeVariables: {
                darkMode: true,
                background: '#030913',
                primaryColor: '#07111f',
                primaryTextColor: '#e8eaf0',
                primaryBorderColor: 'rgba(73,178,255,0.35)',
                lineColor: '#49b2ff',
                secondaryColor: '#0a1829',
                tertiaryColor: '#0d1f36',
                edgeLabelBackground: '#07111f',
                clusterBkg: '#07111f',
                titleColor: '#49b2ff',
                attributeBackgroundColorEven: '#07111f',
                attributeBackgroundColorOdd: '#0a1829',
                classText: '#e8eaf0',
                nodeBorder: 'rgba(73,178,255,0.35)',
                nodeTextColor: '#e8eaf0',
                mainBkg: '#07111f'
            }
        });
        window.renderMermaid = function () {
            mermaid.run({ querySelector: '.mermaid:not([data-processed])' });
        };
        window.dwScrollToId = function (id) {
            var el = document.getElementById(id);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        };
    </script>
    <script src="/_framework/blazor.web.js" autostart="false"></script>
    <script>
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 10,
                    retryIntervalMilliseconds: (n) => Math.min(1000 * Math.pow(2, n), 30000)
                },
                configureSignalR: function (builder) {
                    builder.withUrl('/_blazor', { transport: 7 })
                           .withAutomaticReconnect([0, 1000, 2000, 5000, 10000, 15000, 30000, 30000, 30000, 30000]);
                }
            }
        });
    </script>
</body>
</html>
