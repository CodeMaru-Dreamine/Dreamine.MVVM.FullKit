@namespace DreamineWeb.Blazor.Layout
@inherits LayoutComponentBase
@inject UserPreferencesService Prefs
@inject SiteSettingsService SiteSettings
@inject NavigationManager Nav
@implements IDisposable

<CascadingValue Value="Prefs">
<div class="dw-shell">
    <header class="dw-topbar">
        <a href="/" class="dw-brand">
            @if (!string.IsNullOrWhiteSpace(SiteSettings.Current.IconUrl))
            {
                <img src="@SiteSettings.Current.IconUrl" class="dw-brand__img" alt="icon" />
            }
            else
            {
                <span class="dw-brand__mark"></span>
            }
            <span class="dw-brand__name">@SiteSettings.Current.Title</span>
        </a>
        <nav class="dw-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="dw-nav__link">
                @(Prefs.IsKorean ? "홈" : "Home")
            </NavLink>
            <NavLink href="/libraries" class="dw-nav__link">
                @(Prefs.IsKorean ? "라이브러리" : "Libraries")
            </NavLink>
            <NavLink href="/guide" class="dw-nav__link">
                @(Prefs.IsKorean ? "사용법" : "Guide")
            </NavLink>
            <NavLink href="/playground" class="dw-nav__link">
                @(Prefs.IsKorean ? "체험" : "Playground")
            </NavLink>
            <NavLink href="/knowledge" class="dw-nav__link">
                @(Prefs.IsKorean ? "문서 허브" : "Docs Hub")
            </NavLink>
            <button class="dw-lang-btn" @onclick="Prefs.Toggle" title="언어 전환">
                @(Prefs.IsKorean ? "EN" : "한")
            </button>
        </nav>
    </header>

    <main class="dw-content">
        @Body
    </main>

    <footer class="dw-footer">
        <span>© 2026 @SiteSettings.Current.Title. All rights reserved.</span>
        <a href="@SiteSettings.Current.GitHubUrl" target="_blank" rel="noopener">GitHub</a>
    </footer>
</div>
</CascadingValue>

@code {
    protected override void OnInitialized()
    {
        ApplyLangFromQuery();
        Prefs.Changed += OnPrefChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    // ?lang=en / ?lang=ko 쿼리스트링으로 언어를 강제 지정할 수 있게 한다.
    // 외부 README 벳지에서 영어 페이지로 딥링크할 때 사용된다.
    private void ApplyLangFromQuery()
    {
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers
            .ParseQuery(new Uri(Nav.Uri).Query);
        if (query.TryGetValue("lang", out var value))
        {
            var lang = value.ToString();
            if (lang == "en" || lang == "ko")
            {
                Prefs.Set(lang);
            }
        }
    }

    private void OnPrefChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        ApplyLangFromQuery();
    }

    public void Dispose()
    {
        Prefs.Changed -= OnPrefChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
