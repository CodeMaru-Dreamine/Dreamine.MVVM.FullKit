@namespace DreamineWeb.Blazor.Layout
@inherits LayoutComponentBase

<div class="dw-shell">
    <header class="dw-topbar">
        <a href="/" class="dw-brand">
            <span class="dw-brand__mark"></span>
            <span class="dw-brand__name">Dreamine</span>
        </a>
        <nav class="dw-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="dw-nav__link">홈</NavLink>
            <NavLink href="/libraries" class="dw-nav__link">라이브러리</NavLink>
            <NavLink href="/admin" class="dw-nav__link dw-nav__link--admin">⚙ 관리</NavLink>
        </nav>
    </header>

    <main class="dw-content">
        @Body
    </main>

    <footer class="dw-footer">
        <span>© 2026 Dreamine. All rights reserved.</span>
        <a href="https://github.com/CodeMaru-Dreamine" target="_blank" rel="noopener">GitHub</a>
    </footer>
</div>
