@page "/knowledge"
@namespace DreamineWeb.Blazor.Pages
@rendermode InteractiveServer
@inject DocumentationCatalogService Catalog
@implements IDisposable

<PageTitle>@(Ko ? "프로젝트 문서와 지식 그래프" : "Project Documentation & Knowledge Graphs") — Dreamine</PageTitle>

<div class="dw-page dw-knowledge">
    <div class="dw-page__head dw-knowledge__hero">
        <div>
            <span class="dw-knowledge__eyebrow">@(Ko ? "80개 프로젝트 · 두 언어" : "80 PROJECTS · TWO LANGUAGES")</span>
            <h1 class="dw-page__title">@(Ko ? "프로젝트 문서 허브" : "Project Documentation Hub")</h1>
            <p class="dw-page__copy">
                @(Ko
                    ? "Dreamine FullKit의 앱, 재사용 라이브러리, 테스트, 학습용 샘플을 목적별로 나눠 살펴보세요. 각 카드에서 빌드 XML, 한글·영문 Doxygen API 문서, 프로젝트 전용 지식 그래프로 바로 이동할 수 있습니다."
                    : "Explore Dreamine FullKit by purpose: applications, reusable libraries, tests, and learning samples. Every card links directly to its build XML, bilingual Doxygen API reference, and focused knowledge graph.")
            </p>
        </div>
        <a class="dw-btn dw-btn--outline" href="@FullGraphUrl">
            @(Ko ? "전체 그래프(고급) →" : "Full graph (advanced) →")
        </a>
    </div>

    <nav class="dw-knowledge__filters" aria-label="@(Ko ? "프로젝트 분류" : "Project categories")">
        <button type="button"
                class="dw-knowledge-filter @(string.IsNullOrEmpty(SelectedCategory) ? "is-active" : null)"
                aria-pressed="@(string.IsNullOrEmpty(SelectedCategory))"
                @onclick="() => SelectCategory(string.Empty)">
            <span class="dw-knowledge-filter__icon">ALL</span>
            <span class="dw-knowledge-filter__body">
                <strong>@(Ko ? "전체" : "All")</strong>
                <small>@(Ko ? "모든 문서 모아보기" : "Browse every project")</small>
            </span>
            <span class="dw-knowledge-filter__count">@Projects.Count</span>
        </button>
        @foreach (string category in Categories)
        {
            <button type="button"
                    class="dw-knowledge-filter @CategoryCss(category) @(SelectedCategory == category ? "is-active" : null)"
                    aria-pressed="@(SelectedCategory == category)"
                    @onclick="() => SelectCategory(category)">
                <span class="dw-knowledge-filter__icon">@CategoryCode(category)</span>
                <span class="dw-knowledge-filter__body">
                    <strong>@CategoryLabel(category)</strong>
                    <small>@CategoryDescription(category)</small>
                </span>
                <span class="dw-knowledge-filter__count">@Projects.Count(project => project.Category == category)</span>
            </button>
        }
    </nav>

    <div class="dw-knowledge__toolbar">
        <label class="dw-knowledge__search">
            <span class="sr-only">@(Ko ? "프로젝트 검색" : "Search projects")</span>
            <input class="dw-input" type="search"
                   placeholder="@(Ko ? "프로젝트 이름·설명·프레임워크 검색..." : "Search name, description, or framework...")"
                   @bind="SearchText" @bind:event="oninput" />
        </label>
        <span class="dw-knowledge__count">
            <strong>@FilteredProjects.Count()</strong> @(Ko ? "개 프로젝트" : "projects")
        </span>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="dw-knowledge__notice">
            <strong>@(Ko ? "문서 카탈로그를 불러오지 못했습니다." : "The documentation catalog is unavailable.")</strong>
            <span>@ErrorMessage</span>
        </div>
    }
    else if (!FilteredProjects.Any())
    {
        <div class="dw-knowledge__empty">@(Ko ? "검색 조건에 맞는 프로젝트가 없습니다." : "No projects match the current filters.")</div>
    }
    else
    {
        @foreach (IGrouping<string, DocumentationProjectInfo> group in FilteredProjects.GroupBy(project => project.Category))
        {
            <section class="dw-knowledge__group">
                <div class="dw-knowledge__group-head">
                    <div class="dw-knowledge__group-title">
                        <span class="dw-knowledge__group-code @CategoryCss(group.Key)">@CategoryCode(group.Key)</span>
                        <div>
                            <h2>@CategoryLabel(group.Key)</h2>
                            <p>@CategoryDescription(group.Key)</p>
                        </div>
                    </div>
                    <span class="dw-knowledge__group-count">@group.Count()</span>
                </div>
                <div class="dw-knowledge__grid">
                    @foreach (DocumentationProjectInfo project in group)
                    {
                        <article class="dw-knowledge-card @CategoryCss(project.Category)">
                            <div class="dw-knowledge-card__top">
                                <span class="dw-knowledge-card__category">@CategoryCode(project.Category) · @CategoryLabel(project.Category)</span>
                                @if (!string.IsNullOrWhiteSpace(project.Version))
                                {
                                    <span class="dw-knowledge-card__version">@($"v{project.Version}")</span>
                                }
                            </div>
                            <h3 title="@project.Name">@project.Name</h3>
                            <p>@project.GetDescription(Language)</p>
                            <div class="dw-knowledge-card__frameworks">
                                @foreach (string framework in project.TargetFrameworks)
                                {
                                    <span>@framework</span>
                                }
                            </div>
                            <div class="dw-knowledge-card__availability">
                                <span class="@AvailabilityCss(project.DocumentationAvailable && project.IsDocumentationAvailable(Language))">DOCS</span>
                                <span class="@AvailabilityCss(project.DoxygenAvailable && !string.IsNullOrWhiteSpace(project.GetDoxygenUrl(Language)))">DOXYGEN</span>
                                <span class="@AvailabilityCss(project.KnowledgeGraphAvailable && !string.IsNullOrWhiteSpace(project.GetGraphUrl(Language)))">GRAPH</span>
                            </div>
                            <div class="dw-knowledge-card__actions">
                                @if (project.DocumentationAvailable && project.IsDocumentationAvailable(Language) && !string.IsNullOrWhiteSpace(project.DocumentPageUrl))
                                {
                                    <a href="@project.DocumentPageUrl">@(Ko ? "Dreamine 문서" : "Dreamine docs")</a>
                                }
                                else
                                {
                                    <span class="is-disabled" title="@(Ko ? "이 프로젝트는 별도 Dreamine 문서 페이지를 제공하지 않습니다." : "This project does not have a separate Dreamine documentation page.")">
                                        @(Ko ? "문서 페이지 없음" : "No docs page")
                                    </span>
                                }
                                @if (project.DoxygenAvailable && !string.IsNullOrWhiteSpace(project.GetDoxygenUrl(Language)))
                                {
                                    <a href="@project.GetDoxygenUrl(Language)">Doxygen →</a>
                                }
                                @if (project.KnowledgeGraphAvailable && !string.IsNullOrWhiteSpace(project.GetGraphUrl(Language)))
                                {
                                    <a class="is-primary" href="@project.GetGraphUrl(Language)">
                                        @(Ko ? "지식 그래프 →" : "Knowledge graph →")
                                    </a>
                                }
                            </div>
                        </article>
                    }
                </div>
            </section>
        }
    }
</div>

@code {
    [CascadingParameter] public UserPreferencesService Lang { get; set; } = default!;

    private IReadOnlyList<DocumentationProjectInfo> Projects { get; set; } = [];
    private string SearchText { get; set; } = string.Empty;
    private string SelectedCategory { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private bool Ko => Lang?.IsKorean ?? true;
    private string Language => Ko ? "ko" : "en";
    private string FullGraphUrl => $"/understand/graph/?lang={Language}";

    private IEnumerable<string> Categories =>
        Projects.Select(project => project.Category).Distinct().OrderBy(CategoryOrder);

    private IEnumerable<DocumentationProjectInfo> FilteredProjects =>
        Projects.Where(Matches).OrderBy(project => CategoryOrder(project.Category)).ThenBy(project => project.Name);

    protected override void OnInitialized()
    {
        try
        {
            Projects = Catalog.GetProjects();
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }

        if (Lang is not null)
            Lang.Changed += OnLanguageChanged;
    }

    private bool Matches(DocumentationProjectInfo project)
    {
        if (!string.IsNullOrWhiteSpace(SelectedCategory) && project.Category != SelectedCategory)
            return false;

        if (string.IsNullOrWhiteSpace(SearchText))
            return true;

        string query = SearchText.Trim();
        return project.Name.Contains(query, StringComparison.OrdinalIgnoreCase)
            || project.GetDescription(Language).Contains(query, StringComparison.OrdinalIgnoreCase)
            || project.TargetFrameworks.Any(framework => framework.Contains(query, StringComparison.OrdinalIgnoreCase));
    }

    private string CategoryLabel(string category) => category switch
    {
        "000. Project" => Ko ? "애플리케이션" : "Applications",
        "100. Library" => Ko ? "라이브러리" : "Libraries",
        "200. Tests" => Ko ? "테스트" : "Tests",
        "998. DEMO" => Ko ? "샘플·데모" : "Samples & Demos",
        _ => category
    };

    private static int CategoryOrder(string category) => category switch
    {
        "000. Project" => 0,
        "100. Library" => 1,
        "200. Tests" => 2,
        "998. DEMO" => 3,
        _ => 4
    };

    private string CategoryDescription(string category) => category switch
    {
        "000. Project" => Ko ? "실행 앱과 웹 서비스" : "Apps and web services",
        "100. Library" => Ko ? "재사용 가능한 FullKit 패키지" : "Reusable FullKit packages",
        "200. Tests" => Ko ? "품질 검증과 회귀 테스트" : "Quality and regression tests",
        "998. DEMO" => Ko ? "학습용 예제와 통합 데모" : "Learning samples and demos",
        _ => Ko ? "기타 프로젝트" : "Other projects"
    };

    private static string CategoryCode(string category) => category switch
    {
        "000. Project" => "APP",
        "100. Library" => "LIB",
        "200. Tests" => "TEST",
        "998. DEMO" => "DEMO",
        _ => "ETC"
    };

    private static string CategoryCss(string category) => category switch
    {
        "000. Project" => "is-app",
        "100. Library" => "is-library",
        "200. Tests" => "is-test",
        "998. DEMO" => "is-demo",
        _ => "is-other"
    };

    private static string AvailabilityCss(bool available) => available ? "is-ready" : "is-missing";

    private void SelectCategory(string category) => SelectedCategory = category;

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        if (Lang is not null)
            Lang.Changed -= OnLanguageChanged;
    }
}
