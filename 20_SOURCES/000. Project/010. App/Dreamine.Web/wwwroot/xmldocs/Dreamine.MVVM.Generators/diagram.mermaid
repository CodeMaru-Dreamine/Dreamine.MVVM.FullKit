classDiagram
    class ObservablePropertyGenerator {
        <<SourceGenerator>>
        +Execute(GeneratorExecutionContext) void
        -GenerateProperty(IFieldSymbol) string
    }
    class RelayCommandGenerator {
        <<SourceGenerator>>
        +Execute(GeneratorExecutionContext) void
        -GenerateCommand(IMethodSymbol) string
    }
    class ViewModelGenerator {
        <<SourceGenerator>>
        +Execute(GeneratorExecutionContext) void
        -GeneratePartialClass(INamedTypeSymbol) string
    }
    class ObservablePropertyAttribute {
        +string PropertyName
        +bool NotifyAlso
    }
    class RelayCommandAttribute {
        +string CanExecuteMethod
        +bool IsAsync
    }
    ObservablePropertyGenerator --> ObservablePropertyAttribute
    RelayCommandGenerator --> RelayCommandAttribute