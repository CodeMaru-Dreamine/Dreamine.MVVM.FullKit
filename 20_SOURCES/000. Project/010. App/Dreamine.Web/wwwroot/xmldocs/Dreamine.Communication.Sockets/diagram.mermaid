classDiagram
    class TcpClient {
        -string _host
        -int _port
        +IsConnected bool
        +ConnectAsync() Task
        +DisconnectAsync() Task
        +SendAsync(byte[]) Task
        +ReceiveAsync() Task~byte[]~
        +DataReceived event
    }
    class UdpClient {
        -string _host
        -int _port
        +SendAsync(byte[], IPEndPoint) Task
        +ReceiveAsync() Task~UdpReceiveResult~
        +StartListening() void
        +StopListening() void
    }
    class TcpServer {
        -int _port
        +Start() Task
        +Stop() Task
        +ClientConnected event
        +DataReceived event
        +Broadcast(byte[]) Task
    }
    class SocketPool {
        -int _maxConnections
        +Acquire() Task~TcpClient~
        +Release(TcpClient) void
    }
    class ConnectionClientBase {
        <<abstract>>
    }
    ConnectionClientBase <|-- TcpClient
    TcpServer o-- TcpClient
    SocketPool o-- TcpClient