@page "/{Slug}"
@layout FamiliesApp.Blazor.Layout.FamilyLayout
@namespace FamiliesApp.Blazor.Pages
@rendermode InteractiveServer

@inject FamilyAlbumViewModel Vm
@inject NavigationManager Nav

@if (!Vm.IsLoaded)
{
    <div class="fa-loading">불러오는 중...</div>
}
else if (Vm.NotFound)
{
    <div class="fa-notfound">
        <h2>앨범을 찾을 수 없습니다.</h2>
        <a href="/" class="fa-btn fa-btn--ghost">홈으로 →</a>
    </div>
}
else
{
    <PageTitle>@Vm.FamilyName 가족 앨범</PageTitle>

    <HeadContent>
        <meta property="og:type" content="website" />
        <meta property="og:url" content="@Nav.Uri" />
        <meta property="og:title" content="@Vm.OgTitle" />
        <meta property="og:description" content="@Vm.OgDescription" />
        @if (!string.IsNullOrWhiteSpace(Vm.OgImageUrl))
        {
            <meta property="og:image" content="@Vm.OgImageUrl" />
        }
    </HeadContent>

    <div class="fa-page fa-theme-@Vm.ThemeName">

        <!-- ── 커버 ── -->
        <section class="fa-cover @(string.IsNullOrWhiteSpace(Vm.CoverImageUrl) ? "fa-cover--no-img" : "")">
            @if (!string.IsNullOrWhiteSpace(Vm.CoverImageUrl))
            {
                <div class="fa-cover__bg" style="background-image:url('@Vm.CoverImageUrl')"></div>
            }
            <div class="fa-cover__inner">
                <h1 class="fa-cover__name">@Vm.FamilyName</h1>
                @if (!string.IsNullOrWhiteSpace(Vm.Bio))
                {
                    <p class="fa-cover__bio">@Vm.Bio</p>
                }
            </div>
        </section>

        <!-- ── 앨범 폴더 ── -->
        @if (Vm.Albums.Count > 0)
        {
            <section class="fa-albums">
                <h2 class="fa-section-title">📂 앨범</h2>
                <div class="fa-albums__grid">
                    @foreach (var album in Vm.Albums)
                    {
                        <a href="/@Slug/album/@album.Id" class="fa-album-folder">
                            <div class="fa-album-folder__icon">
                                @if (!string.IsNullOrWhiteSpace(album.CoverPhotoFileName))
                                {
                                    <div class="fa-album-folder__cover"
                                         style="background-image:url('@Vm.GetMediaUrl(album.Id, album.CoverPhotoFileName)')">
                                    </div>
                                }
                                else
                                {
                                    <span>📁</span>
                                }
                            </div>
                            <div class="fa-album-folder__name">@album.Name</div>
                            @if (!string.IsNullOrWhiteSpace(album.Description))
                            {
                                <div class="fa-album-folder__desc">@album.Description</div>
                            }
                        </a>
                    }
                </div>
            </section>
        }

        <!-- ── 타임라인 ── -->
        <section class="fa-timeline">
            <h2 class="fa-section-title">📅 타임라인
                @if (Vm.TotalCount > 0)
                {
                    <span class="fa-timeline__count">(@Vm.TotalCount)</span>
                }
            </h2>

            @if (Vm.TotalCount == 0)
            {
                <div class="fa-empty">아직 등록된 포스트가 없습니다.</div>
            }
            else
            {
                <div class="fa-timeline__list">
                    @foreach (var post in Vm.Posts)
                    {
                        <a href="/@Slug/post/@post.Id" class="fa-post-card">
                            @if (post.PhotoFileNames.Count > 0)
                            {
                                <div class="fa-post-card__thumb"
                                     style="background-image:url('@Vm.GetThumbUrl(post.Id, post.PhotoFileNames[0])')">
                                </div>
                            }
                            else if (post.VideoFileNames.Count > 0)
                            {
                                <div class="fa-post-card__thumb fa-post-card__thumb--video">
                                    <span class="fa-play-icon">▶</span>
                                </div>
                            }
                            <div class="fa-post-card__body">
                                @if (post.IsPinned)
                                {
                                    <span class="fa-pin-badge">📌</span>
                                }
                                <div class="fa-post-card__title">@post.Title</div>
                                <div class="fa-post-card__date">@post.PostedAt.ToString("yyyy. MM. dd")</div>
                                @if (post.PhotoFileNames.Count + post.VideoFileNames.Count > 0)
                                {
                                    <div class="fa-post-card__media-count">
                                        @if (post.PhotoFileNames.Count > 0)
                                        {
                                            <span>📷 @post.PhotoFileNames.Count</span>
                                        }
                                        @if (post.VideoFileNames.Count > 0)
                                        {
                                            <span>🎬 @post.VideoFileNames.Count</span>
                                        }
                                    </div>
                                }
                            </div>
                        </a>
                    }
                </div>

                @if (Vm.TotalPages > 1)
                {
                    <nav class="fa-pager" aria-label="페이지 이동">
                        <button class="fa-pager__btn" disabled="@(Vm.CurrentPage <= 1)"
                                @onclick="() => GoToPage(Vm.CurrentPage - 1)">‹ 이전</button>

                        @for (int p = Math.Max(1, Vm.CurrentPage - 2);
                                  p <= Math.Min(Vm.TotalPages, Vm.CurrentPage + 2); p++)
                        {
                            var pg = p;
                            <button class="fa-pager__btn @(pg == Vm.CurrentPage ? "fa-pager__btn--active" : "")"
                                    @onclick="() => GoToPage(pg)">@pg</button>
                        }

                        <button class="fa-pager__btn" disabled="@(Vm.CurrentPage >= Vm.TotalPages)"
                                @onclick="() => GoToPage(Vm.CurrentPage + 1)">다음 ›</button>
                    </nav>
                }
            }
        </section>

        <footer class="fa-footer">
            <p>Powered by <a href="/">Codemaru Family</a></p>
        </footer>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    protected override async Task OnParametersSetAsync()
    {
        await Vm.LoadAsync(Slug);
    }

    private async Task GoToPage(int page)
    {
        await Vm.LoadPageAsync(Slug, page);
        StateHasChanged();
    }
}
