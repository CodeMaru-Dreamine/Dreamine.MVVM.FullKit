@prefix dreamine: <https://dreamine.kr/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

dreamine:negativeLibrary rdf:type dreamine:SoftwareElement ; dreamine:element_layer "library" .
dreamine:negativeApp rdf:type dreamine:SoftwareElement ; dreamine:element_layer "application" .
dreamine:negativeLayerRelation rdf:type dreamine:SemanticRelation ;
  dreamine:relation_type "depends_on" ; dreamine:source dreamine:negativeLibrary ; dreamine:target dreamine:negativeApp .
